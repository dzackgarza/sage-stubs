#!/usr/bin/env sh
# Pre-commit hook: reject new stub quality violations in staged files.
# Install via: just install-hooks
set -e

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"

if printf '%s\n' "$staged_files" | grep -Eq '(^|/)(plan\.md|test_.*\.py|generate_.*\.py|fix_.*\.py)$'; then
    echo "pre-commit: scratch/helper artifacts are banned in commits" >&2
    printf '%s\n' "$staged_files" | grep -E '(^|/)(plan\.md|test_.*\.py|generate_.*\.py|fix_.*\.py)$' >&2
    exit 1
fi

if printf '%s\n' "$staged_files" | grep -Eq '^sage-stubs/sage/'; then
    echo "pre-commit: nested sage-stubs/sage/ layout is banned" >&2
    printf '%s\n' "$staged_files" | grep -E '^sage-stubs/sage/' >&2
    exit 1
fi

if printf '%s\n' "$staged_files" | grep -qx 'pyproject.toml'; then
    if git diff --cached -U100000 -- pyproject.toml | awk '
        /^\+\+\+|^---|^@@/ { next }
        /^\[[^]]+\]/ { section=$0 }
        /^[+-]/ && section ~ /^\[tool\.(ruff|ruff\.lint|mypy)\]/ { bad=1 }
        END { exit bad ? 0 : 1 }
    '; then
        echo "pre-commit: pyproject lint/type-check config changes are banned in stub commits" >&2
        exit 1
    fi
fi

pyi_files="$(printf '%s\n' "$staged_files" | grep -E '\.pyi$' || true)"
if [ -n "$pyi_files" ]; then
    ruff check $pyi_files
    python3 scripts/check_stubs.py $pyi_files
fi
