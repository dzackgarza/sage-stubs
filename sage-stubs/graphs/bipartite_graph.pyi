from typing import overload

from sage.graphs.graph import Graph

from sage.structure.element import Element
from sage.matrix.matrix import Matrix
class BipartiteGraph(Graph):
    left: set[object]
    right: set[object]

    def __init__(
        self,
        data: object = ...,
        partition: tuple[list[object], list[object]] | None = ...,
        check: bool = ...,
        hash_labels: bool | None = ...,
        *args: object,
        **kwds: object,
    ) -> None: ...
    def __hash__(self) -> int: ...
    def _upgrade_from_graph(self) -> None: ...
    def add_vertex(
        self, name: object | None = ..., left: bool = ..., right: bool = ...
    ) -> object | None: ...
    def add_vertices(
        self, vertices: list[object], left: bool | list[bool] = ..., right: bool | list[bool] = ...
    ) -> None: ...
    def delete_vertex(self, vertex: object, in_order: bool = ...) -> None: ...
    def delete_vertices(self, vertices: list[object]) -> None: ...
    def _flip_vertices(self, vertices: list[object]) -> None: ...
    def add_edge(self, u: object, v: object | None = ..., label: object = ...) -> None: ...
    def add_edges(self, edges: list[tuple[object, ...]], loops: bool = ...) -> None: ...
    def _check_bipartition_for_add_edges(
        self, edges: list[tuple[object, ...]]
    ) -> dict[object, bool] | bool: ...
    def allow_loops(self, new: bool, check: bool = ...) -> None: ...
    def is_bipartite(self, certificate: bool = ...) -> bool | tuple[bool, dict[object, int]]: ...
    def complement(self) -> Graph: ...
    def complement_bipartite(self) -> BipartiteGraph: ...
    def copy(self, immutable: bool | None = ...) -> BipartiteGraph: ...
    def bipartition(self) -> tuple[set[object], set[object]]: ...
