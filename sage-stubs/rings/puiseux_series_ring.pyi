from typing import Self

from sage.rings.integer import Integer
from sage.rings.laurent_series_ring import LaurentSeriesRing_generic
from sage.rings.puiseux_series_ring_element import PuiseuxSeries
from sage.rings.ring import Ring
from sage.structure.parent import Parent
from sage.structure.unique_representation import UniqueRepresentation

class PuiseuxSeriesRing(UniqueRepresentation, Parent):
    Element = PuiseuxSeries

    def __init__(self, laurent_series: LaurentSeriesRing_generic) -> None: ...
    def base_extend(self, R: Ring) -> PuiseuxSeriesRing: ...
    def change_ring(self, R: Ring) -> PuiseuxSeriesRing: ...
    def is_sparse(self) -> bool: ...
    def is_dense(self) -> bool: ...
    def is_field(self, proof: bool = True) -> bool: ...
    def fraction_field(self) -> Self: ...
    def residue_field(self) -> Ring: ...
    def uniformizer(self) -> PuiseuxSeries: ...
    def gen(self, n: int | Integer = 0) -> PuiseuxSeries: ...
    def gens(self) -> tuple[PuiseuxSeries, ...]: ...
    def ngens(self) -> int: ...
    def laurent_series_ring(self) -> LaurentSeriesRing_generic: ...
    def default_prec(self) -> int: ...
