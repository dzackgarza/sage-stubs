from sage.rings.integer import Integer
from sage.rings.ring import Field
from sage.structure.element import FieldElement
from sage.rings.rational import Rational

def shift_floor(x: Integer, shift: int) -> Integer: ...
def shift_ceil(x: Integer, shift: int) -> Integer: ...

def RealIntervalAbsoluteField(absprec: int) -> RealIntervalAbsoluteField_class: ...

class RealIntervalAbsoluteField_class(Field):
    def __init__(self, absprec: int) -> None: ...
    def absprec(self) -> int: ...

class RealIntervalAbsoluteElement(FieldElement):
    def __init__(self, parent: RealIntervalAbsoluteField_class, value: object) -> None: ...
    def lower(self) -> Rational: ...
    def midpoint(self) -> Rational: ...
    def upper(self) -> Rational: ...
    def absolute_diameter(self) -> Rational: ...
    def diameter(self) -> Rational: ...
    def endpoints(self) -> tuple[Rational, Rational]: ...
    def mpfi_prec(self) -> int: ...
    def is_positive(self) -> bool: ...
    def contains_zero(self) -> bool: ...
    def is_negative(self) -> bool: ...
    def abs(self) -> RealIntervalAbsoluteElement: ...
    def __neg__(self) -> RealIntervalAbsoluteElement: ...
    def __abs__(self) -> RealIntervalAbsoluteElement: ...
    def __bool__(self) -> bool: ...
    def __hash__(self) -> int: ...
    def _add_(self, other: RealIntervalAbsoluteElement) -> RealIntervalAbsoluteElement: ...
    def _sub_(self, other: RealIntervalAbsoluteElement) -> RealIntervalAbsoluteElement: ...
    def _mul_(self, other: RealIntervalAbsoluteElement) -> RealIntervalAbsoluteElement: ...
    def _div_(self, other: RealIntervalAbsoluteElement) -> RealIntervalAbsoluteElement: ...
    def __lshift__(self, n: int) -> RealIntervalAbsoluteElement: ...
    def __rshift__(self, n: int) -> RealIntervalAbsoluteElement: ...
    def __pow__(self, exponent: object, dummy: object) -> RealIntervalAbsoluteElement: ...
    def __getattr__(self, name: str) -> MpfrOp: ...
    def sqrt(self) -> RealIntervalAbsoluteElement: ...

class MpfrOp:
    def __init__(self, value: RealIntervalAbsoluteElement, name: str) -> None: ...
    def __call__(self, *args: object) -> RealIntervalAbsoluteElement: ...
