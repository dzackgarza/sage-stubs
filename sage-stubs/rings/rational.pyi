from typing import overload
from sage.structure.element import FieldElement
from sage.rings.rational_field import RationalField
from sage.rings.integer import Integer
from sage.rings.continued_fraction import ContinuedFraction_periodic
from sage.rings.real_mpfr import RealNumber
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.structure.factorization import Factorization
from sage.symbolic.expression import Expression
from sage.rings.infinity import PlusInfinity
from cypari2.gen import Gen

class Rational(FieldElement):
    def __init__(self, x: object = ..., base: int = ...) -> None: ...
    def parent(self) -> RationalField: ...
    
    def numerator(self) -> Integer: ...
    def denominator(self) -> Integer: ...
    def numer(self) -> Integer: ...
    def denom(self) -> Integer: ...
    
    def is_integral(self) -> bool: ...
    def is_unit(self) -> bool: ...
    
    def floor(self) -> Integer: ...
    def ceil(self) -> Integer: ...
    def round(self, mode: str = ...) -> Integer: ...
    
    def __add__(self, right: Rational) -> Rational: ...
    def __sub__(self, right: Rational) -> Rational: ...
    def __mul__(self, right: Rational) -> Rational: ...
    def __truediv__(self, other: Rational) -> Rational: ...
    def __pow__(self, n: Integer | int) -> Rational: ...
    def __neg__(self) -> Rational: ...
    def __abs__(self) -> Rational: ...
    
    def sign(self) -> int: ...
    def height(self) -> Integer: ...
    def global_height(self, prec: int | None = ...) -> RealNumber: ...
    def continued_fraction(self) -> ContinuedFraction_periodic: ...
    def sqrt(self, prec: int | None = ..., extend: bool = ..., all: bool = ...) -> Rational | RealNumber: ...
    
    # Other public methods
    def __cinit__(self) -> None: ...
    def __reduce__(self) -> tuple[object, ...]: ...
    def __index__(self) -> int: ...
    def list(self) -> list[int]: ...
    def continued_fraction_list(self, type: str = ...) -> list[int]: ...
    def __copy__(self) -> Rational: ...
    def __deepcopy__(self, memo: dict[int, object]) -> Rational: ...
    def __mpz__(self) -> int: ...
    def __mpq__(self) -> Rational: ...
    def __array_interface__(self) -> dict[str, object]: ...
    def content(self, other: Rational) -> Rational: ...
    def valuation(self, p: Integer | int) -> Integer: ...
    def local_height(self, p: Integer | int, prec: int | None = ...) -> RealNumber: ...
    def local_height_arch(self, prec: int | None = ...) -> RealNumber: ...
    def global_height_non_arch(self, prec: int | None = ...) -> RealNumber: ...
    def global_height_arch(self, prec: int | None = ...) -> RealNumber: ...
    def is_square(self) -> bool: ...
    def is_norm(self, L: object, element: bool = ..., proof: bool = ...) -> bool: ...
    def is_perfect_power(self, expected_value: bool = ...) -> bool: ...
    def squarefree_part(self) -> Rational: ...
    def is_padic_square(self, p: Integer | int, check: bool = ...) -> bool: ...
    def val_unit(self, p: Integer | int) -> tuple[Integer, Rational]: ...
    def prime_to_S_part(self, S: list[object] = ...) -> Rational: ...
    def period(self) -> int: ...
    def nth_root(self, n: int) -> Rational: ...
    def is_nth_power(self, n: int) -> bool: ...
    def __float__(self) -> float: ...
    def __hash__(self) -> int: ...
    def __getitem__(self, n: int) -> Integer: ...
    def __pos__(self) -> Rational: ...
    def __bool__(self) -> bool: ...
    def mod_ui(self, n: int) -> int: ...
    def __mod__(self, y: object) -> Integer: ...
    def norm(self) -> Rational: ...
    def relative_norm(self) -> Rational: ...
    def absolute_norm(self) -> Rational: ...
    def trace(self) -> Rational: ...
    def charpoly(self, var: str = ...) -> Polynomial: ...
    def minpoly(self, var: str = ...) -> Polynomial: ...
    def __int__(self) -> int: ...
    def as_integer_ratio(self) -> tuple[int, int]: ...
    def factor(self) -> Factorization: ...
    def support(self) -> list[Integer]: ...
    def log(self, m: object | None = ..., prec: int | None = ...) -> Expression | RealNumber | Integer | Rational: ...
    def gamma(self, *, prec: int | None = ...) -> Expression | RealNumber | Integer | Rational: ...
    def trunc(self) -> Integer: ...
    def real(self) -> Rational: ...
    def imag(self) -> Rational: ...
    def additive_order(self) -> Integer | PlusInfinity: ...
    def multiplicative_order(self) -> Integer | PlusInfinity: ...
    def is_one(self) -> bool: ...
    def is_rational(self) -> bool: ...
    def is_S_integral(self, S: list[object] = ...) -> bool: ...
    def is_S_unit(self, S: list[object] | None = ...) -> bool: ...
    def __lshift__(self, y: int) -> Rational: ...
    def __rshift__(self, y: int) -> Rational: ...
    def conjugate(self) -> Rational: ...
    def __pari__(self) -> Gen: ...
