from collections.abc import Iterable, Iterator

from sage.categories.pushout import AlgebraicExtensionFunctor
from sage.modules.free_module import FreeModule_generic as VectorSpace_class
from sage.rings.algebraic_closure_finite_field import AlgebraicClosureFiniteField_generic
from sage.rings.finite_rings.element_base import FiniteRingElement
from sage.rings.finite_rings.galois_group import GaloisGroup_GF
from sage.rings.finite_rings.hom_finite_field import FrobeniusEndomorphism_finite_field
from sage.rings.finite_rings.maps_finite_field import FiniteFieldVectorSpaceIsomorphism
from sage.rings.integer import Integer
from sage.rings.morphism import RingHomomorphism
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.polynomial.polynomial_ring import PolynomialRing_general
from sage.rings.ring import Field, Ring
from sage.structure.factorization import Factorization

class FiniteField(Field):
    def __iter__(self) -> Iterator[FiniteRingElement]: ...
    def absolute_degree(self) -> int: ...
    def from_integer(self, n: int, reverse: bool = ...) -> FiniteRingElement: ...
    def gen(self, n: int = ...) -> FiniteRingElement: ...
    def multiplicative_generator(self) -> FiniteRingElement: ...
    def ngens(self) -> int: ...
    def order(self) -> Integer: ...
    def factored_order(self) -> Factorization: ...
    def factored_unit_order(self) -> Factorization: ...
    def cardinality(self) -> Integer: ...
    def is_prime_field(self) -> bool: ...
    def modulus(self) -> Polynomial: ...
    def polynomial(self, name: str | None = ...) -> Polynomial: ...
    def unit_group_exponent(self) -> Integer: ...
    def random_element(self, *args: object, **kwds: object) -> FiniteRingElement: ...
    def some_elements(self) -> list[FiniteRingElement]: ...
    def polynomial_ring(self, variable_name: str | None = ...) -> PolynomialRing_general: ...
    def free_module(self, base: Ring | None = ..., basis: list[FiniteRingElement] | None = ..., map: bool = ...) -> VectorSpace_class | tuple[VectorSpace_class, FiniteFieldVectorSpaceIsomorphism, FiniteFieldVectorSpaceIsomorphism]: ...
    def construction(self) -> tuple[AlgebraicExtensionFunctor, FiniteField] | None: ...
    def extension(self, modulus: int | Polynomial, name: str | None = ..., names: str | tuple[str, ...] | None = ..., map: bool = ..., embedding: RingHomomorphism | None = ...) -> FiniteField | tuple[FiniteField, RingHomomorphism]: ...
    def subfield(self, degree: int, name: str | None = ..., map: bool = ...) -> FiniteField | tuple[FiniteField, RingHomomorphism, RingHomomorphism]: ...
    def subfields(self, degree: int = ..., name: str | None = ...) -> list[tuple[FiniteField, RingHomomorphism]]: ...
    def algebraic_closure(self, name: str = ..., **kwds: object) -> AlgebraicClosureFiniteField_generic: ...
    def is_conway(self) -> bool: ...
    def an_embedding(self, K: FiniteField) -> RingHomomorphism: ...
    def embeddings(self, K: FiniteField) -> list[RingHomomorphism]: ...
    def frobenius_endomorphism(self, n: int = ...) -> FrobeniusEndomorphism_finite_field: ...
    def galois_group(self) -> GaloisGroup_GF: ...
    def dual_basis(self, basis: list[FiniteRingElement] | None = ..., check: bool = ...) -> list[FiniteRingElement]: ...
    def from_bytes(self, input_bytes: bytes | Iterable[int], byteorder: str = ...) -> FiniteRingElement: ...

    # Required from Phase 2 explicit list that might not have been matched yet
    def characteristic(self) -> int: ...
    def degree(self) -> int: ...
    def prime_subfield(self) -> FiniteField: ...
    def is_perfect(self) -> bool: ...
    def zeta(self, n: int = ...) -> FiniteRingElement: ...

def unpickle_FiniteField_ext(_type: type, order: int, variable_name: str, modulus: Polynomial, kwargs: dict[str, object]) -> FiniteField: ...
def unpickle_FiniteField_prm(_type: type, order: int, variable_name: str, kwargs: dict[str, object]) -> FiniteField: ...
