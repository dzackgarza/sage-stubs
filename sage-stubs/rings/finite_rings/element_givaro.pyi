from collections.abc import Iterator

from sage.rings.finite_rings.element_base import Cache_base, FinitePolyExtElement


class FiniteField_givaroElement(FinitePolyExtElement):
    def __init__(self, parent: FiniteField_givaro) -> None: ...


class Cache_givaro(Cache_base):
    def exponent(self) -> int: ...
    def order_c(self) -> int: ...
    def characteristic(self) -> int: ...
    def gen(self) -> FiniteField_givaroElement: ...
    def element_from_data(
        self,
        e: FiniteField_givaroElement | int | str | None,
    ) -> FiniteField_givaroElement: ...
    def int_to_log(self, i: int) -> int: ...
    def log_to_int(self, i: int) -> int: ...
    def random_element(self) -> FiniteField_givaroElement: ...
    def order(self) -> int: ...
    def fetch_int(self, number: int) -> FiniteField_givaroElement: ...
    def a_times_b_plus_c(
        self,
        a: FiniteField_givaroElement,
        b: FiniteField_givaroElement,
        c: FiniteField_givaroElement,
    ) -> FiniteField_givaroElement: ...
    def a_times_b_minus_c(
        self,
        a: FiniteField_givaroElement,
        b: FiniteField_givaroElement,
        c: FiniteField_givaroElement,
    ) -> FiniteField_givaroElement: ...
    def c_minus_a_times_b(
        self,
        a: FiniteField_givaroElement,
        b: FiniteField_givaroElement,
        c: FiniteField_givaroElement,
    ) -> FiniteField_givaroElement: ...


class FiniteField_givaro_iterator(Iterator[FiniteField_givaroElement]):
    def __init__(self, cache: Cache_givaro) -> None: ...
    def __next__(self) -> FiniteField_givaroElement: ...
    def __iter__(self) -> FiniteField_givaro_iterator: ...


from sage.rings.finite_rings.finite_field_givaro import FiniteField_givaro
