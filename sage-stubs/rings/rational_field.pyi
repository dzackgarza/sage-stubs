from collections.abc import Iterator

from sage.categories.map import Map
from sage.rings.infinity import PlusInfinity
from sage.rings.integer import Integer
from sage.rings.number_field.number_field_element import NumberFieldElement
from sage.rings.number_field.number_field import NumberField_generic
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.qqbar import AlgebraicField
from sage.rings.rational import Rational
from sage.rings.ring import Field
from sage.structure.parent import Parent
from sage.structure.sequence import Sequence_generic

class RationalField(Field):
    def __init__(self) -> None: ...
    def _repr_(self) -> str: ...
    def completion(
        self, p: int | Integer | PlusInfinity, prec: int, extras: dict[str, str] = ...
    ) -> Field: ...
    def discriminant(self) -> Integer: ...
    def absolute_discriminant(self) -> Integer: ...
    def class_number(self) -> Integer: ...
    def signature(self) -> tuple[Integer, Integer]: ...
    def embeddings(self, K: Field) -> Sequence_generic: ...
    def automorphisms(self) -> Sequence_generic: ...
    def places(self, all_complex: bool = ..., prec: int | PlusInfinity | None = ...) -> list[Map]: ...
    def _coerce_map_from_(self, S: Parent | type[int]) -> Map | None: ...
    def is_field(self, proof: bool = ...) -> bool: ...
    def characteristic(self) -> Integer: ...
    def gen(self, n: int = ...) -> Rational: ...
    def gens(self) -> tuple[Rational]: ...
    def ngens(self) -> Integer: ...
    def degree(self) -> Integer: ...
    def absolute_degree(self) -> Integer: ...
    def maximal_order(self) -> Parent: ...
    def power_basis(self) -> list[Rational]: ...
    def extension(
        self,
        poly: Polynomial | NumberFieldElement,
        name: str | None = ...,
        names: str | tuple[str, ...] | None = ...,
        latex_name: str | None = ...,
        latex_names: str | tuple[str, ...] | None = ...,
        *args: str,
        **kwds: str,
    ) -> NumberField_generic: ...
    def algebraic_closure(self) -> AlgebraicField: ...
    def zeta(self, n: int = ...) -> Rational: ...
    def random_element(
        self,
        num_bound: int | None = ...,
        den_bound: int | None = ...,
        distribution: str | None = ...,
    ) -> Rational: ...
    def some_elements(self) -> Iterator[Rational]: ...
    def _an_element_(self) -> Rational: ...

QQ: RationalField
Q: RationalField
