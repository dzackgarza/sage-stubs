from typing import TYPE_CHECKING
from sage.rings.ring import Field

if TYPE_CHECKING:
    from sage.rings.function_field.element import FunctionFieldElement
    from sage.rings.function_field.order import FunctionFieldOrder

class FunctionField(Field):
    def constant_base_field(self) -> Field: ...
    def base_field(self) -> Field: ...
    def gen(self) -> "FunctionFieldElement": ...
    def maximal_order(self) -> "FunctionFieldOrder": ...
    def is_rational_function_field(self) -> bool: ...
