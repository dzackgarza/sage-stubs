from typing import Literal, overload
from sage.structure.element import FieldElement
from sage.structure.parent import Parent
from sage.categories.morphism import Morphism
from sage.rings.integer import Integer
from sage.rings.infinity import PlusInfinity
from sage.rings.number_field.number_field_element import NumberFieldElement
from sage.rings.qqbar import AlgebraicNumber
from sage.rings.polynomial.polynomial_element import Polynomial

def late_import() -> None: ...
def UCF_sqrt_int(N: Integer | int, UCF: UniversalCyclotomicField) -> UniversalCyclotomicFieldElement: ...

class UCFtoQQbar(Morphism):
    def __init__(self, UCF: UniversalCyclotomicField) -> None: ...

class UniversalCyclotomicFieldElement(FieldElement):
    _obj: object
    def __init__(self, parent: UniversalCyclotomicField, obj: object) -> None: ...
    def __bool__(self) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def real(self) -> UniversalCyclotomicFieldElement: ...
    real_part = real
    def imag(self) -> UniversalCyclotomicFieldElement: ...
    imag_part = imag
    def is_real(self) -> bool: ...
    def is_integral(self) -> bool: ...
    def conductor(self) -> Integer: ...
    def to_cyclotomic_field(self, R: Parent | None = ...) -> NumberFieldElement: ...
    def __hash__(self) -> int: ...
    def __float__(self) -> float: ...
    def __complex__(self) -> complex: ...
    def denominator(self) -> Integer: ...
    def multiplicative_order(self) -> Integer | PlusInfinity: ...
    def additive_order(self) -> Integer | PlusInfinity: ...
    def is_rational(self) -> bool: ...
    def inverse(self) -> UniversalCyclotomicFieldElement: ...
    def is_square(self) -> bool: ...
    
    @overload
    def sqrt(self, extend: bool = ..., all: Literal[False] = ...) -> UniversalCyclotomicFieldElement: ...
    @overload
    def sqrt(self, extend: bool = ..., all: Literal[True] = ...) -> list[UniversalCyclotomicFieldElement]: ...
    @overload
    def sqrt(self, extend: bool = ..., all: bool = ...) -> UniversalCyclotomicFieldElement | list[UniversalCyclotomicFieldElement]: ...
    
    def conjugate(self) -> UniversalCyclotomicFieldElement: ...
    def galois_conjugates(self, n: int | Integer | None = ...) -> list[UniversalCyclotomicFieldElement]: ...
    def __abs__(self) -> AlgebraicNumber: ...
    abs = __abs__
    def norm_of_galois_extension(self) -> Integer: ...
    def minpoly(self, var: str = ...) -> Polynomial: ...

class UniversalCyclotomicField(Parent):
    Element = UniversalCyclotomicFieldElement
    def __init__(self, names: object = ...) -> None: ...
    def an_element(self) -> UniversalCyclotomicFieldElement: ...
    def some_elements(self) -> tuple[UniversalCyclotomicFieldElement, ...]: ...
    def is_exact(self) -> bool: ...
    def zero(self) -> UniversalCyclotomicFieldElement: ...
    def one(self) -> UniversalCyclotomicFieldElement: ...
    def characteristic(self) -> Integer: ...
    def gen(self, n: int | Integer, k: int | Integer = ...) -> UniversalCyclotomicFieldElement: ...
    zeta = gen
