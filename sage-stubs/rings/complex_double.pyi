class FloatToCDF:
    def __init__(self, R: type[int | float] | RealDoubleField_class) -> None: ...
    def _call_(self, x: SupportsFloat) -> ComplexDoubleElement: ...
    def _repr_type(self) -> str: ...

class ComplexToCDF:
    def __init__(self, S: type[complex]) -> None: ...
    def _call_(self, x: _ComplexParts) -> ComplexDoubleElement: ...
    def _repr_type(self) -> str: ...

def ComplexDoubleField() -> ComplexDoubleField_class: ...
