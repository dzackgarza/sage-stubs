from collections.abc import Callable
from typing import Protocol, SupportsFloat

from sage.categories.morphism import Morphism
from sage.categories.pushout import AlgebraicClosureFunctor
from sage.structure.factorization import Factorization
from sage.rings.complex_mpfr import ComplexField_class, ComplexNumber
from sage.rings.integer import Integer
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.real_mpfr import RealField_class
from sage.rings.real_double import RealDoubleElement, RealDoubleField_class

class gen: ...

class _ComplexDoubleConvertible(Protocol):
    def _complex_double_(self, CDF: ComplexDoubleField_class) -> ComplexDoubleElement: ...

class _ComplexParts(Protocol):
    real: float
    imag: float

type _ComplexDoubleInput = (
    ComplexDoubleElement
    | ComplexNumber
    | _ComplexDoubleConvertible
    | _ComplexParts
    | complex
    | SupportsFloat
    | str
    | tuple[SupportsFloat, SupportsFloat]
)

class ComplexDoubleField_class:
    def __init__(self) -> None: ...
    def __reduce__(self) -> tuple[Callable[[], ComplexDoubleField_class], tuple[()]]: ...
    def is_exact(self) -> bool: ...
    def __richcmp__(self, other: ComplexDoubleField_class, op: int) -> bool: ...
    def __hash__(self) -> int: ...
    def characteristic(self) -> Integer: ...
    def random_element(self, xmin: float = -1, xmax: float = 1, ymin: float = -1, ymax: float = 1) -> ComplexDoubleElement: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def __call__(self, x: _ComplexDoubleInput | None = None, im: SupportsFloat | None = None) -> ComplexDoubleElement: ...
    def _element_constructor_(self, x: _ComplexDoubleInput) -> ComplexDoubleElement: ...
    def _coerce_map_from_(self, S: type[int | float | complex] | ComplexDoubleField_class | RealField_class) -> Morphism | None: ...
    def _magma_init_(self, magma: str) -> str: ...
    def _fricas_init_(self) -> str: ...
    def prec(self) -> int: ...
    def precision(self) -> int: ...
    def to_prec(self, prec: int) -> ComplexDoubleField_class | ComplexField_class: ...
    def gen(self, n: int = 0) -> ComplexDoubleElement: ...
    def ngens(self) -> int: ...
    def algebraic_closure(self) -> ComplexDoubleField_class: ...
    def real_double_field(self) -> RealDoubleField_class: ...
    def pi(self) -> ComplexDoubleElement: ...
    def construction(self) -> tuple[AlgebraicClosureFunctor, RealDoubleField_class]: ...
    def zeta(self, n: int = 2) -> ComplexDoubleElement: ...
    def _factor_univariate_polynomial(self, f: Polynomial) -> Factorization: ...

