from typing import Self, TypeAlias
from sage.rings.integer import Integer
from sage.rings.rational import Rational
from sage.rings.real_mpfr import RealNumber

_RealIntervalInput: TypeAlias = None | int | float | Integer | Rational | RealNumber | str | bytes | tuple[RealNumber | Rational | Integer | int | float | str | bytes, RealNumber | Rational | Integer | int | float | str | bytes] | list[RealNumber | Rational | Integer | int | float | str | bytes]

class RealIntervalField:
    def to_prec(self, prec: int | Integer) -> RealIntervalField: ...
    def __call__(self, x: _RealIntervalInput = None, y: _RealIntervalInput = None, *, base: int = 10) -> RealIntervalFieldElement: ...

class RealIntervalFieldElement:
    def __init__(self, parent: RealIntervalField, x: _RealIntervalInput, base: int = 10) -> None: ...
    def parent(self, x: None = None) -> RealIntervalField: ...
    def lower(self) -> RealNumber: ...
    def upper(self) -> RealNumber: ...
    def overlaps(self, other: Self) -> bool: ...
