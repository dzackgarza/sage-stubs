from typing import Self

class RealIntervalField:
    def __call__(self, *args: object, **kwargs: object) -> RealIntervalFieldElement: ...

class RealIntervalFieldElement:
    def __init__(self, parent: RealIntervalField, x: object, base: int = 10) -> None: ...
    def parent(self, x: None = None) -> RealIntervalField: ...
    def lower(self) -> object: ...
    def upper(self) -> object: ...
    def overlaps(self, other: Self) -> bool: ...
