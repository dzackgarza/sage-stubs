from typing import TypeAlias, TypeVar, overload

from sage.structure.factorization import Factorization
from sage.rings.rational import Rational

_T = TypeVar("_T")
_IntegerDigit: TypeAlias = int | Integer
_IntegerInput: TypeAlias = int | Integer | Rational | float | str | bytes | list[_IntegerDigit] | tuple[_IntegerDigit, ...] | None
_IntegerComparable: TypeAlias = int | Integer | Rational | float

class Integer:
    def __init__(self, x: _IntegerInput = None, base: int = 0) -> None: ...
    def __index__(self) -> int: ...
    def __neg__(self) -> Integer: ...
    @overload
    def __mul__(self, right: int | Integer) -> Integer: ...
    @overload
    def __mul__(self, right: Rational) -> Rational: ...
    @overload
    def __mul__(self, right: list[_T]) -> list[_T]: ...
    @overload
    def __mul__(self, right: tuple[_T, ...]) -> tuple[_T, ...]: ...
    @overload
    def __mul__(self, right: str) -> str: ...
    @overload
    def __mul__(self, right: bytes) -> bytes: ...
    @overload
    def __sub__(self, right: int | Integer) -> Integer: ...
    @overload
    def __sub__(self, right: Rational) -> Rational: ...
    @overload
    def __rmul__(self, left: int | Integer) -> Integer: ...
    @overload
    def __rmul__(self, left: Rational) -> Rational: ...
    @overload
    def __rmul__(self, left: list[_T]) -> list[_T]: ...
    @overload
    def __rmul__(self, left: tuple[_T, ...]) -> tuple[_T, ...]: ...
    @overload
    def __rmul__(self, left: str) -> str: ...
    @overload
    def __rmul__(self, left: bytes) -> bytes: ...
    @overload
    def __rsub__(self, left: int | Integer) -> Integer: ...
    @overload
    def __rsub__(self, left: Rational) -> Rational: ...
    def __lt__(self, other: _IntegerComparable) -> bool: ...
    def __le__(self, other: _IntegerComparable) -> bool: ...
    def __gt__(self, other: _IntegerComparable) -> bool: ...
    def __ge__(self, other: _IntegerComparable) -> bool: ...
    def is_prime(self) -> bool: ...
    def is_square(self) -> bool: ...
    def ndigits(self, base: int = 10) -> int: ...
    def factor(self) -> Factorization: ...
    def sqrt(self) -> Integer | Rational: ...
    def powermod(self, exp: Integer, mod: Integer) -> Integer: ...
    def gcd(self, other: Integer) -> Integer: ...
    def lcm(self, other: Integer) -> Integer: ...
    def moebius(self) -> int: ...
    def euler_phi(self) -> Integer: ...
