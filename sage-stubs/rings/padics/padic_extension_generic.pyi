

from sage.rings.integer import Integer
from sage.rings.padics.padic_generic import pAdicGeneric

from sage.modules.free_module import FreeModule_generic
from sage.rings.number_field.number_field import NumberField_generic
from sage.rings.number_field.order import Order
from sage.rings.padics.local_generic import LocalGeneric
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.polynomial.polynomial_ring import PolynomialRing_general
from sage.structure.element import Element
class pAdicExtensionGeneric(pAdicGeneric):
    def _extension_type(self) -> str: ...
    def _repr_(self, do_latex: bool = ...) -> str: ...
    def defining_polynomial(
        self, var: str | None = ..., exact: bool = ...
    ) -> Polynomial: ...
    def exact_field(self) -> NumberField_generic: ...
    def exact_ring(self) -> Order: ...
    def modulus(self, exact: bool = ...) -> Polynomial: ...
    def ground_ring(self) -> LocalGeneric: ...
    def ground_ring_of_tower(self) -> LocalGeneric: ...
    def polynomial_ring(self) -> PolynomialRing_general: ...
    def random_element(self) -> Element: ...
    def free_module(
        self,
        base: LocalGeneric | None = ...,
        basis: list[Element] | None = ...,
        map: bool = ...,
    ) -> tuple[FreeModule_generic, pAdicModuleIsomorphism, pAdicModuleIsomorphism]: ...
    def variable_name(self) -> str: ...
    def latex_name(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...


class pAdicModuleIsomorphism:
    def _repr_type(self) -> str: ...
    def is_injective(self) -> bool: ...
    def is_surjective(self) -> bool: ...
