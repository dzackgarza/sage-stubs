from __future__ import annotations

from sage.rings.finite_rings.finite_field_base import FiniteField
from sage.rings.padics.padic_extension_generic import pAdicExtensionGeneric
from sage.structure.element import Element


class UnramifiedExtensionGeneric(pAdicExtensionGeneric):
    def __init__(self, poly, prec, print_mode, names, element_class) -> None: ...
    def _extension_type(self) -> str: ...
    def absolute_f(self) -> int: ...
    def residue_class_field(self) -> FiniteField: ...
    def residue_ring(self, n: int) -> FiniteField: ...
    def discriminant(self, K: pAdicExtensionGeneric | None = ...) -> int: ...
    def is_galois(self, K: pAdicExtensionGeneric | None = ...) -> bool: ...
    def gen(self, n: int = ...) -> Element: ...
    def _frob_gen(self, arithmetic: bool = ...) -> Element: ...
    def uniformizer_pow(self, n: int) -> Element: ...
    def uniformizer(self) -> Element: ...
    def _uniformizer_print(self) -> str: ...
    def _unram_print(self) -> str: ...
    def has_pth_root(self) -> bool: ...
    def has_root_of_unity(self, n: int) -> bool: ...
