from sage.rings.padics.padic_generic import pAdicGeneric
from sage.rings.rational_field import RationalField
from sage.rings.integer_ring import IntegerRing_class
from sage.rings.integer import Integer
from sage.structure.element import Element
from sage.plot.graphics import Graphics

class pAdicBaseGeneric(pAdicGeneric):
    def exact_field(self) -> RationalField: ...
    def exact_ring(self) -> IntegerRing_class: ...
    def is_isomorphic(self, ring: object) -> bool: ...
    def gen(self, n: int = ...) -> Element: ...
    def modulus(self) -> Integer: ...
    def absolute_discriminant(self) -> Integer: ...
    def discriminant(self) -> Integer: ...
    def is_abelian(self) -> bool: ...
    def is_normal(self) -> bool: ...
    def uniformizer(self) -> Element: ...
    def uniformizer_pow(self, n: int) -> Element: ...
    def has_pth_root(self) -> bool: ...
    def has_root_of_unity(self, n: int) -> bool: ...
    def zeta(self, n: int | None = ...) -> Element: ...
    def zeta_order(self) -> Integer: ...
    def plot(self, *args: object, **kwds: object) -> Graphics: ...
