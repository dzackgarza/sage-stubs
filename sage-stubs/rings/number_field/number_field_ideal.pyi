from sage.rings.integer import Integer
from sage.rings.finite_rings.finite_field_base import FiniteField
from sage.rings.number_field.number_field_element import NumberFieldElement

class NumberFieldIdeal:
    def norm(self) -> Integer: ...
    def absolute_norm(self) -> Integer: ...
    def is_prime(self) -> bool: ...
    def is_principal(self, proof: bool | None = ...) -> bool: ...
    def gens(self) -> tuple[NumberFieldElement, ...]: ...
    def ramification_index(self) -> int: ...
    def residue_field(self, names: str | None = ...) -> FiniteField: ...
    def residue_class_degree(self) -> int: ...

class NumberFieldFractionalIdeal(NumberFieldIdeal): ...
