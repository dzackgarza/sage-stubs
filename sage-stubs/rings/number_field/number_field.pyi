def NumberFieldTower(
    polynomials: list[Polynomial] | tuple[Polynomial, ...],
    names: str | Sequence[str],
    check: bool = ...,
    embeddings: Sequence[RingElement | None] | None = ...,
    latex_names: str | Sequence[str | None] | None = ...,
    assume_disc_small: bool = ...,
    maximize_at_primes: Sequence[Integer | int] | None = ...,
    structures: Sequence[NumberFieldStructure | None] | None = ...,
) -> NumberField_generic | RationalField: ...

