class NumberField_absolute(NumberField_generic):
    def base_field(self) -> RationalField: ...
    def is_absolute(self) -> bool: ...
    def absolute_polynomial(self) -> Polynomial: ...
    def absolute_generator(self) -> NumberFieldElement: ...
    def optimized_representation(self, name: str | None = ..., both_maps: bool = ...) -> NumberField_absolute | tuple[NumberField_absolute, RingHomomorphism, RingHomomorphism]: ...
    def optimized_subfields(self, name: str | None = ...) -> list[tuple[NumberField_absolute, RingHomomorphism, RingHomomorphism]]: ...
    def change_names(self, names: str | tuple[str, ...]) -> NumberField_absolute: ...
    def subfields(self, degree: int = ..., name: str | None = ...) -> list[tuple[NumberField_absolute, RingHomomorphism, RingHomomorphism]]: ...
    @overload
    def order(self) -> PlusInfinity: ...
    @overload
    def order(self, *args: _NumberFieldElementInput | Sequence[_NumberFieldElementInput], **kwds: _OrderKwds) -> NumberFieldOrder: ...
    def free_module(self, base: RationalField | None = ..., map: bool = ...) -> Parent | tuple[Parent, RingHomomorphism, RingHomomorphism]: ...
    def absolute_vector_space(self) -> tuple[Parent, RingHomomorphism, RingHomomorphism]: ...
    def galois_closure(self, names: str | tuple[str, ...] | None = ..., map: bool = ..., algorithm: str | None = ...) -> NumberField_absolute | tuple[NumberField_absolute, RingHomomorphism]: ...
    def automorphisms(self) -> list[RingHomomorphism]: ...
    def embeddings(self, K: Field) -> list[RingHomomorphism]: ...
    def minkowski_embedding(self, B: Sequence[_NumberFieldElementInput] | None = ..., prec: int | None = ...) -> Matrix: ...
    def logarithmic_embedding(self, units: list[NumberFieldElement], prec: int = ...) -> list[list[float]]: ...
    def places(self, all_complex: bool = ..., prec: int | None = ...) -> list[RingHomomorphism]: ...
    def real_places(self, prec: int | None = ...) -> list[RingHomomorphism]: ...
    def abs_val(self, x: NumberFieldElement, prec: int | None = ...) -> float: ...
    def relativize(self, alpha: NumberFieldElement | RingHomomorphism, names: str | tuple[str, ...], structure: NumberFieldStructure | None = ...) -> NumberField_generic: ...
    def absolute_degree(self) -> int: ...
    def relative_degree(self) -> int: ...
    def relative_polynomial(self) -> Polynomial: ...
    def relative_vector_space(self) -> tuple[Parent, RingHomomorphism, RingHomomorphism]: ...
    def absolute_discriminant(self) -> Integer: ...
    def relative_discriminant(self) -> Integer: ...
    def absolute_different(self) -> NumberFieldIdeal: ...
    def relative_different(self) -> NumberFieldIdeal: ...
    def hilbert_symbol(self, a: NumberFieldElement, b: NumberFieldElement, P: AbstractOrder) -> int: ...
    def hilbert_symbol_negative_at_S(self, S: list[AbstractOrder], b: NumberFieldElement | None = ...) -> NumberFieldElement: ...
    def hilbert_conductor(self, a: NumberFieldElement, b: NumberFieldElement) -> NumberFieldIdeal: ...
    def elements_of_bounded_height(self, bound: int | Integer, tolerance: float = ..., precision: int = ...) -> list[NumberFieldElement]: ...

class NumberField_cyclotomic(NumberField_absolute, AbstractNumberField_cyclotomic):
    def __init__(self, n: int | Integer, names: str | tuple[str, ...], embedding: _EmbeddingInput | None = ..., assume_disc_small: bool = ..., maximize_at_primes: list[int | Integer] | None = ...) -> None: ...
    def construction(self) -> tuple[type, tuple[int | Integer]]: ...
    def is_galois(self) -> bool: ...
    def is_abelian(self) -> bool: ...
    def is_isomorphic(self, other: NumberField_generic, isomorphism_maps: bool = ...) -> bool | tuple[bool, RingHomomorphism]: ...
    def complex_embedding(self, prec: int = ...) -> RingHomomorphism: ...
    def embeddings(self, K: Field) -> list[RingHomomorphism]: ...
    def complex_embeddings(self, prec: int = ...) -> list[RingHomomorphism]: ...
    def real_embeddings(self, prec: int = ...) -> list[RingHomomorphism]: ...
    def signature(self) -> tuple[int, int]: ...
    def different(self) -> NumberFieldIdeal: ...
    def discriminant(self, v: Sequence[_NumberFieldElementInput] | None = ...) -> Integer | Rational: ...
    def next_split_prime(self, p: int | Integer = ...) -> Integer: ...
    def zeta_order(self) -> int: ...
    def zeta(self, n: int = ..., all: bool = ...) -> NumberFieldElement | list[NumberFieldElement]: ...
    def number_of_roots_of_unity(self) -> int: ...
    def roots_of_unity(self) -> list[NumberFieldElement]: ...

class NumberField_quadratic(NumberField_absolute, AbstractNumberField_quadratic):
    def __init__(
        self,
        polynomial: Polynomial,
        name: str | None = ...,
        latex_name: str | None = ...,
        check: bool = ...,
        embedding: _EmbeddingInput | None = ...,
        assume_disc_small: bool = ...,
        maximize_at_primes: list[int | Integer] | None = ...,
        structure: NumberFieldStructure | None = ...,
    ) -> None: ...
    def discriminant(self, v: Sequence[_NumberFieldElementInput] | None = ...) -> Integer | Rational: ...
    def is_galois(self) -> bool: ...
    def class_number(self, proof: bool = ...) -> Integer: ...
    def hilbert_class_field_defining_polynomial(self, name: str | None = ...) -> Polynomial: ...
    def hilbert_class_field(self, name: str | None = ...) -> NumberField_absolute: ...
    def hilbert_class_polynomial(self) -> Polynomial: ...
    def number_of_roots_of_unity(self) -> int: ...
    def order_of_conductor(self, conductor: int | Integer, names: str | tuple[str, ...] | None = ...) -> NumberFieldOrder: ...
