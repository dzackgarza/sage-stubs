    def change_names(self, names: tuple[str, ...] | str) -> NumberField_relative: ...
    def subfields(self, degree: int = ..., name: str | None = ...) -> Sequence: ...
    def is_absolute(self) -> bool: ...
    def gens(self) -> tuple: ...
    def _first_ngens(self, n: int) -> tuple: ...
    def ngens(self) -> int: ...
    def gen(self, n: int = ...) -> NumberField_generic: ...
    def galois_closure(self, names: str | None = ...) -> NumberField_generic: ...
    def composite_fields(
        self,
