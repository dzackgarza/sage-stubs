    def is_CM_extension(self) -> bool: ...
    def free_module(self, base=None, basis=None, map: bool = ...): ...
    def relative_vector_space(self, base=None, *args, **kwds): ...
    def absolute_vector_space(self, base=None, *args, **kwds): ...
