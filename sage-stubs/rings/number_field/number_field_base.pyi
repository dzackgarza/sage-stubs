from sage.matrix.matrix2 import Matrix
from sage.rings.integer import Integer
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.ring import Field
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.structure.sage_object import SageCoercionAtom

from .order import Order

type _PrimeListInput = Integer | int | list[Integer | int] | None

class NumberField(Field):
    def _pushout_(self, other: Parent | Element | SageCoercionAtom) -> Parent | None: ...
    def ring_of_integers(
        self, v: _PrimeListInput = ..., assume_maximal: bool | str | None = ...
    ) -> Order: ...
    def OK(self, v: _PrimeListInput = ..., assume_maximal: bool | str | None = ...) -> Order: ...
    def maximal_order(self) -> Order: ...
    def is_absolute(self) -> bool: ...
    def signature(self) -> tuple[int, int]: ...
    def degree(self) -> int: ...
    def discriminant(self) -> Integer: ...
    def minkowski_bound(self) -> Element: ...
    def bach_bound(self) -> Element | Integer: ...
    def _init_embedding_approx(self) -> None: ...
    def _get_embedding_approx(self, i: int) -> Element: ...
    def _matrix_charpoly(self, M: Matrix, var: str) -> Polynomial: ...
