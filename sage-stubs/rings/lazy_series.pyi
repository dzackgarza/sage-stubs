from sage.rings.polynomial.polynomial_element import Polynomial

from sage.structure.element import Element

class LazyCauchyProductSeries: ...

class LazyPowerSeries(LazyCauchyProductSeries):
    def is_unit(self) -> bool: ...
    def exponential(self) -> LazyPowerSeries: ...
    def compute_coefficients(self, i: int) -> None: ...
    def __call__(self, *g: Element) -> Element: ...
    def revert(self) -> LazyPowerSeries: ...
    def hadamard_product(self, other: LazyPowerSeries) -> LazyPowerSeries: ...
    def egf_to_ogf(self) -> LazyPowerSeries: ...
    def ogf_to_egf(self) -> LazyPowerSeries: ...
    def derivative(self, *args: Element | int | str) -> LazyPowerSeries: ...
    def adams_operator(self, p: int) -> LazyPowerSeries: ...
    def integral(self, variable: Element | int | str | list[Element] | None = None, *, constants: list[Element] | None = None) -> LazyPowerSeries: ...
    def polynomial(self, degree: int | None = None, names: str | tuple[str, ...] | list[str] | None = None) -> Polynomial: ...
    def add_bigoh(self, prec: int) -> LazyPowerSeries: ...
    
    compose = __call__
    compositional_inverse = revert
    O = add_bigoh
