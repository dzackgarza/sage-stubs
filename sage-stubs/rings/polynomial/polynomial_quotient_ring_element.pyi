from sage.rings.ring import Ring
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.structure.element import CommutativeRingElement, Element
from sage.rings.number_field.number_field import NumberField_generic
from sage.categories.morphism import Morphism
from sage.structure.factorization import Factorization
from sage.matrix.matrix import Matrix
from sage.rings.polynomial.polynomial_singular_interface import Polynomial_singular_repr

class PolynomialQuotientRingElement(Polynomial_singular_repr, CommutativeRingElement):
    def __init__(self, parent: Ring, polynomial: Polynomial, check: bool = True) -> None: ...
    def is_unit(self) -> bool: ...
    def field_extension(self, names: str | tuple[str, ...]) -> tuple[NumberField_generic, Morphism, Morphism]: ...
    def charpoly(self, var: str | Element | None = None) -> Polynomial: ...
    def fcp(self, var: str | Element = 'x') -> Factorization: ...
    def lift(self) -> Polynomial: ...
    def list(self, copy: bool = True) -> list[Element]: ...
    def matrix(self) -> Matrix: ...
    def minpoly(self, var: str | Element | None = None) -> Polynomial: ...
    def norm(self) -> Element: ...
    def trace(self) -> Element: ...
    def rational_reconstruction(self, *args: object, **kwargs: object) -> Polynomial: ...
