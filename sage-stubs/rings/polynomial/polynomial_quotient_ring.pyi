from sage.rings.integer import Integer
from sage.rings.ring import Ring
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.polynomial.polynomial_quotient_ring_element import PolynomialQuotientRingElement
from sage.structure.element import Element
from sage.categories.functor import Functor
from sage.rings.quotient_ring import QuotientRing_generic
from sage.rings.number_field.number_field import NumberField_generic

class PolynomialQuotientRing_generic(QuotientRing_generic):
    def __init__(self, ring: Ring, polynomial: Polynomial, name: str | None = None, category: object = None) -> None: ...
    def lift(self, x: object) -> Polynomial: ...
    def construction(self) -> tuple[Functor, Ring]: ...
    def base_ring(self) -> Ring: ...
    def cardinality(self) -> Integer: ...
    def is_finite(self) -> bool: ...
    def characteristic(self) -> Integer: ...
    def degree(self) -> Integer: ...
    def discriminant(self) -> Element: ...
    def gen(self, n: int = 0) -> PolynomialQuotientRingElement: ...
    def is_field(self, proof: bool = True) -> bool: ...
    def is_integral_domain(self, proof: bool = True) -> bool: ...
    def krull_dimension(self) -> Integer: ...
    def modulus(self) -> Polynomial: ...
    def ngens(self) -> Integer: ...
    def number_field(self) -> NumberField_generic: ...
    def polynomial_ring(self) -> Ring: ...
    def fraction_field(self) -> Ring: ...
    def random_element(self, *args: object, **kwds: object) -> PolynomialQuotientRingElement: ...
    def S_class_group(self, S: object, proof: bool = True) -> list[tuple[tuple[PolynomialQuotientRingElement, ...], int]]: ...
    def class_group(self, proof: bool = True) -> list[tuple[tuple[PolynomialQuotientRingElement, ...], int]]: ...
    def S_units(self, S: object, proof: bool = True) -> list[PolynomialQuotientRingElement]: ...
    def units(self, proof: bool = True) -> list[PolynomialQuotientRingElement]: ...
    def selmer_generators(self, S: object, m: int, proof: bool = True) -> list[PolynomialQuotientRingElement]: ...
