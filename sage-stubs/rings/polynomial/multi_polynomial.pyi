from sage.structure.element import Element
from sage.structure.element import CommutativeAlgebraElement
from sage.rings.polynomial.polydict import ETuple
from sage.rings.ideal import Ideal_generic as Ideal

class MPolynomial(CommutativeAlgebraElement):
    def degree(self, x: MPolynomial | None = None) -> int: ...
    def total_degree(self) -> int: ...
    def variables(self) -> tuple[MPolynomial, ...]: ...
    def monomials(self) -> list[MPolynomial]: ...
    def coefficients(self) -> list[Element]: ...
    def coefficient(self, degrees: ETuple | dict[object, int]) -> Element: ...
    def is_homogeneous(self) -> bool: ...
    def homogenize(self, var: str = 'h') -> MPolynomial: ...
    def gradient(self) -> list[MPolynomial]: ...
    def jacobian_ideal(self) -> Ideal: ...

class MPolynomial_libsingular(MPolynomial): ...
