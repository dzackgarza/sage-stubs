from sage.rings.integer import Integer
from sage.rings.ring import Ring, CommutativeRing
from sage.rings.ideal import Ideal
from sage.rings.polynomial.multi_polynomial import MPolynomial
from sage.categories.morphism import Morphism
from sage.categories.functor import Functor
from sage.rings.polynomial.term_order import TermOrder

class MPolynomialRing_base(Ring):
    def __init__(self, base_ring: Ring, n: int, names: str | tuple[str, ...], order: str | TermOrder) -> None: ...
    def is_integral_domain(self, proof: bool = True) -> bool: ...
    def is_noetherian(self) -> bool: ...
    def flattening_morphism(self) -> Morphism: ...
    def construction(self) -> tuple[Functor, Ring]: ...
    def irrelevant_ideal(self) -> Ideal: ...
    def completion(self, names: str | tuple[str, ...] | list[str] | None = None, prec: int = 20, extras: dict[str, object] | None = None, **kwds: object) -> Ring: ...
    def remove_var(self, *var: object, order: str | TermOrder | None = None) -> 'MPolynomialRing_base': ...
    def univariate_ring(self, x: object) -> Ring: ...
    def interpolation(self, bound: int, *args: object) -> MPolynomial: ...
    def is_exact(self) -> bool: ...
    def is_field(self, proof: bool = True) -> bool: ...
    def term_order(self) -> TermOrder: ...
    def characteristic(self) -> Integer: ...
    def gen(self, n: int = 0) -> MPolynomial: ...
    def variable_names_recursive(self, depth: int | float = ...) -> tuple[str, ...]: ...
    def krull_dimension(self) -> Integer: ...
    def ngens(self) -> Integer: ...
    def random_element(self, degree: int = 2, terms: int | None = None, choose_degree: bool = False, *args: object, **kwds: object) -> MPolynomial: ...
    def some_elements(self) -> tuple[MPolynomial, ...]: ...
    def change_ring(self, base_ring: Ring | None = None, names: str | tuple[str, ...] | list[str] | None = None, order: str | TermOrder | None = None) -> 'MPolynomialRing_base': ...
    def monomial(self, *exponents: int | tuple[int, ...]) -> MPolynomial: ...
    def monomials_of_degree(self, degree: int) -> tuple[MPolynomial, ...]: ...
    def macaulay_resultant(self, *args: object, **kwds: object) -> MPolynomial: ...
    def weyl_algebra(self) -> Ring: ...
