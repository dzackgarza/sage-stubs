from sage.matrix.matrix2 import Matrix
from sage.interfaces.expect import ExpectElement
from sage.rings.ideal import Ideal_generic
from sage.rings.integer import Integer
from sage.rings.polynomial.multi_polynomial import MPolynomial
from sage.rings.polynomial.multi_polynomial_sequence import PolynomialSequence_generic
from sage.rings.ring import Ring
from sage.structure.element import CommutativeRingElement, InfinityElement, RingElement
from sage.structure.sequence import Sequence_generic

class MPolynomialIdeal(Ideal_generic):
    def groebner_basis(self) -> PolynomialSequence_generic: ...
    def basis_is_groebner(self) -> bool: ...
    def dimension(self) -> Integer: ...
    def vector_space_dimension(self) -> Integer | InfinityElement: ...
    def hilbert_polynomial(self) -> MPolynomial: ...
    def hilbert_series(self) -> CommutativeRingElement: ...
    def variety(self, ring: Ring | None = ...) -> list[dict[MPolynomial, RingElement]]: ...
    def is_zero(self) -> bool: ...
    def is_one(self) -> bool: ...
    def radical(self) -> MPolynomialIdeal: ...
    def primary_decomposition(self, algorithm: str = 'sy') -> list[MPolynomialIdeal]: ...
    def triangular_decomposition(self, algorithm: str | None = None, singular: ExpectElement | None = ...) -> Sequence_generic: ...
    def saturation(self, J: MPolynomialIdeal) -> tuple[MPolynomialIdeal, int]: ...
    def genus(self) -> Integer: ...
    def complete_primary_decomposition(self, algorithm: str = 'sy') -> Sequence_generic: ...
    def associated_primes(self, algorithm: str = 'sy') -> list[MPolynomialIdeal]: ...
    def is_prime(self, **kwds: object) -> bool: ...
    def syzygy_module(self) -> Matrix: ...
    def intersection(self, other: MPolynomialIdeal) -> MPolynomialIdeal: ...
    def is_homogeneous(self) -> bool: ...
    def interreduced_basis(self) -> list[MPolynomial]: ...
    def transformed_basis(self, algorithm: str) -> list[MPolynomial]: ...
    def change_ring(self, ring: Ring) -> MPolynomialIdeal: ...
    def defining_polynomials(self) -> tuple[MPolynomial, ...]: ...
