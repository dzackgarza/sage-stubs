from collections.abc import Iterator, Sequence
from typing import TypeAlias

from sage.categories.morphism import Morphism
from sage.categories.pushout import PolynomialFunctor
from sage.rings.infinity import PlusInfinity
from sage.rings.integer import Integer
from sage.rings.lazy_series_ring import LazyPowerSeriesRing
from sage.rings.polynomial.multi_polynomial_ring import MPolynomialRing_base
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.power_series_ring import PowerSeriesRing_generic
from sage.rings.ring import CommutativeRing, Ring
from sage.structure.parent import Parent

_RandomDegree: TypeAlias = int | Integer | tuple[int | Integer, int | Integer] | list[int | Integer]
_RandomArg: TypeAlias = int | Integer | bool | str | None
_WeilLead: TypeAlias = int | Integer | Sequence[int | Integer] | Sequence[tuple[int | Integer, int | Integer]]

class PolynomialRing_generic(Ring):
    def is_integral_domain(self, proof: bool = True) -> bool: ...
    def is_unique_factorization_domain(self, proof: bool = True) -> bool: ...
    def is_noetherian(self) -> bool: ...
    def flattening_morphism(self) -> Morphism: ...
    def construction(self) -> tuple[PolynomialFunctor, CommutativeRing]: ...
    def gen(self, n: int | Integer = 0) -> Polynomial: ...
    def gens(self) -> tuple[Polynomial, ...]: ...
    def ngens(self) -> Integer: ...
    def base_ring(self) -> CommutativeRing: ...
    def characteristic(self) -> Integer: ...
    def is_field(self, proof: bool = True) -> bool: ...
    def is_exact(self) -> bool: ...
    def is_sparse(self) -> bool: ...
    def random_element(self, degree: _RandomDegree = ..., monic: bool = ..., *args: _RandomArg, **kwds: _RandomArg) -> Polynomial: ...
    def base_extend(self, R: Parent) -> PolynomialRing_generic: ...
    def change_ring(self, R: CommutativeRing) -> PolynomialRing_generic: ...
    def change_variable_name(self, var: str) -> PolynomialRing_generic: ...
    change_var = change_variable_name
    def extend_variables(self, added_names: str | tuple[str, ...] | list[str], order: str = "degrevlex") -> MPolynomialRing_base: ...
    def variable_names_recursive(self, depth: int | Integer | PlusInfinity = ...) -> tuple[str, ...]: ...
    def completion(self, p: Polynomial | None = None, prec: int | Integer | PlusInfinity = 20, extras: dict[str, str] | None = None) -> PowerSeriesRing_generic | LazyPowerSeriesRing: ...
    def cyclotomic_polynomial(self, n: int | Integer) -> Polynomial: ...
    def gens_dict(self) -> dict[str, Polynomial]: ...
    def parameter(self) -> Polynomial: ...
    def monomial(self, exponent: int | Integer) -> Polynomial: ...
    def krull_dimension(self) -> Integer: ...
    def monomials_of_degree(self, degree: int | Integer) -> list[Polynomial]: ...
    def karatsuba_threshold(self) -> int: ...
    def set_karatsuba_threshold(self, Karatsuba_threshold: int | Integer) -> None: ...
    def polynomials(self, of_degree: int | Integer | None = None, max_degree: int | Integer | None = None) -> Iterator[Polynomial]: ...
    def monics(self, of_degree: int | Integer | None = None, max_degree: int | Integer | None = None) -> Iterator[Polynomial]: ...
    def weil_polynomials(self, d: int | Integer, q: int | Integer, sign: int | Integer = 1, lead: _WeilLead = 1) -> list[Polynomial]: ...
    def some_elements(self) -> list[Polynomial]: ...

PolynomialRing_general = PolynomialRing_generic
