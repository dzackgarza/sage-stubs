from typing import Any
from collections.abc import Callable
from collections.abc import Iterator
from sage.rings.ring import Ring, CommutativeRing
from sage.categories.category import Category
from sage.rings.morphism import RingHomomorphism
from sage.categories.pushout import ConstructionFunctor
from sage.rings.infinity import PlusInfinity

class PolynomialRing_general(Ring):
    class Element: ...
    def __init__(self, base_ring: Ring, name: str | None = None, sparse: bool = False, implementation: str | None = None, element_class: type | None = None, category: Category | None = None) -> None: ...
    def __reduce__(self) -> tuple[Callable[..., PolynomialRing_general], tuple[Ring, tuple[str, ...], type[None], bool]]: ...
    def __hash__(self) -> int: ...
    def is_integral_domain(self, proof: bool = True) -> bool: ...
    def is_unique_factorization_domain(self, proof: bool = True) -> bool: ...
    def is_noetherian(self) -> bool: ...
    def some_elements(self) -> list[PolynomialRing_general.Element]: ...
    def monomials_of_degree(self, degree: int) -> list[PolynomialRing_general.Element]: ...
    def flattening_morphism(self) -> RingHomomorphism: ...
    def construction(self) -> tuple[ConstructionFunctor, Ring]: ...
    def completion(self, p: PolynomialRing_general.Element | None = None, prec: int | PlusInfinity = 20, extras: dict[str, str] | None = None) -> Ring: ...
    def base_extend(self, R: Ring) -> PolynomialRing_general: ...
    def change_ring(self, R: Ring) -> PolynomialRing_general: ...
    def change_variable_name(self, var: str) -> PolynomialRing_general: ...
    def extend_variables(self, added_names: str | list[str] | tuple[str, ...], order: str = 'degrevlex') -> Ring: ...
    def variable_names_recursive(self, depth: int | PlusInfinity = ...) -> tuple[str, ...]: ...
    def characteristic(self) -> int: ...
    def cyclotomic_polynomial(self, n: int) -> PolynomialRing_general.Element: ...
    def gen(self, n: int = 0) -> PolynomialRing_general.Element: ...
    def gens_dict(self) -> dict[str, PolynomialRing_general.Element]: ...
    def parameter(self) -> PolynomialRing_general.Element: ...
    def is_exact(self) -> bool: ...
    def is_field(self, proof: bool = True) -> bool: ...
    def is_sparse(self) -> bool: ...
    def monomial(self, exponent: int) -> PolynomialRing_general.Element: ...
    def krull_dimension(self) -> int | PlusInfinity: ...
    def ngens(self) -> int: ...
    def random_element(self, degree: int | tuple[int, int] = (-1, 2), monic: bool = False, *args: Any, **kwds: Any) -> PolynomialRing_general.Element: ...
    def karatsuba_threshold(self) -> int: ...
    def set_karatsuba_threshold(self, Karatsuba_threshold: int) -> None: ...
    def polynomials(self, of_degree: int | None = None, max_degree: int | None = None) -> Iterator[PolynomialRing_general.Element]: ...
    def monics(self, of_degree: int | None = None, max_degree: int | None = None) -> Iterator[PolynomialRing_general.Element]: ...

PolynomialRing_generic = PolynomialRing_general
