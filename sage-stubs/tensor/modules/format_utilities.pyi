from sage.misc.latex import LatexExpr
from sage.structure.sage_object import SageObject

def is_atomic(expr: str, sep: list[str] = ...) -> bool: ...
def is_atomic_wedge_txt(expression: str) -> bool: ...
def is_atomic_wedge_latex(expression: str) -> bool: ...
def format_mul_txt(name1: str | None, operator: str, name2: str | None) -> str | None: ...
def format_mul_latex(name1: str | None, operator: str, name2: str | None) -> str | None: ...
def format_unop_txt(operator: str, name: str | None) -> str | None: ...
def format_unop_latex(operator: str, name: str | None) -> str | None: ...

class FormattedExpansion(SageObject):
    _txt: str | None
    _latex: str | LatexExpr | None
    def __init__(self, txt: str | None = None, latex: str | LatexExpr | None = None) -> None: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
