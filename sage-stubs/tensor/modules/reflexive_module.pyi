from collections.abc import Iterable
from typing import Self, TypeAlias

from sage.structure.parent import Parent

_IndexBlock: TypeAlias = Iterable[int]
_Symmetry: TypeAlias = _IndexBlock | Iterable[_IndexBlock] | None
_TensorKeyword: TypeAlias = str | _Symmetry

class ReflexiveModule_abstract(Parent):
    def tensor_type(self) -> tuple[int, int]: ...
    def base_module(self) -> ReflexiveModule_base: ...
    def dual(self) -> ReflexiveModule_abstract: ...
    def tensor(self, *args: ReflexiveModule_abstract, **kwds: _TensorKeyword) -> ReflexiveModule_abstract: ...
    def tensor_power(self, n: int) -> ReflexiveModule_abstract: ...
    def tensor_product(self, *others: ReflexiveModule_abstract) -> ReflexiveModule_abstract: ...

class ReflexiveModule_base(ReflexiveModule_abstract):
    def base_module(self) -> Self: ...
    def tensor_type(self) -> tuple[int, int]: ...
    def dual(self) -> ReflexiveModule_abstract: ...
    def tensor_module(
        self,
        k: int,
        l: int,
        *,
        sym: _Symmetry = ...,
        antisym: _Symmetry = ...,
    ) -> ReflexiveModule_abstract: ...

class ReflexiveModule_dual(ReflexiveModule_abstract):
    def tensor_type(self) -> tuple[int, int]: ...
    def construction(self) -> None: ...

class ReflexiveModule_tensor(ReflexiveModule_abstract):
    def tensor_factors(self) -> list[ReflexiveModule_abstract]: ...
