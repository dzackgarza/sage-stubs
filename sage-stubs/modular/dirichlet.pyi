from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from sage.rings.number_field.number_field import NumberField_generic
    from sage.rings.polynomial.polynomial_element import Polynomial
    from sage.lfunctions.pari import LFunction
    from sage.structure.parent import Parent
    from sage.rings.ring import Ring

from sage.rings.integer import Integer
from sage.structure.element import MultiplicativeGroupElement, RingElement


class DirichletCharacter(MultiplicativeGroupElement):
    def __init__(self, parent: DirichletGroup_class, x: tuple | object, check: bool = ...) -> None: ...
    def __call__(self, m: int) -> RingElement: ...
    def change_ring(self, R: Ring) -> DirichletCharacter: ...
    def _richcmp_(self, other: DirichletCharacter, op: int) -> bool: ...
    def __hash__(self) -> int: ...
    def __invert__(self) -> DirichletCharacter: ...
    def _mul_(self, other: DirichletCharacter) -> DirichletCharacter: ...
    def __copy__(self) -> DirichletCharacter: ...
    def __pow__(self, n: int) -> DirichletCharacter: ...
    def _repr_short_(self) -> str: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def base_ring(self) -> Ring: ...
    def bar(self) -> DirichletCharacter: ...
    def bernoulli(self, k: int, algorithm: str = ..., cache: bool = ..., **opts: object) -> RingElement: ...
    def lfunction(self, prec: int = ..., algorithm: str = ...) -> LFunction: ...
    def conductor(self) -> Integer: ...
    def fixed_field_polynomial(self, algorithm: str = ...) -> Polynomial: ...
    def fixed_field(self) -> NumberField_generic: ...
    def decomposition(self) -> list: ...
    def extend(self, M: int) -> DirichletCharacter: ...
    def _pari_init_(self) -> tuple: ...
    def conrey_number(self) -> int: ...
    def lmfdb_page(self) -> None: ...
    def galois_orbit(self, sort: bool = ...) -> list: ...
    def gauss_sum(self, a: int = ...) -> RingElement: ...
    def is_even(self) -> bool: ...
    def is_odd(self) -> bool: ...
    def is_primitive(self) -> bool: ...
    def is_trivial(self) -> bool: ...
    def kernel(self) -> list: ...
    def maximize_base_ring(self) -> DirichletCharacter: ...
    def modulus(self) -> Integer: ...
    def level(self) -> Integer: ...
    def multiplicative_order(self) -> int: ...
    def primitive_character(self) -> DirichletCharacter: ...
    def restrict(self, M: int) -> DirichletCharacter: ...
    def values(self) -> list: ...
    def values_on_gens(self) -> tuple: ...
    def parent(self) -> DirichletGroup_class: ...
    def order(self) -> int: ...


class DirichletGroup_class:
    def __init__(self, N: int, base_ring: Ring | None = ..., zeta: object | None = ..., zeta_order: int | None = ..., names: str | None = ...) -> None: ...
    def __call__(self, x: int | list | tuple | DirichletCharacter) -> DirichletCharacter: ...
    def list(self) -> list: ...
    def order(self) -> Integer: ...
    def unit_gens(self) -> tuple: ...
    def zeta_order(self) -> int: ...
    def base_ring(self) -> Ring: ...
    def modulus(self) -> Integer: ...
    def ngens(self) -> int: ...
    def gen(self, i: int) -> DirichletCharacter: ...
    def gens(self) -> tuple: ...
    def primitive_characters(self) -> list: ...
    def decomposition(self) -> list: ...
    def integers_mod(self) -> RingElement: ...
    def zeta(self) -> RingElement: ...


def trivial_character(N: int, base_ring: Ring | None = ...) -> DirichletCharacter: ...

def kronecker_character(d: Integer) -> DirichletCharacter: ...

def kronecker_character_upside_down(d: Integer) -> DirichletCharacter: ...

def DirichletGroup(N: int, base_ring: Ring | None = ..., zeta: object | None = ..., zeta_order: int | None = ..., names: str | None = ...) -> DirichletGroup_class: ...
