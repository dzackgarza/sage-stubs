from collections.abc import Iterable
from typing import Literal, overload
from sage.groups.group import Group
from sage.modular.arithgroup.arithgroup_element import ArithmeticSubgroupElement
from sage.modular.cusps import Cusp
from sage.matrix.matrix_space import MatrixSpace
from sage.modular.arithgroup.farey_symbol import Farey
from sage.modular.arithgroup.arithgroup_perm import ArithmeticSubgroup_Permutation_class
from sage.rings.infinity import PlusInfinity

class ArithmeticSubgroup(Group):
    def __init__(self) -> None: ...
    def matrix_space(self) -> MatrixSpace: ...
    def is_parent_of(self, x: object) -> bool: ...
    def coset_reps(self, G: ArithmeticSubgroup | None = None) -> Iterable[ArithmeticSubgroupElement]: ...
    def todd_coxeter(self, G: ArithmeticSubgroup | None = None, on_right: bool = True) -> tuple[list[ArithmeticSubgroupElement], list[ArithmeticSubgroupElement], list[int], list[int]]: ...
    def nu2(self) -> int: ...
    def nu3(self) -> int: ...
    def is_abelian(self) -> bool: ...
    def is_finite(self) -> bool: ...
    def is_subgroup(self, right: ArithmeticSubgroup) -> bool: ...
    def is_normal(self) -> bool: ...
    def is_odd(self) -> bool: ...
    def is_even(self) -> bool: ...
    def to_even_subgroup(self) -> ArithmeticSubgroup: ...
    def order(self) -> PlusInfinity: ...
    def reduce_cusp(self, c: object) -> Cusp: ...
    def cusps(self, algorithm: str = 'default') -> list[Cusp]: ...
    @overload
    def are_equivalent(self, x: object, y: object, trans: Literal[False] = False) -> bool: ...
    @overload
    def are_equivalent(self, x: object, y: object, trans: Literal[True]) -> bool | ArithmeticSubgroupElement: ...
    def cusp_data(self, c: object) -> tuple[ArithmeticSubgroupElement, int, int]: ...
    def is_regular_cusp(self, c: object) -> bool: ...
    def cusp_width(self, c: object) -> int: ...
    def index(self) -> int: ...
    def generalised_level(self) -> int: ...
    def projective_index(self) -> int: ...
    def is_congruence(self) -> bool: ...
    def genus(self) -> int: ...
    def farey_symbol(self) -> Farey: ...
    def generators(self, algorithm: str = 'farey') -> list[ArithmeticSubgroupElement]: ...
    def gens(self, *args: object, **kwds: object) -> tuple[ArithmeticSubgroupElement, ...]: ...
    def gen(self, i: int) -> ArithmeticSubgroupElement: ...
    def ngens(self) -> int: ...
    def ncusps(self) -> int: ...
    def nregcusps(self) -> int: ...
    def nirregcusps(self) -> int: ...
    def dimension_modular_forms(self, k: int = 2) -> int: ...
    def dimension_cusp_forms(self, k: int = 2) -> int: ...
    def dimension_eis(self, k: int = 2) -> int: ...
    def as_permutation_group(self) -> ArithmeticSubgroup_Permutation_class: ...
    def sturm_bound(self, weight: int = 2) -> int: ...
