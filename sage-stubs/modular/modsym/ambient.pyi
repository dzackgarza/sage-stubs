from typing import TYPE_CHECKING

from sage.matrix.matrix_dense import Matrix_dense
from sage.modular.hecke.module import HeckeModule
from sage.modular.modsym.space import ModularSymbolsSpace
from sage.rings.commutative_ring import CommutativeRing
from sage.rings.integer import Integer
from sage.structure.factorization import Factorization

if TYPE_CHECKING:
    from sage.modular.arithgroup.congruence_subgroup import CongruenceSubgroup
    from sage.modular.dirichlet import DirichletCharacter
    from sage.modules.free_module import FreeModule
    from sage.modular.modsym.element import ModularSymbolsElement
    from sage.modular.hecke.morphism import HeckeModuleMorphism_matrix
    from sage.modular.modsym.manin_symbol_list import ManinSymbolList_gamma0
    from sage.modular.modsym.p1list import P1List
    from sage.modular.modsym.boundary import BoundarySpace_wtk_g0
    from sage.modular.hecke.morphism import HeckeModuleMorphism

class ModularSymbolsAmbient(ModularSymbolsSpace, HeckeModule):
    """
    An ambient space of modular symbols for a congruence subgroup.
    """

    def __init__(
        self,
        group: CongruenceSubgroup,
        weight: Integer,
        sign: Integer,
        base_ring: CommutativeRing,
        character: DirichletCharacter | None = None,
        custom_init: callable | None = None,
        category: object | None = None,
    ) -> None: ...
    def new_submodule(self, p: Integer | None = None) -> ModularSymbolsAmbient: ...
    def manin_symbols(self) -> ManinSymbolList_gamma0: ...
    def manin_generators(self) -> list: ...
    def manin_basis(self) -> list[int]: ...
    def p1list(self) -> P1List: ...
    def compute_presentation(self) -> None: ...
    def manin_gens_to_basis(self) -> Matrix_dense: ...
    def _element_constructor_(self, x, computed_with_hecke: bool = False) -> ModularSymbolsElement: ...
    def change_ring(self, R: CommutativeRing) -> ModularSymbolsAmbient: ...
    def manin_symbol(self, x: list | tuple, check: bool = True) -> ModularSymbolsElement: ...
    def modular_symbol(self, x: list, check: bool = True) -> ModularSymbolsElement: ...
    def modular_symbol_sum(self, x: list, check: bool = True) -> ModularSymbolsElement: ...
    def _compute_hecke_matrix_prime(self, p: int, rows: list[int] | None = None) -> Matrix_dense: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def change_ring(self, R: CommutativeRing) -> ModularSymbolsAmbient: ...
    def boundary_map(self) -> HeckeModuleMorphism_matrix: ...
    def cusps(self) -> list: ...
    def boundary_space(self) -> BoundarySpace_wtk_g0: ...
    def cuspidal_submodule(self) -> ModularSymbolsAmbient: ...
    def rank(self) -> int: ...
    def eisenstein_submodule(self) -> ModularSymbolsAmbient: ...
    def element(self, x) -> ModularSymbolsElement: ...
    def dual_star_involution_matrix(self) -> Matrix_dense: ...
    def factorization(self) -> Factorization: ...
    factor = factorization
    def is_cuspidal(self) -> bool: ...
    def is_eisenstein(self) -> bool: ...
    def manin_symbols_basis(self) -> list: ...
    def modular_symbols_of_level(self, G) -> ModularSymbolsAmbient: ...
    def modular_symbols_of_sign(self, sign: Integer) -> ModularSymbolsAmbient: ...
    def modular_symbols_of_weight(self, k: int | Integer) -> ModularSymbolsAmbient: ...
    def star_involution(self) -> HeckeModuleMorphism: ...
    def submodule(self, M: FreeModule, dual_free_module: FreeModule | None = None, check: bool = True) -> ModularSymbolsAmbient: ...
    def twisted_winding_element(self, i: int | Integer, eps: DirichletCharacter) -> ModularSymbolsElement: ...
    def integral_structure(self, algorithm: str = "default") -> FreeModule: ...
    def compact_newform_eigenvalues(self, v: list[int], names: str = "alpha") -> list: ...

class ModularSymbolsAmbient_wtk_g0(ModularSymbolsAmbient):
    """
    Modular symbols for Gamma_0(N) of weight k >= 2.
    """

    def __init__(
        self,
        N: int,
        k: int,
        sign: int,
        F: CommutativeRing,
        custom_init: callable | None = None,
        category: object | None = None,
    ) -> None: ...
    def _dimension_formula(self) -> int | None: ...
    def _repr_(self) -> str: ...
    def _cuspidal_submodule_dimension_formula(self) -> int: ...
    def _degeneracy_raising_matrix_1(self, M: ModularSymbolsAmbient) -> Matrix_dense: ...
    def _cuspidal_new_submodule_dimension_formula(self) -> int: ...
    def boundary_space(self) -> BoundarySpace_wtk_g0: ...
    def manin_symbols(self) -> ManinSymbolList_gamma0: ...
    def _hecke_images(self, i: int, v: list[int]) -> Matrix_dense: ...

