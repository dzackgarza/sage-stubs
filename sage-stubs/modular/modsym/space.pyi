from typing import TYPE_CHECKING, Optional, Sequence

from sage.rings.integer import Integer
from sage.rings.rational_field import QQ
from sage.modular.hecke.module import HeckeModule_free_module
from sage.structure.factorization import Factorization

if TYPE_CHECKING:
    from sage.modular.modsym.subspace import ModularSymbolsSubspace
    from sage.modular.modsym.ambient import ModularSymbolsAmbient
    from sage.modular.modsym.boundary import BoundarySpace
    from sage.modular.dirichlet import DirichletCharacter
    from sage.modules.free_module import FreeModule_generic
    from sage.rings.ring import Ring
    from sage.modular.arithgroup.congroup_generic import CongruenceSubgroup

class ModularSymbolsSpace(HeckeModule_free_module):
    def __init__(
        self,
        group: CongruenceSubgroup,
        weight: Integer,
        character: Optional[DirichletCharacter],
        sign: Integer,
        base_ring: Ring,
        category=None,
    ) -> None: ...
    def character(self) -> Optional[DirichletCharacter]: ...
    def group(self) -> CongruenceSubgroup: ...
    def is_ambient(self) -> bool: ...
    def is_cuspidal(self) -> bool: ...
    def is_simple(self) -> bool: ...
    def sign(self) -> Integer: ...
    def weight(self) -> Integer: ...
    def dimension(self) -> Integer: ...
    def rank(self) -> Integer: ...
    def cuspidal_submodule(self) -> ModularSymbolsSubspace: ...
    def cuspidal_subspace(self) -> ModularSymbolsSubspace: ...
    def eisenstein_submodule(self) -> ModularSymbolsSubspace: ...
    def eisenstein_subspace(self) -> ModularSymbolsSubspace: ...
    def new_submodule(self, p: Optional[Integer] = None) -> ModularSymbolsSubspace: ...
    def new_subspace(self, p: Optional[Integer] = None) -> ModularSymbolsSubspace: ...
    def old_submodule(self, p: Optional[Integer] = None) -> ModularSymbolsSubspace: ...
    def old_subspace(self, p: Optional[Integer] = None) -> ModularSymbolsSubspace: ...
    def complement(self) -> ModularSymbolsSubspace: ...
    def boundary_space(self) -> BoundarySpace: ...
    def dual_free_module(self) -> FreeModule_generic: ...
    def intersection(self, N: Integer) -> ModularSymbolsSpace: ...
    def plus_submodule(self, compute_dual: bool = True) -> ModularSymbolsSubspace: ...
    def minus_submodule(self, compute_dual: bool = True) -> ModularSymbolsSubspace: ...
    def ambient_hecke_module(self) -> ModularSymbolsAmbient: ...
    def ambient_module(self) -> ModularSymbolsAmbient: ...
    def ambient(self) -> ModularSymbolsAmbient: ...
    def modular_symbols_of_sign(self) -> ModularSymbolsAmbient: ...
    def default_prec(self) -> Integer: ...
    def set_default_prec(self, prec: Integer) -> None: ...
    def set_precision(self, prec: Integer) -> None: ...
    def q_expansion_basis(
        self, prec: Optional[Integer] = None, algorithm: str = "default"
    ) -> Sequence: ...
    def q_expansion_module(
        self, prec: Optional[Integer] = None, R: Optional[Ring] = None
    ) -> FreeModule_generic: ...
    def q_expansion_cuspforms(self, prec: Optional[Integer] = None): ...
    def q_eigenform(self, prec: Integer, names: Optional[str] = None): ...
    def q_eigenform_character(self, names: Optional[str] = None): ...
    def integral_structure(self) -> FreeModule_generic: ...
    def integral_basis(self) -> tuple: ...
    def integral_hecke_matrix(self, n: Integer): ...
    def multiplicity(self, S: ModularSymbolsSpace, check_simple: bool = True) -> Integer: ...
    def factorization(self) -> Factorization: ...
    def simple_factors(self) -> list[ModularSymbolsSubspace]: ...
    def decomposition(self, depth: Optional[Integer] = None) -> list[ModularSymbolsSubspace]: ...
    def star_involution(self): ...
    def star_eigenvalues(self) -> list[Integer]: ...
    def star_decomposition(self) -> list[ModularSymbolsSubspace]: ...
    def is_new(self) -> bool: ...
    def is_old(self) -> bool: ...
    def new_level(self) -> Integer: ...
    def sturm_bound(self) -> Integer: ...
    def hecke_bound(self) -> Integer: ...
    def ngens(self) -> Integer: ...
    def intersection_number(self, M: ModularSymbolsSpace) -> Integer: ...
    def congruence_number(self, other: ModularSymbolsSpace, prec: Optional[Integer] = None) -> Integer: ...
    def compact_system_of_eigenvalues(
        self, v: list[Integer], names: str = "alpha", nz: Optional[Integer] = None
    ) -> tuple: ...
