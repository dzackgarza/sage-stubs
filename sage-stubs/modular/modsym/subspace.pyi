from typing import TYPE_CHECKING

from sage.modular.modsym.space import ModularSymbolsSpace
from sage.structure.factorization import Factorization

if TYPE_CHECKING:
    from sage.modular.modsym.ambient import ModularSymbolsAmbient

class ModularSymbolsSubspace(ModularSymbolsSpace):
    def __init__(
        self,
        ambient_hecke_module: ModularSymbolsAmbient,
        submodule,
        dual_free_module=None,
        check: bool = False,
    ) -> None: ...
    def _repr_(self) -> str: ...
    def ambient_hecke_module(self) -> ModularSymbolsAmbient: ...
    def boundary_map(self): ...
    def cuspidal_submodule(self) -> ModularSymbolsSubspace: ...
    def dual_star_involution_matrix(self): ...
    def eisenstein_subspace(self) -> ModularSymbolsSubspace: ...
    def factorization(self) -> Factorization: ...
    def is_cuspidal(self) -> bool: ...
    def is_eisenstein(self) -> bool: ...
    def _set_is_cuspidal(self, t: bool) -> None: ...
    def star_involution(self): ...
