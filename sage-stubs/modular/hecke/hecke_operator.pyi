from typing import TYPE_CHECKING, Optional
from sage.rings.integer import Integer
from sage.structure.element import AlgebraElement, Element
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.structure.factorization import Factorization

if TYPE_CHECKING:
    from sage.modular.hecke.algebra import HeckeAlgebra_base
    from sage.modular.hecke.module import HeckeModule_generic, HeckeModule_free_module
    from sage.modular.hecke.element import HeckeModuleElement
    from sage.modular.hecke.submodule import HeckeSubmodule
    from sage.modular.hecke.morphism import HeckeModuleMorphism_matrix as HeckeModuleMorphism_matrix_type
    from sage.matrix.matrix_dense import Matrix

class HeckeAlgebraElement(AlgebraElement):
    def __init__(self, parent: HeckeAlgebra_base) -> None: ...
    def domain(self) -> HeckeModule_generic: ...
    def codomain(self) -> HeckeModule_generic: ...
    def matrix(self, *args, **kwds) -> Matrix: ...
    def hecke_module_morphism(self) -> HeckeModuleMorphism_matrix_type: ...
    def __call__(self, x: HeckeModuleElement) -> HeckeModuleElement: ...
    def __rmul__(self, left: object) -> HeckeAlgebraElement: ...
    def _add_(self, other: HeckeAlgebraElement) -> HeckeAlgebraElement: ...
    def _sub_(self, other: HeckeAlgebraElement) -> HeckeAlgebraElement: ...
    def apply_sparse(self, x: HeckeModuleElement) -> HeckeModuleElement: ...
    def charpoly(self, var: str = ...) -> Polynomial: ...
    def decomposition(self) -> list[HeckeSubmodule]: ...
    def det(self) -> Element: ...
    def fcp(self, var: str = ...) -> Factorization: ...
    def image(self) -> HeckeSubmodule: ...
    def kernel(self) -> HeckeSubmodule: ...
    def trace(self) -> Element: ...
    def __getitem__(self, ij: tuple) -> Element: ...

class HeckeAlgebraElement_matrix(HeckeAlgebraElement):
    def __init__(self, parent: HeckeAlgebra_base, A: Matrix) -> None: ...
    def matrix(self) -> Matrix: ...
    def _mul_(self, other: HeckeAlgebraElement) -> HeckeAlgebraElement: ...

class DiamondBracketOperator(HeckeAlgebraElement_matrix):
    def __init__(self, parent: HeckeAlgebra_base, d: Integer) -> None: ...

class HeckeOperator(HeckeAlgebraElement):
    def __init__(self, parent: HeckeAlgebra_base, n: Integer) -> None: ...
    def index(self) -> Integer: ...
    def matrix(self, *args, **kwds) -> Matrix: ...
    def matrix_form(self) -> HeckeAlgebraElement_matrix: ...
    def _mul_(self, other: HeckeAlgebraElement) -> HeckeAlgebraElement: ...
