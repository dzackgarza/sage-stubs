from typing import overload

from sage.categories.category import Category
from sage.matrix.matrix import Matrix
from sage.modular.hecke.element import HeckeModuleElement
from sage.modular.hecke.morphism import HeckeModuleMorphism_matrix
from sage.modular.hecke.submodule import HeckeSubmodule
from sage.modules.free_module import FreeModule_generic
from sage.modules.free_module_element import FreeModuleElement
from sage.rings.integer import Integer
from sage.rings.ring import CommutativeRing
from sage.structure.element import Element
from sage.structure.factorization import Factorization
from .module import HeckeModule_free_module

class AmbientHeckeModule(HeckeModule_free_module):
    def __init__(
        self,
        base_ring: CommutativeRing,
        rank: int,
        level: int,
        weight: int,
        category: Category | None = None,
    ) -> None: ...
    def __add__(self, other: HeckeModule_free_module) -> AmbientHeckeModule: ...
    def rank(self) -> Integer: ...
    def complement(self) -> HeckeModule_free_module: ...
    def decomposition_matrix(self) -> Matrix: ...
    def decomposition_matrix_inverse(self) -> Matrix: ...
    def degeneracy_map(self, codomain: HeckeModule_free_module | int, t: int = 1) -> HeckeModuleMorphism_matrix: ...
    def dual_free_module(self) -> FreeModule_generic: ...
    def fcp(self, n: int, var: str = 'x') -> Factorization: ...
    def free_module(self) -> FreeModule_generic: ...
    def hecke_bound(self) -> int: ...
    def hecke_module_of_level(self, level: int) -> AmbientHeckeModule: ...
    def hecke_images(self, i: int, v: list[FreeModuleElement]) -> Matrix: ...
    def intersection(self, other: HeckeModule_free_module) -> HeckeModule_free_module: ...
    def is_ambient(self) -> bool: ...
    def is_full_hecke_module(self, compute: bool = True) -> bool: ...
    def is_new(self, p: int | None = None) -> bool: ...
    def is_old(self, p: int | None = None) -> bool: ...
    @overload
    def is_submodule(self, V: HeckeModule_free_module) -> bool: ...
    @overload
    def is_submodule(self, other: object) -> bool: ...
    def linear_combination_of_basis(self, v: list[Element] | FreeModuleElement) -> HeckeModuleElement: ...
    def new_submodule(self, p: int | None = None) -> HeckeModule_free_module: ...
    def nonembedded_free_module(self) -> FreeModule_generic: ...
    def old_submodule(self, p: int | None = None) -> HeckeModule_free_module: ...
    @overload
    def submodule(self, M: FreeModule_generic | list[HeckeModuleElement], Mdual: FreeModule_generic | None = None, check: bool = True) -> HeckeModule_free_module: ...
    @overload
    def submodule(self, X: object) -> HeckeSubmodule: ...
    def _submodule_class(self) -> type: ...
    def submodule_from_nonembedded_module(
        self, V: FreeModule_generic, Vdual: FreeModule_generic | None = None, check: bool = True
    ) -> HeckeModule_free_module: ...
    def submodule_generated_by_images(self, M: HeckeModule_free_module) -> HeckeModule_free_module: ...
    def _degeneracy_raising_matrix(self, codomain: HeckeModule_free_module | int) -> Matrix: ...
    def _degeneracy_lowering_matrix(self, codomain: HeckeModule_free_module | int, t: int) -> Matrix: ...
    def _hecke_image_of_ith_basis_element(self, n: int, i: int) -> HeckeModuleElement: ...
    def _set_dual_free_module(self, V: FreeModule_generic | None) -> None: ...
    def ambient_hecke_module(self) -> AmbientHeckeModule: ...
