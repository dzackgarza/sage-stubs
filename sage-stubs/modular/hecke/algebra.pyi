from collections.abc import Iterator

from sage.matrix.matrix import Matrix
from sage.matrix.matrix_space import MatrixSpace
from sage.modular.hecke.hecke_operator import (
    DiamondBracketOperator,
    HeckeAlgebraElement_matrix,
    HeckeOperator,
)
from sage.modular.hecke.module import HeckeModule_free_module, HeckeModule_generic
from sage.rings.ring import CommutativeRing
from sage.rings.integer import Integer
from sage.rings.infinity import PlusInfinity
from sage.structure.parent import Parent
from sage.structure.unique_representation import CachedRepresentation


class HeckeAlgebra_base(CachedRepresentation, Parent):
    def __init__(self, M: HeckeModule_generic) -> None: ...
    def level(self) -> Integer: ...
    def module(self) -> HeckeModule_generic: ...
    def is_noetherian(self) -> bool: ...
    def basis(self) -> tuple[HeckeOperator | HeckeAlgebraElement_matrix, ...]: ...
    def discriminant(self) -> Integer: ...
    def rank(self) -> Integer: ...
    def matrix_space(self) -> MatrixSpace: ...
    def gen(self, n: Integer) -> HeckeOperator: ...
    def gens(self) -> Iterator[HeckeOperator]: ...
    def ngens(self) -> PlusInfinity: ...
    def one(self) -> HeckeAlgebraElement_matrix: ...
    def hecke_operator(self, n: Integer) -> HeckeOperator: ...
    def hecke_matrix(self, n: Integer, *args: int, **kwds: int) -> Matrix: ...
    def diamond_bracket_matrix(self, d: Integer) -> Matrix: ...
    def diamond_bracket_operator(self, d: Integer) -> DiamondBracketOperator: ...
    def is_anemic(self) -> bool: ...

class HeckeAlgebra_full(HeckeAlgebra_base):
    def is_anemic(self) -> bool: ...
    def anemic_subalgebra(self) -> HeckeAlgebra_anemic: ...

class HeckeAlgebra_anemic(HeckeAlgebra_base):
    def is_anemic(self) -> bool: ...
    def hecke_operator(self, n: Integer) -> HeckeOperator: ...
    def gens(self) -> Iterator[HeckeOperator]: ...

HeckeAlgebra = HeckeAlgebra_full
AnemicHeckeAlgebra = HeckeAlgebra_anemic
