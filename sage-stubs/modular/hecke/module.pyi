from typing import TYPE_CHECKING, Optional, Sequence
from sage.rings.commutative_ring import CommutativeRing
from sage.rings.integer import Integer
from sage.matrix.matrix_dense import Matrix
from sage.modules.module import Module
from sage.structure.sequence import Sequence as SageSequence
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.modules.free_module_element import FreeModuleElement
from sage.structure.element import Element

if TYPE_CHECKING:
    from sage.modular.hecke.algebra import HeckeAlgebra_full, HeckeAlgebra_anemic
    from sage.modular.hecke.hecke_operator import HeckeOperator, DiamondBracketOperator
    from sage.modular.hecke.element import HeckeModuleElement
    from sage.modular.hecke.submodule import HeckeSubmodule
    from sage.modular.hecke.morphism import HeckeModuleMorphism_matrix

class HeckeModule_generic(Module):
    def __init__(self, base_ring: CommutativeRing, level: Integer, category=None) -> None: ...
    def __hash__(self) -> int: ...
    def level(self) -> Integer: ...
    def rank(self) -> Integer: ...
    def dimension(self) -> Integer: ...
    def is_zero(self) -> bool: ...
    def is_full_hecke_module(self) -> bool: ...
    def is_hecke_invariant(self, n: Integer) -> bool: ...
    def is_simple(self) -> bool: ...
    def is_splittable(self) -> bool: ...
    def is_splittable_anemic(self) -> bool: ...
    def hecke_algebra(self) -> HeckeAlgebra_full: ...
    def anemic_hecke_algebra(self) -> HeckeAlgebra_anemic: ...
    def hecke_operator(self, n: Integer) -> HeckeOperator: ...
    def T(self, n: Integer) -> HeckeOperator: ...
    def hecke_matrix(self, n: Integer) -> Matrix: ...
    def hecke_polynomial(self, n: Integer, var: str = ...) -> Polynomial: ...
    def character(self) -> Optional[object]: ...
    def submodule(self, X: object) -> HeckeSubmodule: ...
    def basis(self) -> tuple[HeckeModuleElement, ...]: ...
    def gens(self) -> tuple[HeckeModuleElement, ...]: ...
    def gen(self, n: Integer) -> HeckeModuleElement: ...
    def ngens(self) -> Integer: ...

class HeckeModule_free_module(HeckeModule_generic):
    def __init__(
        self, base_ring: CommutativeRing, level: Integer, weight: Integer, category=None
    ) -> None: ...
    def __len__(self) -> Integer: ...
    def __getitem__(self, n: Integer) -> HeckeSubmodule: ...
    def __hash__(self) -> Integer: ...
    def weight(self) -> Integer: ...
    def ambient_module(self) -> HeckeModule_free_module: ...
    def ambient_hecke_module(self) -> HeckeModule_free_module: ...
    def ambient(self) -> HeckeModule_free_module: ...
    def degree(self) -> Integer: ...
    def decomposition(
        self,
        bound: Optional[Integer] = None,
        anemic: bool = True,
        height_guess: Integer = 1,
        sort_by_basis: bool = False,
        proof: Optional[bool] = None,
    ) -> SageSequence: ...
    def basis_matrix(self) -> Matrix: ...
    def coordinate_vector(self, x: HeckeModuleElement) -> FreeModuleElement: ...
    def atkin_lehner_operator(self, d: Optional[Integer] = None) -> HeckeModuleMorphism_matrix: ...
    def dual_eigenvector(
        self, names: str = ..., lift: bool = True, nz: Optional[Integer] = None
    ) -> FreeModuleElement: ...
    def dual_hecke_matrix(self, n: Integer) -> Matrix: ...
    def eigenvalue(self, n: Integer, name: str = ...) -> Element: ...
    def factor_number(self) -> Integer: ...
    def projection(self) -> HeckeModuleMorphism_matrix: ...
    def system_of_eigenvalues(self, n: Integer, name: str = ...) -> list: ...
    def zero_submodule(self) -> HeckeSubmodule: ...
    def is_submodule(self, other: object) -> bool: ...
    def diamond_bracket_matrix(self, d: Integer) -> Matrix: ...
    def diamond_bracket_operator(self, d: Integer) -> DiamondBracketOperator: ...
