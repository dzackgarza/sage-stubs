from typing import Self
from sage.modular.hecke.module import HeckeModule_free_module, HeckeModule_generic
from sage.modules.free_module_element import FreeModuleElement
from sage.rings.ring import Ring
from sage.structure.element import ModuleElement

class HeckeModuleElement(ModuleElement):
    def __init__(self, parent: HeckeModule_generic, x: FreeModuleElement | None = None) -> None: ...
    def element(self) -> FreeModuleElement: ...
    def _vector_(self, R: Ring | None = None) -> FreeModuleElement: ...
    def ambient_module(self) -> HeckeModule_generic: ...
    def _lmul_(self, x: object) -> HeckeModuleElement: ...
    def _rmul_(self, x: object) -> HeckeModuleElement: ...
    def _neg_(self) -> HeckeModuleElement: ...
    def _pos_(self) -> Self: ...
    def _sub_(self, right: HeckeModuleElement) -> HeckeModuleElement: ...
    def is_cuspidal(self) -> bool: ...
    def is_eisenstein(self) -> bool: ...
    def is_new(self, p: int | None = None) -> bool: ...
    def is_old(self, p: int | None = None) -> bool: ...
