from typing import TYPE_CHECKING, Optional, Self
from sage.structure.element import ModuleElement

if TYPE_CHECKING:
    from sage.modular.hecke.module import HeckeModule_generic, HeckeModule_free_module
    from sage.modules.free_module import FreeModuleElement

class HeckeModuleElement(ModuleElement):
    def __init__(self, parent: HeckeModule_generic, x: Optional[FreeModuleElement] = None) -> None: ...
    def element(self) -> FreeModuleElement: ...
    def _vector_(self, R=None) -> FreeModuleElement: ...
    def ambient_module(self) -> HeckeModule_generic: ...
    def _lmul_(self, x: object) -> HeckeModuleElement: ...
    def _rmul_(self, x: object) -> HeckeModuleElement: ...
    def _neg_(self) -> HeckeModuleElement: ...
    def _pos_(self) -> Self: ...
    def _sub_(self, right: HeckeModuleElement) -> HeckeModuleElement: ...
    def is_cuspidal(self) -> bool: ...
    def is_eisenstein(self) -> bool: ...
    def is_new(self, p: Optional[int] = None) -> bool: ...
    def is_old(self, p: Optional[int] = None) -> bool: ...
