from sage.modular.modsym.space import ModularSymbolsSpace
from sage.rings.integer import Integer
from sage.rings.rational import Rational
from sage.rings.ring import Ring
from sage.modular.hecke.module import HeckeModule_generic
from sage.modular.arithgroup.congroup_generic import CongruenceSubgroup
from sage.modular.dirichlet import DirichletCharacter
from sage.structure.sequence import Sequence
from sage.modular.modform.element import ModularFormElement
from typing import overload

class ModularFormsSpace(HeckeModule_generic):
    Element = ModularFormElement

    def __init__(self, group: CongruenceSubgroup, weight: Integer | Rational, character: DirichletCharacter | None, base_ring: Ring, category: object = ...) -> None: ...
    def prec(self, new_prec: Integer | None = ...) -> Integer: ...
    def set_precision(self, new_prec: Integer) -> None: ...
    def weight(self) -> Integer | Rational: ...
    def group(self) -> CongruenceSubgroup: ...
    def character(self) -> DirichletCharacter | None: ...
    def has_character(self) -> bool: ...
    def is_ambient(self) -> bool: ...
    def echelon_form(self) -> ModularFormsSpace: ...
    def echelon_basis(self) -> Sequence: ...
    def integral_basis(self) -> Sequence: ...
    def q_expansion_basis(self, prec: Integer | None = ...) -> Sequence: ...
    def q_echelon_basis(self, prec: Integer | None = ...) -> Sequence: ...
    def q_integral_basis(self, prec: Integer | None = ...) -> Sequence: ...
    def span_of_basis(self, B: object) -> ModularFormsSpace: ...
    def basis(self) -> Sequence: ...
    def dimension(self) -> Integer: ...
    def gen(self, n: Integer) -> ModularFormElement: ...
    def gens(self) -> tuple[ModularFormElement, ...]: ...
    def sturm_bound(self, M: ModularFormsSpace | None = ...) -> Integer: ...
    def cuspidal_submodule(self) -> ModularFormsSpace: ...
    def cuspidal_subspace(self) -> ModularFormsSpace: ...
    def is_cuspidal(self) -> bool: ...
    def is_eisenstein(self) -> bool: ...
    def new_submodule(self, p: Integer | None = ...) -> ModularFormsSpace: ...
    def new_subspace(self, p: Integer | None = ...) -> ModularFormsSpace: ...
    def eisenstein_series(self) -> list[ModularFormElement]: ...
    def decomposition(self) -> list[ModularFormsSpace]: ...
    def newforms(self, names: str | tuple[str, ...] | None = ...) -> list[ModularFormElement]: ...
    def eisenstein_submodule(self) -> ModularFormsSpace: ...
    def eisenstein_subspace(self) -> ModularFormsSpace: ...
    def embedded_submodule(self) -> HeckeModule_generic: ...
    def level(self) -> Integer: ...
    def modular_symbols(self, sign: Integer = ...) -> ModularSymbolsSpace: ...
    def find_in_space(self, f: ModularFormElement, forms: list[ModularFormElement] | None = ..., prec: Integer | None = ..., indep: bool = ...) -> Sequence: ...

class CuspForms(ModularFormsSpace): ...

class ModularForms(ModularFormsSpace): ...
