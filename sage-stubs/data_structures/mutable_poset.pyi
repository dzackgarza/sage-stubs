from collections.abc import Callable, Iterable, Iterator
from sage.structure.element import Element
from sage.structure.sage_object import SageObject


class MutablePosetShell(SageObject):
    @property
    def poset(self) -> MutablePoset: ...
    @property
    def element(self) -> Element: ...
    @property
    def key(self) -> Element: ...
    def __init__(self, poset: object, element: object) -> None: ...
    def predecessors(self, reverse: object = ...) -> Iterator[object]: ...
    def successors(self, reverse: object = ...) -> Iterator[object]: ...
    def is_special(self) -> bool: ...
    def is_null(self) -> bool: ...
    def is_oo(self) -> bool: ...
    def __hash__(self) -> int: ...
    def le(self, other: object, reverse: object = ...) -> bool: ...
    def eq(self, other: object) -> bool: ...
    def lower_covers(self, shell: object, reverse: object = ...) -> Iterator[object]: ...
    def upper_covers(self, shell: object, reverse: object = ...) -> Iterator[object]: ...
    def iter_depth_first(self, reverse: object = ..., key: object = ..., condition: object = ...) -> Iterator[object]: ...
    def iter_topological(self, reverse: object = ..., key: object = ..., condition: object = ...) -> Iterator[object]: ...
    def merge(self, element: object, check: object = ..., delete: object = ...) -> None: ...

class MutablePoset(SageObject):
    @property
    def null(self) -> Element: ...
    @property
    def oo(self) -> Element: ...
    def __init__(self, data: object = ..., key: object = ..., merge: object = ..., can_merge: object = ...) -> None: ...
    def clear(self) -> None: ...
    def __len__(self) -> int: ...
    def shell(self, key: object) -> MutablePosetShell: ...
    def element(self, key: object) -> Element: ...
    def get_key(self, element: object) -> Element: ...
    def copy(self, mapping: object = ...) -> MutablePoset: ...
    def shells(self, include_special: object = ...) -> Iterator[object]: ...
    def shells_topological(self, include_special: object = ..., reverse: object = ..., key: object = ...) -> Iterator[object]: ...
    def elements(self, **kwargs: object) -> Iterator[object]: ...
    def elements_topological(self, **kwargs: object) -> Iterator[object]: ...
    def keys(self, **kwargs: object) -> Iterator[object]: ...
    def keys_topological(self, **kwargs: object) -> Iterator[object]: ...
    def repr(self, include_special: object = ..., reverse: object = ...) -> str: ...
    def repr_full(self, reverse: object = ...) -> str: ...
    def contains(self, key: object) -> bool: ...
    def add(self, element: object) -> None: ...
    def remove(self, key: object, raise_key_error: object = ...) -> None: ...
    def discard(self, key: object, raise_key_error: object = ...) -> None: ...
    def pop(self, **kwargs: object) -> Element: ...
    def union(self, *other: object) -> MutablePoset: ...
    def union_update(self, *other: object) -> None: ...
    def difference(self, *other: object) -> MutablePoset: ...
    def difference_update(self, *other: object) -> None: ...
    def intersection(self, *other: object) -> MutablePoset: ...
    def intersection_update(self, *other: object) -> None: ...
    def symmetric_difference(self, other: object) -> MutablePoset: ...
    def symmetric_difference_update(self, other: object) -> None: ...
    def is_disjoint(self, other: object) -> bool: ...
    def is_subset(self, other: object) -> bool: ...
    def is_superset(self, other: object) -> bool: ...
    def merge(self, key: object = ..., reverse: object = ...) -> None: ...
    def maximal_elements(self) -> Iterator[object]: ...
    def minimal_elements(self) -> Iterator[object]: ...
    def map(self, function: object, topological: object = ..., reverse: object = ...) -> None: ...
    def mapped(self, function: object) -> Element: ...
