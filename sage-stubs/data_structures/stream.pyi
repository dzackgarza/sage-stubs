    def order(self) -> int: ...
    def __ne__(self, other: object) -> bool: ...
    def is_nonzero(self) -> bool: ...
    def is_uninitialized(self) -> bool: ...
    def input_streams(self) -> list[Stream]: ...

class Stream_inexact(Stream):
    def __init__(self, is_sparse: object, true_order: object) -> None: ...
    def is_nonzero(self) -> bool: ...
    def __getstate__(self) -> None: ...
    def __setstate__(self, d: object) -> None: ...
    def __getitem__(self, n: object) -> Element: ...
    def iterate_coefficients(self) -> Iterator[Element]: ...
    def __ne__(self, other: object) -> bool: ...

class Stream_exact(Stream):
