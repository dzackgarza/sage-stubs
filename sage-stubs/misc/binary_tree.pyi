class BinaryTree:
    def insert(self, key: object, value: object = ...) -> None: ...
    def delete(self, key: int) -> object | None: ...
    def get(self, key: int) -> object | None: ...
    def contains(self, key: int) -> bool: ...
    def get_max(self) -> object | None: ...
    def get_min(self) -> object | None: ...
    def pop_max(self) -> object | None: ...
    def pop_min(self) -> object | None: ...
    def is_empty(self) -> bool: ...
    def keys(self, order: str = ...) -> list[int]: ...
    def values(self, order: str = ...) -> list[object | None]: ...
