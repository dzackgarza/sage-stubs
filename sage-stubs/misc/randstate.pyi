import random
from collections.abc import Callable
from typing import Protocol
from typing import Self

from sage.rings.integer import Integer


class _GpRandomState(Protocol):
    def getrand(self) -> int: ...
    def setrand(self, seed: int) -> int: ...

class randstate:
    def __cinit__(self, *args: object, **opts: object) -> None: ...
    def __init__(self, seed: int | None = None) -> None: ...
    def seed(self) -> int: ...
    def python_random(
        self,
        cls: type[random.Random] | None = None,
        seed: int | None = None,
    ) -> random.Random: ...
    def ZZ_seed(self) -> Integer: ...
    def long_seed(self) -> int: ...
    def set_seed_libc(self, force: bool) -> None: ...
    def set_seed_ntl(self, force: bool) -> None: ...
    def set_seed_gap(self) -> None: ...
    def set_seed_libgap(self) -> None: ...
    def set_seed_gp(self, gp: _GpRandomState | None = None) -> None: ...
    def set_seed_pari(self) -> None: ...
    def c_random(self) -> int: ...
    def c_rand_double(self) -> float: ...
    def __dealloc__(self) -> None: ...
    def __enter__(self) -> Self: ...
    def __exit__(
        self,
        ty: type[BaseException] | None,
        value: BaseException | None,
        traceback: object,
    ) -> bool: ...

def current_randstate() -> randstate: ...
def set_random_seed(seed: int | None = None) -> None: ...
def random() -> int: ...
def initial_seed() -> int: ...
def benchmark_libc() -> None: ...
def benchmark_mt() -> None: ...
def _doctest_libc_random() -> int: ...

seed: type[randstate]
