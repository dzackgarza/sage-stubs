from collections.abc import Iterator
from typing import TypeVar, overload

_K = TypeVar("_K")
_V = TypeVar("_V")
_T = TypeVar("_T")

class WeakValueDictEraser:
    def __init__(self, D: WeakValueDictionary[_K, _V]) -> None: ...
    def __call__(self, r: object) -> None: ...

class WeakValueDictionary(dict[_K, _V]):
    def __init__(self, data: object = ...) -> None: ...
    def __copy__(self) -> WeakValueDictionary[_K, _V]: ...
    def __deepcopy__(self, memo: dict[int, object]) -> WeakValueDictionary[_K, _V]: ...
    def setdefault(self, key: _K, default: _V, /) -> _V: ...
    def __setitem__(self, k: _K, v: _V) -> None: ...
    @overload
    def pop(self, key: _K, /) -> _V: ...
    @overload
    def pop(self, key: _K, default: _V | _T, /) -> _V | _T: ...
    def popitem(self) -> tuple[_K, _V]: ...
    @overload
    def get(self, key: _K, default: None = ..., /) -> _V | None: ...
    @overload
    def get(self, key: _K, default: _V, /) -> _V: ...
    @overload
    def get(self, key: _K, default: _T, /) -> _V | _T: ...
    def __getitem__(self, k: _K) -> _V: ...
    def __contains__(self, key: object) -> bool: ...
    def __iter__(self) -> Iterator[_K]: ...
    def values_list(self) -> list[_V]: ...
    def items_list(self) -> list[tuple[_K, _V]]: ...

class CachedWeakValueDictionary(WeakValueDictionary[_K, _V]):
    def __init__(self, data: object = ..., cache: int = ...) -> None: ...
