class WithEqualityById:
    def __hash__(self) -> int: ...
    def __richcmp__(self, other: object, op: int) -> bool: ...

class Singleton(WithEqualityById):
    @staticmethod
    def __classcall__(cls: type) -> Singleton: ...
    def __copy__(self) -> Singleton: ...
    def __reduce__(self) -> tuple[type, tuple[()]]: ...

class FastHashable_class:
    h: int
    def __init__(self, h: int) -> None: ...
    def __hash__(self) -> int: ...
    def __copy__(self) -> FastHashable_class: ...
    def __reduce__(self) -> tuple[object, ...]: ...

