from collections.abc import Callable, Iterator

class lazy_list_generic:
    cache: list[object]
    start: int | None
    stop: int | None
    step: int | None

    def __init__(
        self,
        cache: list[object] | None = None,
        start: int | None = None,
        stop: int | None = None,
        step: int | None = None,
    ) -> None: ...

    def list(self) -> list[object]: ...
    def _info(self) -> str: ...
    def __add__(self, other: object) -> lazy_list_generic: ...
    def __reduce__(self) -> tuple[object, ...]: ...
    def __iter__(self) -> Iterator[object]: ...

class lazy_list_from_iterator(lazy_list_generic):
    iterator: Iterator[object]
    def __init__(self, iterator: Iterator[object], cache: list[object] | None = None, stop: int | None = None) -> None: ...
    def __reduce__(self) -> tuple[object, ...]: ...

class lazy_list_from_function(lazy_list_generic):
    function: Callable[[int], object]
    def __init__(self, function: Callable[[int], object], cache: list[object] | None = None, stop: int | None = None) -> None: ...
    def __reduce__(self) -> tuple[object, ...]: ...

class lazy_list_from_update_function(lazy_list_generic):
    function: Callable[[list[object]], None]
    def __init__(self, function: Callable[[list[object]], None], cache: list[object] | None = None, stop: int | None = None) -> None: ...
    def __reduce__(self) -> tuple[object, ...]: ...
