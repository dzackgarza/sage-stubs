from collections.abc import Callable, Iterable, Mapping
from typing import TypeVar, overload

_KT = TypeVar("_KT")
_VT = TypeVar("_VT")
_TDefault = TypeVar("_TDefault")

class KeyConvertingDict(dict[_KT, _VT]):
    key_conversion_function: Callable[[object], _KT]
    def __init__(
        self,
        key_conversion_function: Callable[[object], _KT],
        data: Mapping[object, _VT] | Iterable[tuple[object, _VT]] | None = ...,
    ) -> None: ...
    def __getitem__(self, key: object) -> _VT: ...
    def __setitem__(self, key: object, value: _VT) -> None: ...
    def __delitem__(self, key: object) -> None: ...
    def __contains__(self, key: object) -> bool: ...
    @overload
    def pop(self, key: object) -> _VT: ...
    @overload
    def pop(self, key: object, default: _VT) -> _VT: ...
    @overload
    def pop(self, key: object, default: _TDefault) -> _VT | _TDefault: ...
    @overload
    def setdefault(self, key: object) -> _VT | None: ...
    @overload
    def setdefault(self, key: object, default: _VT) -> _VT: ...
    def update(self, *args: object, **kwds: object) -> None: ...
