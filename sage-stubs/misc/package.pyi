from pathlib import Path
from typing import NamedTuple

class PackageInfo(NamedTuple):
    name: str
    type: str | None
    source: str | None
    installed_version: str | None
    remote_version: str | None
    def is_installed(self) -> bool: ...

def pkgname_split(name: str) -> tuple[str, str]: ...
def pip_remote_version(pkg: str, pypi_url: str = ..., ignore_URLError: bool = ...) -> str | None: ...
def spkg_type(name: str) -> str | None: ...
def pip_installed_packages(normalization: str | None = ...) -> dict[str, str]: ...
def list_packages(
    *pkg_types: str,
    pkg_sources: list[str] = ...,
    local: bool = ...,
    ignore_URLError: bool = ...,
    exclude_pip: bool = ...,
) -> dict[str, PackageInfo]: ...
def installed_packages(exclude_pip: bool = ...) -> dict[str, str]: ...
def is_package_installed(package: str, exclude_pip: bool = ...) -> bool: ...
def is_package_installed_and_updated(package: str) -> bool: ...
def package_versions(package_type: str, local: bool = ...) -> dict[str, tuple[str, str]]: ...
def package_manifest(package: str) -> dict[str, object]: ...
