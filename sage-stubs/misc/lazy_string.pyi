from collections.abc import Callable, Iterable, Iterator
import types

def is_lazy_string(obj: object) -> bool: ...
def lazy_string(f: Callable[..., str] | str, *args: object, **kwargs: object) -> _LazyString: ...
def _make_lazy_string(
    ftype: str | None,
    fpickle: Callable[[], str] | str,
    args: tuple[object, ...],
    kwargs: dict[str, object],
) -> _LazyString: ...

class _LazyString:
    func: Callable[..., str] | str
    args: tuple[object, ...]
    kwargs: dict[str, object]
    def __init__(
        self,
        f: Callable[..., str] | str,
        args: tuple[object, ...],
        kwargs: dict[str, object],
    ) -> None: ...
    @property
    def value(self) -> str: ...
    def __contains__(self, key: str) -> bool: ...
    def __bool__(self) -> bool: ...
    def __dir__(self) -> list[str]: ...
    def __iter__(self) -> Iterator[str]: ...
    def __len__(self) -> int: ...
    def __fspath__(self) -> str: ...
    def __add__(self, other: str) -> str: ...
    def __mod__(self, other: str | tuple[object, ...]) -> str: ...
    def __mul__(self, other: int) -> str: ...
    def __richcmp__(self, other: object, op: int) -> bool: ...
    def __getattr__(self, name: str) -> str | int | bool | list[str]: ...
    def __reduce__(self) -> tuple[object, ...]: ...
    def __getitem__(self, key: int | slice) -> str: ...
    def __copy__(self) -> _LazyString: ...
    def update_lazy_string(self, args: tuple[object, ...], kwds: dict[str, object]) -> None: ...
