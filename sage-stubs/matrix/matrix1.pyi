from sage.matrix.matrix0 import Matrix
from sage.matrix.matrix_space import MatrixSpace
from sage.modules.free_module_element import FreeModuleElement
from collections.abc import Iterator
from sage.structure.element import Element

class Matrix(Matrix):
    def numpy(self, dtype: object = None, copy: bool = True) -> Element: ...
    def matrix_over_field(self) -> Matrix: ...
    def lift(self) -> Matrix: ...
    def lift_centered(self) -> Matrix: ...
    def columns(self, copy: bool = True) -> list[FreeModuleElement]: ...
    def rows(self, copy: bool = True) -> list[FreeModuleElement]: ...
    def dense_columns(self, copy: bool = True) -> list[FreeModuleElement]: ...
    def dense_rows(self, copy: bool = True) -> list[FreeModuleElement]: ...
    def sparse_columns(self, copy: bool = True) -> list[FreeModuleElement]: ...
    def sparse_rows(self, copy: bool = True) -> list[FreeModuleElement]: ...
    def column(self, i: int, from_list: bool = False) -> FreeModuleElement: ...
    def row(self, i: int, from_list: bool = False) -> FreeModuleElement: ...
    def stack(self, bottom: Matrix, subdivide: bool = False) -> Matrix: ...
    def augment(self, right: Matrix, subdivide: bool = False) -> Matrix: ...
    def matrix_from_columns(self, columns: object) -> Matrix: ...
    def delete_columns(self, dcols: object, check: bool = True) -> Matrix: ...
    def matrix_from_rows(self, rows: object) -> Matrix: ...
    def delete_rows(self, drows: object, check: bool = True) -> Matrix: ...
    def matrix_from_rows_and_columns(self, rows: object, columns: object) -> Matrix: ...
    def submatrix(self, row: int = 0, col: int = 0, nrows: int | None = None, ncols: int | None = None) -> Matrix: ...
    def set_row(self, row: int, v: FreeModuleElement) -> None: ...
    def set_column(self, col: int, v: FreeModuleElement) -> None: ...
    def zero_pattern_matrix(self, ring: object = None) -> Matrix: ...
    def dense_matrix(self) -> Matrix: ...
    def sparse_matrix(self) -> Matrix: ...
    def matrix_space(self, nrows: int | None = None, ncols: int | None = None, sparse: bool | None = None) -> MatrixSpace: ...
    def new_matrix(self, nrows: int | None = None, ncols: int | None = None, entries: object = None, coerce: bool = True, copy: bool = True) -> Matrix: ...
    def block_sum(self, other: Matrix) -> Matrix: ...
