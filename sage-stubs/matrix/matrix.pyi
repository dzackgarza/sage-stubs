from sage.structure.element import Matrix as Matrix_element
from sage.rings.integer import Integer
from sage.rings.ring import CommutativeRing
from sage.structure.element import Element

class Matrix(Matrix_element):
    def nrows(self) -> Integer: ...
    def ncols(self) -> Integer: ...
    def base_ring(self) -> CommutativeRing: ...
    def det(self, *args: object, **kwds: object) -> Element: ...
    def rank(self) -> Integer: ...
    def trace(self) -> Element: ...
    def transpose(self) -> Matrix: ...
    def inverse(self) -> Matrix: ...
    def is_square(self) -> bool: ...
    def is_invertible(self) -> bool: ...
    def change_ring(self, ring: CommutativeRing) -> Matrix: ...
    def submatrix(self, row: int = 0, col: int = 0, nrows: int | None = None, ncols: int | None = None) -> Matrix: ...
    def augment(self, right: Matrix, subdivide: bool = False) -> Matrix: ...
    def stack(self, bottom: Matrix, subdivide: bool = False) -> Matrix: ...

class Matrix_dense(Matrix):
    def __copy__(self) -> Matrix_dense: ...
    def transpose(self) -> Matrix_dense: ...
    def antitranspose(self) -> Matrix_dense: ...
