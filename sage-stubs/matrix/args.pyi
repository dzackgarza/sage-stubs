from collections.abc import Iterator
from sage.structure.parent import Parent
from sage.rings.ring import CommutativeRing
from sage.matrix.matrix_space import MatrixSpace
from sage.matrix.matrix import Matrix

class SparseEntry:
    i: int
    j: int
    entry: object
    def __init__(self, i: int, j: int, entry: object) -> None: ...
    def __iter__(self) -> Iterator[object]: ...

class MatrixArgs:
    base: CommutativeRing | None
    nrows: int
    ncols: int
    entries: object
    sparse: int
    row_keys: object
    column_keys: object
    space: MatrixSpace | None
    kwds: dict[str, object]
    def __init__(self, *args: object, base_ring: CommutativeRing | None = None, nrows: int | None = None, ncols: int | None = None, entries: object = None, sparse: bool | None = None, row_keys: object = None, column_keys: object = None, space: MatrixSpace | None = None, **kwds: object) -> None: ...
    def __reduce__(self) -> tuple[object, ...]: ...
    def __iter__(self) -> Iterator[object]: ...
    def iter(self, convert: bool = True, sparse: bool = False) -> Iterator[object]: ...
    def __len__(self) -> int: ...
    def finalized(self) -> MatrixArgs: ...
    def set_nrows(self, nrows: int) -> None: ...
    def set_ncols(self, ncols: int) -> None: ...
    def set_sparse(self, sparse: bool) -> None: ...
    def set_row_keys(self, row_keys: object) -> None: ...
    def set_column_keys(self, column_keys: object) -> None: ...
    def set_space(self, space: MatrixSpace) -> None: ...
    def matrix(self) -> Matrix: ...
    def list(self) -> list[object]: ...
    def dict(self) -> dict[tuple[int, int], object]: ...
