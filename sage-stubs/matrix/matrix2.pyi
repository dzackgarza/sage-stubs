from collections.abc import Sequence

class Matrix:
    def __getitem__(self, key: object) -> object: ...
    def determinant(self, algorithm: str | None = None) -> object: ...
    def det(self, *args: object, **kwds: object) -> object: ...
    def elementary_divisors(self, algorithm: str | None = None) -> Sequence[object]: ...
    def subdivisions(self) -> object: ...
