from collections.abc import Sequence

from sage.structure.element import Element
from sage.structure.parent import Parent

class Matrix:
    def __getitem__(self, key: object) -> Element: ...
    def base_ring(self) -> Parent: ...
    def determinant(self, algorithm: str | None = None) -> Element: ...
    def det(self, *args: object, **kwds: object) -> Element: ...
    def elementary_divisors(self, algorithm: str | None = None) -> Sequence[object]: ...
    def ncols(self) -> int: ...
    def nrows(self) -> int: ...
    def subdivisions(self) -> tuple[list[int], list[int]]: ...
