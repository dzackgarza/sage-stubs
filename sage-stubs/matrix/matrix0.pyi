from sage.structure.element import Element
from sage.rings.ring import CommutativeRing
from sage.matrix.matrix_space import MatrixSpace
from sage.rings.integer import Integer
from sage.modules.free_module_element import FreeModuleElement
from collections.abc import Iterator

class Matrix(Element):
    def list(self) -> list[Element]: ...
    def dense_coefficient_list(self, order: object = None) -> list[Element]: ...
    def dict(self, copy: bool = True) -> dict[tuple[int, int], Element]: ...
    def items(self) -> Iterator[tuple[tuple[int, int], Element]]: ...
    def set_immutable(self) -> None: ...
    def is_immutable(self) -> bool: ...
    def is_mutable(self) -> bool: ...
    def add_to_entry(self, i: int, j: int, elt: Element) -> None: ...
    def __iter__(self) -> Iterator[FreeModuleElement]: ...
    def __getitem__(self, key: object) -> Element | FreeModuleElement | Matrix: ...
    def __setitem__(self, key: object, value: Element) -> None: ...
    def base_ring(self) -> CommutativeRing: ...
    def change_ring(self, ring: CommutativeRing) -> Matrix: ...
    def ncols(self) -> int: ...
    def nrows(self) -> int: ...
    def dimensions(self) -> tuple[int, int]: ...
    def commutator(self, other: Matrix) -> Matrix: ...
    def anticommutator(self, other: Matrix) -> Matrix: ...
    def swap_columns(self, c1: int, c2: int) -> None: ...
    def with_swapped_columns(self, c1: int, c2: int) -> Matrix: ...
    def permute_columns(self, permutation: object) -> None: ...
    def with_permuted_columns(self, permutation: object) -> Matrix: ...
    def swap_rows(self, r1: int, r2: int) -> None: ...
    def with_swapped_rows(self, r1: int, r2: int) -> Matrix: ...
    def permute_rows(self, permutation: object) -> None: ...
    def with_permuted_rows(self, permutation: object) -> Matrix: ...
    def permute_rows_and_columns(self, row_permutation: object, column_permutation: object) -> None: ...
    def with_permuted_rows_and_columns(self, row_permutation: object, column_permutation: object) -> Matrix: ...
    def add_multiple_of_row(self, i: int, j: int, s: Element, start_col: int = 0) -> None: ...
    def with_added_multiple_of_row(self, i: int, j: int, s: Element, start_col: int = 0) -> Matrix: ...
    def add_multiple_of_column(self, i: int, j: int, s: Element, start_row: int = 0) -> None: ...
    def with_added_multiple_of_column(self, i: int, j: int, s: Element, start_row: int = 0) -> Matrix: ...
    def rescale_row(self, i: int, s: Element, start_col: int = 0) -> None: ...
    def with_rescaled_row(self, i: int, s: Element, start_col: int = 0) -> Matrix: ...
    def rescale_col(self, i: int, s: Element, start_row: int = 0) -> None: ...
    def with_rescaled_col(self, i: int, s: Element, start_row: int = 0) -> Matrix: ...
    def set_row_to_multiple_of_row(self, i: int, j: int, s: Element) -> None: ...
    def with_row_set_to_multiple_of_row(self, i: int, j: int, s: Element) -> Matrix: ...
    def set_col_to_multiple_of_col(self, i: int, j: int, s: Element) -> None: ...
    def with_col_set_to_multiple_of_col(self, i: int, j: int, s: Element) -> Matrix: ...
