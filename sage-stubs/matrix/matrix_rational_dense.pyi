from sage.matrix.matrix import Matrix_dense
from sage.structure.parent import Parent
from sage.rings.rational import Rational
from sage.rings.integer import Integer
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.rings.ring import CommutativeRing
from sage.modules.free_module_element import FreeModuleElement

class Matrix_rational_dense(Matrix_dense):
    def __init__(self, parent: Parent, entries: list[object] | None = None, copy: bool | None = None, coerce: bool = True) -> None: ...
    def matrix_from_columns(self, columns: list[int] | tuple[int, ...]) -> Matrix_rational_dense: ...
    def add_to_entry(self, i: int, j: int, elt: object) -> None: ...
    def __neg__(self) -> Matrix_rational_dense: ...
    def __copy__(self) -> Matrix_rational_dense: ...
    def __invert__(self) -> Matrix_rational_dense: ...
    def inverse(self, algorithm: str | None = None, check_invertible: bool = True) -> Matrix_rational_dense: ...
    def determinant(self, algorithm: str | None = None, proof: bool | None = None) -> Rational: ...
    def denominator(self) -> Integer: ...
    def charpoly(self, var: str = 'x', algorithm: str | None = None) -> Polynomial: ...
    def minpoly(self, var: str = 'x', algorithm: str | None = None) -> Polynomial: ...
    def height(self) -> Integer: ...
    def prod_of_row_sums(self, cols: int | tuple[int, ...]) -> Rational: ...
    def change_ring(self, R: CommutativeRing) -> Matrix_dense: ...
    def echelonize(self, algorithm: str | None = None, height_guess: int | None = None, proof: bool | None = None, **kwds: object) -> None: ...
    def echelon_form(self, algorithm: str | None = None, height_guess: int | None = None, proof: bool | None = None, **kwds: object) -> Matrix_rational_dense: ...
    def decomposition(self, is_diagonalizable: bool = False, dual: bool = False, algorithm: str | None = None) -> list[object]: ...
    def randomize(self, density: float = 1, num_bound: int = 2, den_bound: int = 2, distribution: str | None = None, nonzero: bool = False) -> None: ...
    def rank(self, algorithm: str | None = None) -> Integer: ...
    def transpose(self) -> Matrix_rational_dense: ...
    def antitranspose(self) -> Matrix_rational_dense: ...
    def set_row_to_multiple_of_row(self, i: int, j: int, s: object) -> None: ...
    def row(self, i: int, from_list: bool = False) -> FreeModuleElement | list[Rational]: ...
    def column(self, i: int, from_list: bool = False) -> FreeModuleElement | list[Rational]: ...
    def BKZ(self, *args: object, **kwargs: object) -> Matrix_rational_dense: ...
    def LLL(self, *args: object, **kwargs: object) -> Matrix_rational_dense: ...
    def is_LLL_reduced(self, delta: float | None = None, eta: float | None = None) -> bool: ...
