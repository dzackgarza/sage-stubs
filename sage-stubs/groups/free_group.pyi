class FreeGroup_class(Group):
    def rank(self) -> int: ...
    def generators(self) -> tuple[FreeGroupElement, ...]: ...
    def is_abelian(self) -> bool: ...
    def gap(self) -> GapElement: ...

def FreeGroup(*args: object, **kwds: object) -> FreeGroup_class: ...
