from collections.abc import Iterator
from sage.structure.sage_object import SageObject
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.rings.integer import Integer

class ClassFunction(SageObject):
    def __init__(self, G: object, values: object) -> None: ...
    def _repr_(self) -> str: ...
    def __hash__(self) -> int: ...
    def __iter__(self) -> Iterator[Element]: ...
    def __richcmp__(self, other: object, op: object) -> bool: ...
    def __reduce__(self) -> tuple[object, ...]: ...
    def domain(self) -> Parent: ...
    def __call__(self, g: object) -> Element: ...
    def __add__(self, other: object) -> ClassFunction: ...
    def __sub__(self, other: object) -> ClassFunction: ...
    def __mul__(self, other: object) -> ClassFunction: ...
    def __rmul__(self, other: object) -> ClassFunction: ...
    def __pos__(self) -> ClassFunction: ...
    def __neg__(self) -> ClassFunction: ...
    def __pow__(self, other: object) -> ClassFunction: ...
    def symmetric_power(self, n: object) -> ClassFunction: ...
    def exterior_power(self, n: object) -> ClassFunction: ...
    def scalar_product(self, other: object) -> Element: ...
    def is_irreducible(self) -> bool: ...
    def degree(self) -> Integer: ...
    def irreducible_constituents(self) -> tuple[Element, ...]: ...
    def decompose(self) -> tuple[Element, ...]: ...
    def norm(self) -> Element: ...
    def values(self) -> list[Element]: ...
    def central_character(self) -> ClassFunction: ...
    def determinant_character(self) -> ClassFunction: ...
    def tensor_product(self, other: object) -> ClassFunction: ...
    def restrict(self, H: object) -> ClassFunction: ...
    def induct(self, G: object) -> ClassFunction: ...
    def adams_operation(self, k: object) -> ClassFunction: ...
