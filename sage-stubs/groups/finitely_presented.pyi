
from collections.abc import Callable, Sequence
from typing import Protocol, TypeAlias

from sage.categories.category import Category
from sage.categories.morphism import SetMorphism
from sage.groups.free_group import FreeGroup_class, FreeGroupElement
from sage.groups.group import Group
from sage.groups.libgap_mixin import GroupMixinLibGAP
from sage.groups.libgap_wrapper import ElementLibGAP, ParentLibGAP
from sage.groups.perm_gps.permgroup import PermutationGroup_generic
from sage.interfaces.expect import ExpectElement
from sage.libs.gap.element import GapElement
from sage.rings.ring import Ring
from sage.rings.integer import Integer
from sage.rings.infinity import PlusInfinity
from sage.rings.polynomial.laurent_polynomial import LaurentPolynomial
from sage.structure.element import Element
from sage.structure.unique_representation import CachedRepresentation

_TietzeWord: TypeAlias = Sequence[int | Integer]
_RelationTuple: TypeAlias = tuple[FreeGroupElement, ...]
_SemidirectAutomorphism: TypeAlias = tuple[Sequence[FinitelyPresentedGroupElement], Sequence[FinitelyPresentedGroupElement]]
_SemidirectHom: TypeAlias = tuple[Sequence[FinitelyPresentedGroupElement], Sequence[_SemidirectAutomorphism]]
_GroupAlgebraData: TypeAlias = tuple[FinitelyPresentedGroup, Ring, list[LaurentPolynomial], list[LaurentPolynomial]]

class _ReginaGroupPresentation(ExpectElement):
    def __deepcopy__(self) -> _ReginaGroupPresentation: ...
    def addRelation(self, relation: Element) -> None: ...

class GroupMorphismWithGensImages(SetMorphism):
    def _repr_defn(self) -> str: ...

class FinitelyPresentedGroupElement(FreeGroupElement, ElementLibGAP):
    def __init__(self, parent: FinitelyPresentedGroup, x: GapElement | FreeGroupElement | _TietzeWord, check: bool = True) -> None: ...
    def __reduce__(self) -> tuple[FinitelyPresentedGroup, tuple[tuple[int, ...]]]: ...
    def _repr_(self) -> str: ...
    def Tietze(self) -> tuple[int, ...]: ...
    def __hash__(self) -> int: ...
    def __call__(self, *values: Element | int, **kwds: bool) -> Element | int: ...

class RewritingSystem:
    def __init__(self, G: FinitelyPresentedGroup) -> None: ...
    def free_group(self) -> FreeGroup_class: ...
    def finitely_presented_group(self) -> FinitelyPresentedGroup: ...
    def reduce(self, element: FinitelyPresentedGroupElement | FreeGroupElement | _TietzeWord) -> FinitelyPresentedGroupElement: ...
    def gap(self) -> GapElement: ...
    def rules(self) -> dict[FreeGroupElement, FreeGroupElement]: ...
    def is_confluent(self) -> bool: ...
    def make_confluent(self) -> None: ...

class FinitelyPresentedGroup(GroupMixinLibGAP, CachedRepresentation, Group, ParentLibGAP):
    Element: type[FinitelyPresentedGroupElement]
    def __init__(self, free_group: FreeGroup_class, relations: _RelationTuple, category: Category | None = None, libgap_fpgroup: GapElement | None = None) -> None: ...
    def __hash__(self) -> int: ...
    def __richcmp__(self, other: FinitelyPresentedGroup, op: int) -> bool: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def _regina_(self, regina: object | None = ...) -> _ReginaGroupPresentation: ...
    def free_group(self) -> FreeGroup_class: ...
    def relations(self) -> tuple[FreeGroupElement, ...]: ...
    def _perm_isomorphism(self) -> GapElement | None: ...
    def cardinality(self, limit: int = 4096000) -> Integer | PlusInfinity: ...
    def order(self, limit: int = 4096000) -> Integer | PlusInfinity: ...
    def as_permutation_group(self, limit: int = 4096000) -> PermutationGroup_generic: ...
    def direct_product(self, H: FinitelyPresentedGroup, reduced: bool = False, new_names: bool = True) -> FinitelyPresentedGroup: ...
    def semidirect_product(self, H: FinitelyPresentedGroup, hom: _SemidirectHom, check: bool = True, reduced: bool = False) -> FinitelyPresentedGroup: ...
    def _element_constructor_(self, *args: GapElement | FreeGroupElement | _TietzeWord, **kwds: bool) -> FinitelyPresentedGroupElement: ...
    def abelian_invariants(self) -> tuple[Integer, ...]: ...
    def abelianization_map(self) -> GroupMorphismWithGensImages: ...
    def abelianization_to_algebra(self, ring: Ring = ...) -> _GroupAlgebraData: ...
    def simplification_isomorphism(self) -> GroupMorphismWithGensImages: ...
    def simplified(self) -> FinitelyPresentedGroup: ...
    def sorted_presentation(self) -> FinitelyPresentedGroup: ...
    def epimorphisms(self, H: FinitelyPresentedGroup | Group) -> list[GroupMorphismWithGensImages]: ...
