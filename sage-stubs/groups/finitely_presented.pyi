from typing import TYPE_CHECKING, Tuple

if TYPE_CHECKING:
    from sage.groups.free_group import FreeGroup, FreeGroupElement
    from sage.libs.gap.element import GapElement
    from sage.rings.integer import Integer

class GroupMorphismWithGensImages:
    def _repr_defn(self) -> str: ...

class FinitelyPresentedGroupElement:
    def __init__(self, parent, x, check: bool = True) -> None: ...
    def __reduce__(self) -> tuple: ...
    def _repr_(self) -> str: ...
    def Tietze(self) -> Tuple[int, ...]: ...
    def __hash__(self) -> int: ...
    def __call__(self, *values, **kwds): ...

class RewritingSystem:
    def __init__(self, G) -> None: ...
    def __repr__(self) -> str: ...
    def free_group(self) -> FreeGroup: ...
    def finitely_presented_group(self) -> FinitelyPresentedGroup: ...
    def reduce(self, element) -> FinitelyPresentedGroupElement: ...
    def gap(self) -> GapElement: ...
    def rules(self) -> dict: ...
    def is_confluent(self) -> bool: ...
    def make_confluent(self) -> None: ...

class FinitelyPresentedGroup:
    Element: type[FinitelyPresentedGroupElement]
    def __init__(self, free_group: FreeGroup, relations: Tuple, category=None, libgap_fpgroup=None) -> None: ...
    def __hash__(self) -> int: ...
    def __richcmp__(self, other, op: int) -> bool: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def _regina_(self, regina): ...
    def free_group(self) -> FreeGroup: ...
    def relations(self) -> Tuple[FreeGroupElement, ...]: ...
    def _perm_isomorphism(self) -> GapElement | None: ...
    def cardinality(self, limit: int = 4096000) -> Integer: ...
    def order(self, limit: int = 4096000) -> Integer: ...
    def as_permutation_group(self, limit: int = 4096000): ...
    def direct_product(self, H: FinitelyPresentedGroup, reduced: bool = False, new_names: bool = True) -> FinitelyPresentedGroup: ...
    def semidirect_product(self, H: FinitelyPresentedGroup, hom, check: bool = True, reduced: bool = False) -> FinitelyPresentedGroup: ...
    def _element_constructor_(self, *args, **kwds) -> FinitelyPresentedGroupElement: ...
    def abelian_invariants(self) -> Tuple[Integer, ...]: ...
    def abelianization_map(self): ...
    def abelianization_to_algebra(self, ring=None): ...
    def simplification_isomorphism(self): ...
    def simplified(self) -> FinitelyPresentedGroup: ...
    def sorted_presentation(self) -> FinitelyPresentedGroup: ...
    def epimorphisms(self, H): ...
