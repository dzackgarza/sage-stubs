from typing import Optional
from ..algebras.algebra import Algebra
from ..categories.category import Category
from ..categories.morphism import Morphism
from ..categories.homset import Homset
from ..rings.commutative_ring import CommutativeRing
from .element import Element

from .category_object import CategoryObject

class Parent(CategoryObject):
    def __init__(self, category: Optional[Category] = ...) -> None: ...
    def Hom(self, codomain: Parent, category: Optional[Category] = ...) -> Homset: ...
    def _refine_category_(self, category: Category) -> None: ...
    def _test_not_implemented_methods(self) -> None: ...
    def __call__(self, x: Element = ..., *args: Element, **kwargs: Element) -> Element: ...
    def structure_morphism(self) -> Morphism: ...
    def saturation(self, *args: Element, **kwargs: Element) -> Parent: ...
    def zero(self) -> Element: ...
    def base_ring(self) -> Optional[CommutativeRing]: ...
    def quotient_module(self, sub: Parent, **kwargs: Element) -> Parent: ...
    def direct_sum(self, *others: Parent, **kwargs: Element) -> Parent: ...
    def algebra(self, base_ring: CommutativeRing) -> Algebra: ...
