from sage.structure.element import Element
from sage.structure.parent import Parent

class ElementWrapper(Element):
    value: object
    def __init__(self, parent: Parent, value: object) -> None: ...
    def __getstate__(self) -> tuple[Parent, dict[str, object]]: ...
    def __setstate__(self, state: tuple[Parent, dict[str, object]]) -> None: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def _ascii_art_(self) -> str: ...
    def _unicode_art_(self) -> str: ...
    def __hash__(self) -> int: ...
    def __richcmp__(self, other: object, op: int) -> bool | None: ...
    def _lt_by_value(self, other: object) -> bool: ...
    def __copy__(self) -> ElementWrapper: ...

class DummyParent(Parent):
    def __init__(self, name: str) -> None: ...
    def _repr_(self) -> str: ...

class ElementWrapperTester(ElementWrapper):
    def __init__(self) -> None: ...
    def append(self, x: object) -> None: ...
