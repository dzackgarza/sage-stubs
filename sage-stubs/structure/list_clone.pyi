from typing import Self
from types import TracebackType
from sage.structure.element import Element
from sage.structure.parent import Parent
from typing import TypeVar, overload
from collections.abc import Iterable, Iterator

_T = TypeVar("_T")

class ClonableElement(Element):
    def __cinit__(self) -> None: ...
    def set_immutable(self) -> None: ...
    def _set_mutable(self) -> None: ...
    def __hash__(self) -> int: ...
    def __enter__(self) -> Self: ...
    def __exit__(self, typ: type[BaseException] | None, value: BaseException | None, traceback: TracebackType | None) -> bool: ...

class ClonableArray(ClonableElement, Iterable[_T]):
    def __init__(self, parent: Parent, lst: list[_T] | tuple[_T, ...] | ClonableArray[_T], check: bool = True, immutable: bool = True) -> None: ...
    def _repr_(self) -> str: ...
    def __bool__(self) -> bool: ...
    def _set_list(self, lst: list[_T] | tuple[_T, ...]) -> None: ...
    def __len__(self) -> int: ...
    def __getitem__(self, key: int | slice) -> _T | list[_T]: ...
    def __setitem__(self, key: int, value: _T) -> None: ...
    def _setitem(self, key: int, value: _T) -> None: ...
    def __iter__(self) -> Iterator[_T]: ...
    def __contains__(self, item: _T) -> bool: ...
    def __hash__(self) -> int: ...
    def _richcmp_(self, other: object, op: int) -> bool: ...
    def check(self) -> None: ...
    def __reduce__(self) -> tuple[object, tuple[object, ...]]: ...

class ClonableList(ClonableArray[_T]):
    def append(self, el: _T) -> None: ...
    def extend(self, it: Iterable[_T]) -> None: ...
    def insert(self, index: int, el: _T) -> None: ...
    def pop(self, index: int = -1) -> _T: ...
    def remove(self, el: _T) -> None: ...
    def __setitem__(self, key: int | slice, value: _T | Iterable[_T]) -> None: ...
    def __delitem__(self, key: int | slice) -> None: ...

class ClonableIntArray(ClonableElement):
    def __cinit__(self) -> None: ...
    def __init__(self, parent: Parent, lst: list[int] | tuple[int, ...] | ClonableIntArray, check: bool = True, immutable: bool = True) -> None: ...
    def _alloc_(self, size: int) -> None: ...
    def __dealloc__(self) -> None: ...
    def _repr_(self) -> str: ...
    def __bool__(self) -> bool: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[int]: ...
    def __getitem__(self, key: int | slice) -> int | list[int]: ...
    def __setitem__(self, key: int, value: int) -> None: ...
    def _setitem(self, key: int, value: int) -> None: ...
    def __contains__(self, item: int) -> bool: ...
    def __hash__(self) -> int: ...
    def _richcmp_(self, other: object, op: int) -> bool: ...
    def check(self) -> None: ...
    def __reduce__(self) -> tuple[object, tuple[object, ...]]: ...

class NormalizedClonableList(ClonableList[_T]):
    def __init__(self, parent: Parent, lst: list[_T] | tuple[_T, ...] | ClonableArray[_T], check: bool = True, immutable: bool = True) -> None: ...
    def __exit__(self, typ: type[BaseException] | None, value: BaseException | None, traceback: TracebackType | None) -> bool: ...
    def normalize(self) -> None: ...
