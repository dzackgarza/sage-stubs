from sage.structure.parent import Parent

class GenericAction:
    def __init__(self, G: Parent, S: object, is_left: bool, check: bool = True) -> None: ...
    def codomain(self) -> Parent: ...

class ActOnAction(GenericAction):
    def _act_(self, g: object, x: object) -> Parent: ...

class ActedUponAction(GenericAction):
    def _act_(self, g: object, x: object) -> Parent: ...

class ModuleAction:
    def __init__(self, G: Parent, M: Parent, is_left: bool) -> None: ...

class LeftModuleAction(ModuleAction):
    ...

class RightModuleAction(ModuleAction):
    ...

class IntegerAction:
    ...

class IntegerMulAction(IntegerAction):
    ...

class IntegerPowAction(IntegerAction):
    ...

def detect_element_action(X: Parent, Y: object, X_on_left: bool, X_el: object | None = None, Y_el: object | None = None) -> GenericAction | None: ...
