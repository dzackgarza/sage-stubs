from sage.misc.sage_unittest import InstanceTester
from sage.libs.pari.gen import gen
from sage.interfaces.expect import Expect, ExpectElement
from sage.typeset.unicode_art import UnicodeArt
from sage.typeset.ascii_art import AsciiArt
from sage.categories.category import Category
from sage.structure.parent import Parent
from typing import TypeAlias, TypeVar, overload
from collections.abc import Hashable, Iterable
from types import TracebackType

_CacheKey: TypeAlias = Hashable | tuple[Hashable, ...]
_TesterOption: TypeAlias = bool | int | str | None
_PersistKwarg: TypeAlias = bool | int | str | bytes | None


class SageObject:
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def _test_new(self, **options: _TesterOption) -> None: ...
    def rename(self, x: str | None = None) -> None: ...
    def reset_name(self) -> None: ...
    def get_custom_name(self) -> str | None: ...
    def _ascii_art_(self) -> AsciiArt: ...
    def _unicode_art_(self) -> UnicodeArt: ...
    def _cache_key(self) -> _CacheKey: ...
    def save(self, filename: str | None = None, compress: bool = True) -> None: ...
    def dump(self, filename: str, compress: bool = True) -> None: ...
    def dumps(self, compress: bool = True) -> bytes: ...
    def category(self) -> Category: ...
    def _test_category(self, **options: _TesterOption) -> None: ...
    def parent(self) -> type | Parent: ...
    def _tester(self, **options: _TesterOption) -> InstanceTester: ...
    def _test_not_implemented_methods(self, **options: _TesterOption) -> None: ...
    def _test_pickling(self, **options: _TesterOption) -> None: ...
    def _sage_(self) -> SageObject: ...
    def _interface_(self, I: Expect) -> ExpectElement: ...
    def _interface_init_(self, I: Expect | None = None) -> str: ...
    def _interface_is_cached_(self) -> bool: ...
    def _gap_(self, G: Expect | None = None) -> ExpectElement: ...
    def _gap_init_(self) -> str: ...
    def _libgap_(self) -> ExpectElement: ...
    def _gp_(self, G: Expect | None = None) -> ExpectElement: ...
    def _gp_init_(self) -> str: ...
    def _kash_(self, G: Expect | None = None) -> ExpectElement: ...
    def _kash_init_(self) -> str: ...
    def _axiom_(self, G: Expect | None = None) -> ExpectElement: ...
    def _axiom_init_(self) -> str: ...
    def _fricas_(self, G: Expect | None = None) -> ExpectElement: ...
    def _fricas_init_(self) -> str: ...
    def _giac_(self, G: Expect | None = None) -> ExpectElement: ...
    def _giac_init_(self) -> str: ...
    def _maxima_(self, G: Expect | None = None) -> ExpectElement: ...
    def _maxima_init_(self) -> str: ...
    def _maxima_lib_(self, G: Expect | None = None) -> ExpectElement: ...
    def _maxima_lib_init_(self) -> str: ...
    def _magma_init_(self, magma: Expect) -> str: ...
    def _macaulay2_(self, G: Expect | None = None) -> ExpectElement: ...
    def _macaulay2_init_(self, macaulay2: Expect | None = None) -> str: ...
    def _maple_(self, G: Expect | None = None) -> ExpectElement: ...
    def _maple_init_(self) -> str: ...
    def _mathematica_(self, G: Expect | None = None) -> ExpectElement: ...
    def _mathematica_init_(self) -> str: ...
    def _mathics_(self, G: Expect | None = None) -> ExpectElement: ...
    def _octave_(self, G: Expect | None = None) -> ExpectElement: ...
    def _octave_init_(self) -> str: ...
    def _polymake_(self, G: Expect | None = None) -> ExpectElement: ...
    def _polymake_init_(self) -> str: ...
    def _r_init_(self) -> str: ...
    def _singular_(self, G: Expect | None = None) -> ExpectElement: ...
    def _singular_init_(self) -> str: ...
    def __pari__(self) -> gen: ...
    def _pari_init_(self) -> str: ...
    def _regina_(self, G: Expect | None = None) -> ExpectElement: ...
    def _regina_init_(self) -> str: ...


_Persistable: TypeAlias = SageObject | Hashable | Iterable[Hashable]

def loads(s: bytes, compress: bool = True, **kwargs: _PersistKwarg) -> SageObject: ...
def dumps(obj: _Persistable, compress: bool = True, **kwargs: _PersistKwarg) -> bytes: ...
def save(obj: _Persistable, filename: str | None = None, compress: bool = True, **kwargs: _PersistKwarg) -> None: ...
def load(filename: str, compress: bool = True, **kwargs: _PersistKwarg) -> SageObject: ...
def unpickle_all(d: str, compress: bool = True) -> None: ...
def unpickle_global(module: str, name: str) -> SageObject: ...
def unpickle_override(module: str, name: str) -> SageObject: ...
