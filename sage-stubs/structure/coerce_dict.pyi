from collections.abc import Iterator
from typing import Generic, TypeVar

_V = TypeVar("_V")

class MonoDict(Generic[_V]):
    def __init__(self, data: object | None = None, *, weak_values: bool = False) -> None: ...
    def __len__(self) -> int: ...
    def __contains__(self, k: object) -> bool: ...
    def __getitem__(self, k: object) -> _V: ...
    def __setitem__(self, k: object, value: _V) -> None: ...
    def __delitem__(self, k: object) -> None: ...
    def items(self) -> Iterator[tuple[object, _V]]: ...
    def copy(self) -> MonoDict[_V]: ...
    def __reduce__(self) -> tuple[type, ...]: ...

class TripleDict(Generic[_V]):
    def __init__(self, data: object | None = None, *, weak_values: bool = False) -> None: ...
    def __len__(self) -> int: ...
    def __contains__(self, k: object) -> bool: ...
    def __getitem__(self, k: tuple[object, object, object]) -> _V: ...
    def __setitem__(self, k: tuple[object, object, object], value: _V) -> None: ...
    def __delitem__(self, k: tuple[object, object, object]) -> None: ...
    def items(self) -> Iterator[tuple[tuple[object, object, object], _V]]: ...
    def copy(self) -> TripleDict[_V]: ...
    def __reduce__(self) -> tuple[type, ...]: ...
