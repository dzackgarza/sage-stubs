from sage.typeset.unicode_art import UnicodeArt
from sage.typeset.ascii_art import AsciiArt
from typing import TypeVar, overload
from collections.abc import Iterable

_T = TypeVar("_T")

from typing import Generic

class IndexedGenerators(Generic[_T]):
    _indices: _T
    def __init__(self, indices: _T, prefix: str = 'x', **kwds: object) -> None: ...
    def indices(self) -> _T: ...
    def prefix(self) -> str: ...
    @overload
    def print_options(self) -> dict[str, object]: ...
    @overload
    def print_options(self, **kwds: object) -> None: ...
    def _parse_names(self, m: object, use_latex: bool) -> str | None: ...
    def _repr_generator(self, m: object) -> str: ...
    def _ascii_art_generator(self, m: object) -> AsciiArt: ...
    def _unicode_art_generator(self, m: object) -> UnicodeArt: ...
    def _latex_generator(self, m: object) -> str: ...
