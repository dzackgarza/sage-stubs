from sage.structure.parent import Parent
from sage.structure.element import Element

def py_scalar_parent(py_type: type) -> Parent | None: ...
def py_scalar_to_element(x: object) -> Element: ...
def parent_is_numerical(P: object) -> bool: ...
def parent_is_real_numerical(P: object) -> bool: ...

class CoercionModel:
    def __init__(self) -> None: ...
    def reset_cache(self) -> None: ...
    def get_cache(self) -> tuple[dict[object, object], dict[object, object]]: ...
    def record_exceptions(self, value: bool = True) -> None: ...
    def _test_exception_stack(self) -> None: ...
    def exception_stack(self) -> list[str]: ...
    def explain(self, xp: object, yp: object, op: object = ..., verbosity: int = 2) -> tuple[list[object], Parent | None]: ...
    def common_parent(self, *args: object) -> Parent | type: ...
    def _coercion_error(self, x: object, x_map: object, x_elt: object, y: object, y_map: object, y_elt: object) -> None: ...
