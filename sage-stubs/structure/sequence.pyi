from typing import TYPE_CHECKING, TypeVar
from sage.structure.sage_object import SageObject
from collections.abc import Callable

if TYPE_CHECKING:
    from sage.structure.parent import Parent
    from sage.categories.category import Category

_T = TypeVar("_T")

def Sequence(
    x: object,
    universe: Parent | Category | None = None,
    check: bool = True,
    immutable: bool = False,
    cr: bool = False,
    cr_str: bool | None = None,
    use_sage_types: bool = False,
) -> Sequence_generic: ...

class Sequence_generic(SageObject, list):
    def __init__(
        self,
        x: object,
        universe: Parent | Category | None = None,
        check: bool = True,
        immutable: bool = False,
        cr: bool = False,
        cr_str: bool | None = None,
        use_sage_types: bool = False,
    ) -> None: ...
    def reverse(self) -> None: ...
    def __setitem__(self, n: int | slice, value: object) -> None: ...
    def __getitem__(self, n: int | slice) -> object | Sequence_generic: ...
    def __getslice__(self, i: int, j: int) -> Sequence_generic: ...
    def __setslice__(self, i: int, j: int, value: object) -> None: ...
    def append(self, x: object) -> None: ...
    def extend(self, iterable: object) -> None: ...
    def insert(self, index: int, object: object) -> None: ...
    def pop(self, index: int = -1) -> _T: ...
    def remove(self, value: object) -> None: ...
    def sort(self, key: Callable[[object], object] | None = None, reverse: bool = False) -> None: ...
    def __hash__(self) -> int: ...
    def _repr_(self) -> str: ...
    def _repr_pretty_(self, p: object, cycle: bool) -> None: ...
    def _latex_(self) -> str: ...
    def __str__(self) -> str: ...
    def universe(self) -> Parent | Category: ...
    def _require_mutable(self) -> None: ...
    def set_immutable(self) -> None: ...
    def is_immutable(self) -> bool: ...
    def is_mutable(self) -> bool: ...
    def __reduce__(self) -> tuple[type, tuple[object, ...]]: ...
    def __copy__(self) -> Sequence_generic: ...
    def __getattr__(self, name: str) -> Parent | Category | bool | None: ...

seq = Sequence
