from collections.abc import Iterable

from sage.categories.category import Category
from sage.categories.category_singleton import Category_singleton
from sage.categories.category_with_axiom import CategoryWithAxiom
from sage.categories.tensor import TensorProductsCategory
from sage.graphs.digraph import DiGraph
from sage.structure.element import Element
from sage.structure.parent import Parent

class SuperCrystals(Category_singleton):
    def super_categories(self) -> list[Category]: ...

    class ParentMethods:
        def tensor(self, *crystals: Parent, **options: object) -> Parent: ...

    class Finite(CategoryWithAxiom):
        class ParentMethods:
            def digraph(self, index_set: Iterable[int | str] | None = None) -> DiGraph: ...
            def genuine_highest_weight_vectors(self) -> tuple[Element, ...]: ...
            def connected_components(self) -> list[Parent]: ...
            def genuine_lowest_weight_vectors(self) -> tuple[Element, ...]: ...
            def _genuine_highest_lowest_weight_vectors(self) -> tuple[tuple[Element, Element], ...]: ...
            def character(self) -> Element: ...
            def highest_weight_vectors(self) -> tuple[Element, ...]: ...
            def lowest_weight_vectors(self) -> tuple[Element, ...]: ...

        class ElementMethods:
            def is_genuine_highest_weight(self, index_set: Iterable[int | str] | None = None) -> bool: ...
            def is_genuine_lowest_weight(self, index_set: Iterable[int | str] | None = None) -> bool: ...

    class TensorProducts(TensorProductsCategory):
        def extra_super_categories(self) -> list[Category]: ...
