from collections.abc import Callable, Iterable
from sage.categories.category_with_axiom import CategoryWithAxiom_over_base_ring
from sage.categories.category import Category
from sage.structure.parent import Parent
from sage.structure.element import Element
from sage.modules.free_module_element import FreeModuleElement
from sage.rings.integer import Integer
from sage.categories.category_types import Category_over_base_ring

class LieAlgebras(Category_over_base_ring): # type: ignore[misc]
    def super_categories(self) -> list[Category]: ...

    class SubcategoryMethods:
        def Nilpotent(self) -> Category: ...

    def example(self, gens: int | Iterable[int] = 3) -> Parent: ...

    class FiniteDimensional(CategoryWithAxiom_over_base_ring):
        def extra_super_categories(self) -> list[Category]: ...

    class Nilpotent(CategoryWithAxiom_over_base_ring):
        ...

    class ParentMethods:
        def bracket(self, lhs: Element, rhs: Element) -> Element: ...
        def universal_enveloping_algebra(self) -> Parent: ...
        def center_universal_enveloping_algebra(self, UEA: Parent | None = None) -> Parent: ...
        def module(self) -> Parent: ...
        def from_vector(self, v: FreeModuleElement, order: Iterable[object] | None = None, coerce: bool = False) -> Element: ...
        def lift(self) -> Callable[[Element], Element]: ... # Actually a Morphism, returning element lift
        def subalgebra(self, gens: Iterable[Element], names: str | tuple[str, ...] | None = None, index_set: Iterable[object] | None = None, category: Category | None = None) -> Parent: ...
        def ideal(self, *args: object, **kwds: object) -> Parent: ...
        def is_ideal(self, A: Parent) -> bool: ...
        def killing_form(self, x: Element, y: Element) -> Element: ...
        def is_abelian(self) -> bool: ...
        def is_commutative(self) -> bool: ...
        def is_solvable(self) -> bool: ...
        def is_nilpotent(self) -> bool: ...
        def bch(self, X: Element, Y: Element, prec: int | None = None) -> Element: ...
        def lie_group(self, name: str = "G") -> Parent: ...
        def trivial_representation(self) -> Parent: ...
        def representation(self, f: Callable[[Element], object] | dict[object, object], index_set: Iterable[object] | None = None, on_basis: bool = False) -> Parent: ...

    class ElementMethods:
        def bracket(self, rhs: Element) -> Element: ...
        def to_vector(self, order: Iterable[object] | None = None) -> FreeModuleElement: ...
        def lift(self) -> Element: ...
        def killing_form(self, x: Element) -> Element: ...
        def exp(self, lie_group: Parent | None = None) -> Element: ...
