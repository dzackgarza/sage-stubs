from collections.abc import Iterable, Iterator, Sequence
from typing import NoReturn, Protocol

from sage.algebras.group_algebra import GroupAlgebra_class
from .cartesian_product import _CartesianProductCallable
from .category import Category
from .category_with_axiom import CategoryWithAxiom
from .enumerated_sets import EnumeratedSets
from .facade_sets import FacadeSets
from .finite_sets import FiniteSets
from .metric_spaces import MetricSpaces
from .topological_spaces import TopologicalSpaces
from sage.categories.pushout import ConstructionFunctor
from sage.misc.call import AttrCallObject
from sage.rings.infinity import PlusInfinity
from sage.rings.ring import Ring
from sage.sets.image_set import ImageSet, ImageSubobject
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.structure.sage_object import SageCoercionAtom


class _SympySetLike(Protocol):
    @property
    def is_finite_set(self) -> bool: ...

    def __contains__(self, x: object) -> bool: ...


class EmptySetError(ValueError): ...

class Sets:
    class ElementMethods:
        def cartesian_product(self, *elements: Element) -> Element: ...
    class MorphismMethods:
        def is_injective(self) -> bool: ...
        def image(self, domain_subset: Parent | None = None) -> Parent | ImageSet | ImageSubobject: ...
    class ParentMethods:
        def __contains__(self, x: object) -> bool: ...
        def _element_constructor_(self, x: SageCoercionAtom) -> Element: ...
        def is_parent_of(self, element: SageCoercionAtom | Element) -> bool: ...
        def an_element(self) -> Element: ...
        def some_elements(self) -> Sequence[Element]: ...
        def is_empty(self) -> bool: ...
        def construction(self) -> tuple[ConstructionFunctor, Parent] | None: ...
        def cartesian_product(self, *parents: Parent, category: Category | None = ..., extra_category: Category | None = ...) -> Parent: ...
        def algebra(self, base_ring: Ring, category: Category | None = ..., **kwds: SageCoercionAtom) -> GroupAlgebra_class: ...
        def _sympy_(self) -> _SympySetLike: ...
    class SubcategoryMethods:
        def Topological(self) -> TopologicalSpaces: ...
        def Metric(self) -> MetricSpaces: ...
        def Finite(self) -> FiniteSets: ...
        def Infinite(self) -> CategoryWithAxiom: ...
        def Enumerated(self) -> EnumeratedSets: ...
        def Facade(self) -> FacadeSets: ...
    class Finite(CategoryWithAxiom):
        ...
    class Topological(CategoryWithAxiom):
        ...
    class Metric(CategoryWithAxiom):
        def Complete(self) -> CategoryWithAxiom: ...
    class Enumerated(CategoryWithAxiom):
        ...
    class Facade(FacadeSets):
        ...
    class Infinite:
        class SubcategoryMethods:
            def Finite(self) -> NoReturn: ...
        class ParentMethods:
            def is_finite(self) -> bool: ...
            def is_empty(self) -> bool: ...
            def cardinality(self) -> PlusInfinity: ...
    class CartesianProducts:
        class ElementMethods:
            def cartesian_projection(self, i: int | str) -> Element: ...
            def cartesian_factors(self) -> tuple[Element, ...]: ...
        class ParentMethods:
            def __iter__(self) -> Iterator[tuple[Element, ...]]: ...
            def an_element(self) -> tuple[Element, ...]: ...
            def is_empty(self) -> bool: ...
            def is_finite(self) -> bool: ...
            def cardinality(self) -> int | Element: ...
            def random_element(self, *args: SageCoercionAtom) -> tuple[Element, ...]: ...
            def _sets_keys(self) -> Iterable[int | str]: ...
            def cartesian_factors(self) -> tuple[Parent, ...]: ...
            def cartesian_projection(self, i: int | str) -> AttrCallObject: ...
            def construction(self) -> tuple[_CartesianProductCallable, tuple[Parent, ...]]: ...
            def _cartesian_product_of_elements(self, elements: Iterable[Element]) -> tuple[Element, ...]: ...
            def _sympy_(self) -> _SympySetLike: ...
    class Subquotients:
        class ElementMethods:
            def lift(self) -> Element: ...
        class ParentMethods:
            def ambient(self) -> Parent: ...
            def lift(self, x: Element) -> Element: ...
            def retract(self, x: Element) -> Element: ...
    class Quotients:
        class ParentMethods:
            def _an_element_(self) -> Element: ...
    class Subobjects:
        class ParentMethods:
            ...
