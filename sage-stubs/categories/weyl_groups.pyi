from sage.categories.category import Category
from sage.categories.category_with_axiom import CategoryWithAxiom
from sage.structure.element import Element

class WeylGroups(CategoryWithAxiom):
    def super_categories(self) -> list[Category]: ...
    def additional_structure(self) -> Category: ...
    class ParentMethods:
        def coxeter_matrix(self) -> Element: ...
        def pieri_factors(self, *args: object, **keywords: object) -> Element: ...
        def bruhat_cone(self, x: Element, y: Element, side: str = 'upper', backend: str = 'cdd') -> Element: ...
        def quantum_bruhat_graph(self, index_set: tuple[int, ...] | list[int] = ()) -> Element: ...
    class ElementMethods:
        def is_pieri_factor(self) -> bool: ...
        def left_pieri_factorizations(self, max_length: int | None = None) -> list[tuple[Element, ...]]: ...
        def stanley_symmetric_function_as_polynomial(self, max_length: int | None = None) -> Element: ...
        def stanley_symmetric_function(self) -> Element: ...
        def reflection_to_root(self) -> Element: ...
        def reflection_to_coroot(self) -> Element: ...
        def inversions(self, side: str = 'right', inversion_type: str = 'reflections') -> list[Element]: ...
        def inversion_arrangement(self, side: str = 'right') -> Element: ...
        def bruhat_lower_covers_coroots(self) -> list[tuple[Element, Element]]: ...
        def bruhat_upper_covers_coroots(self) -> list[tuple[Element, Element]]: ...
        def quantum_bruhat_successors(self, index_set: list[int] | tuple[int, ...] | None = None, roots: bool = False, quantum_only: bool = False) -> list[Element] | list[tuple[Element, Element]]: ...
