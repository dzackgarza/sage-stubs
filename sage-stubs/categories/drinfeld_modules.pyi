from typing import TYPE_CHECKING
from sage.categories.category import Category
from sage.structure.element import Element

if TYPE_CHECKING:
    from sage.rings.ring_extension import RingExtension
    from sage.rings.morphism import RingHomomorphism
    from sage.rings.polynomial.ore_polynomial_ring import OrePolynomialRing
    from sage.rings.ring import Ring

class DrinfeldModules(Category):
    def super_categories(self) -> list[Category]: ...
    class ParentMethods:
        def A_field(self) -> 'RingExtension': ...
        def base(self) -> 'Ring': ...
        def base_morphism(self) -> 'RingHomomorphism': ...
        def base_over_constants_field(self) -> 'RingExtension': ...
        def characteristic(self) -> Element: ...
        def function_ring(self) -> 'Ring': ...
        def constant_coefficient(self) -> Element: ...
        def ore_polring(self) -> 'OrePolynomialRing': ...
        def ore_variable(self) -> Element: ...
