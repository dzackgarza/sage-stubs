from collections.abc import Iterable, Iterator, Callable
from sage.categories.category import Category
from sage.sets.recursively_enumerated_set import RecursivelyEnumeratedSet
from sage.structure.element import Element
from sage.structure.parent import Parent

class FinitelyGeneratedSemigroups:
    def extra_super_categories(self) -> list[Category]: ...
    def example(self) -> Parent: ...
    class ParentMethods:
        def semigroup_generators(self) -> tuple[Element, ...]: ...
        def succ_generators(self, side: str = ...) -> Callable[[Element], tuple[Element, ...]]: ...
        def __iter__(self) -> Iterator[Element]: ...
        def ideal(self, gens: Iterable[Element], side: str = ...) -> RecursivelyEnumeratedSet: ...
    class Finite:
        class ParentMethods:
            def some_elements(self) -> list[Element]: ...
