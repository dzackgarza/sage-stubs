from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.structure.sage_object import SageCoercionAtom

type FacadeElementInput = Element | SageCoercionAtom

class FacadeSets:
    class ParentMethods:
        def _element_constructor_(self, element: FacadeElementInput) -> Element: ...
        def facade_for(self) -> tuple[Parent, ...] | bool: ...
        def __contains__(self, x: object) -> bool: ...
        def is_parent_of(self, element: FacadeElementInput) -> bool: ...
        def _an_element_(self) -> Element: ...
