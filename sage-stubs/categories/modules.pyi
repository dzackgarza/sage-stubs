from collections.abc import Iterable

from sage.categories.category import Category
from sage.categories.morphism import Morphism
from sage.structure.element import Element
from sage.structure.parent import Parent

class Modules:
    class SubcategoryMethods:
        def base_ring(self) -> Parent: ...
        def TensorProducts(self) -> Category: ...
        def DualObjects(self) -> Category: ...
        def FiniteDimensional(self) -> Category: ...
        def FinitelyPresented(self) -> Category: ...
        def Filtered(self) -> Category: ...
        def Graded(self) -> Category: ...
        def Super(self) -> Category: ...
        def WithBasis(self) -> Category: ...
    class FiniteDimensional:
        def extra_super_categories(self) -> list[Category]: ...
        class TensorProducts:
            def extra_super_categories(self) -> list[Category]: ...
    class FinitelyPresented:
        def extra_super_categories(self) -> list[Category]: ...
    class ParentMethods:
        def linear_combination(
            self,
            iter_of_elements_coeff: Iterable[tuple[object, object]],
            factor_on_left: bool = True,
        ) -> Element: ...
        def tensor_square(self) -> Parent: ...
        def module_morphism(
            self,
            *,
            function: object,
            category: object | None = None,
            codomain: object,
            **keywords: object,
        ) -> Morphism: ...
        def quotient(self, submodule: object, check: bool = True, **kwds: object) -> Parent: ...
    class ElementMethods:
        ...
    class Homsets:
        def extra_super_categories(self) -> list[Category]: ...
        def base_ring(self) -> Parent: ...
        class ParentMethods:
            def base_ring(self) -> Parent: ...
            def zero(self) -> Morphism: ...
        class Endset:
            def extra_super_categories(self) -> list[Category]: ...
    class CartesianProducts:
        def extra_super_categories(self) -> list[Category]: ...
        class ParentMethods:
            def __init_extra__(self) -> None: ...
        class ElementMethods:
            def _lmul_(self, x: object) -> Element: ...
    class TensorProducts:
        def extra_super_categories(self) -> list[Category]: ...
        class ParentMethods:
            def construction(self) -> tuple[object, tuple[Parent, ...]]: ...
            def tensor_factors(self) -> tuple[Parent, ...]: ...
