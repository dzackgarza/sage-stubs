from sage.categories.super_modules import SuperModulesCategory
from sage.structure.element import Element

class SuperModulesWithBasis(SuperModulesCategory):
    class ParentMethods:
        def _even_odd_on_basis(self, m: int | tuple[int, ...]) -> int: ...

    class ElementMethods:
        def is_super_homogeneous(self) -> bool: ...
        def is_even_odd(self) -> int: ...
        def even_component(self) -> Element: ...
        def odd_component(self) -> Element: ...
