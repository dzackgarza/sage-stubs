from sage.categories.category import Category
from sage.categories.morphism import Morphism
from sage.matrix.matrix2 import Matrix
from sage.structure.element import Element
from sage.structure.parent import Parent

class FiniteDimensionalModulesWithBasis:
    class ParentMethods:
        def gens(self) -> tuple[Element, ...]: ...
        def annihilator(self) -> Parent: ...
        def annihilator_basis(self) -> tuple[Element, ...]: ...
        def from_vector(self, vector: object, order: object | None = None) -> Element: ...
        def echelon_form(self, elements: object, **kwargs: object) -> tuple[Element, ...]: ...
        def invariant_module(self, *args: object, **kwargs: object) -> Parent: ...
        def twisted_invariant_module(self, *args: object, **kwargs: object) -> Parent: ...
    class ElementMethods:
        def dense_coefficient_list(self, order: object | None = None) -> list[object]: ...
    class MorphismMethods:
        def matrix(self, side: str = "left") -> Matrix: ...
        def kernel_basis(self) -> tuple[Element, ...]: ...
        def kernel(self) -> Parent: ...
        def image_basis(self) -> tuple[Element, ...]: ...
        def image(self) -> Parent: ...
    class Homsets:
        class Endset:
            class ElementMethods:
                def characteristic_polynomial(self, *args: object, **kwargs: object) -> object | None: ...
                def determinant(self) -> object | None: ...
                def fcp(self, *args: object, **kwargs: object) -> object | None: ...
                def minimal_polynomial(self, *args: object, **kwargs: object) -> object | None: ...
                def trace(self) -> object | None: ...
    class TensorProducts:
        def extra_super_categories(self) -> list[Category]: ...
