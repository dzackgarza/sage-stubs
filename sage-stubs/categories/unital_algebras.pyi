from sage.categories.category import Category
from sage.structure.element import Element

class UnitalAlgebras:
    class ParentMethods:
        def from_base_ring(self, r: object) -> Element: ...
    class WithBasis:
        class ParentMethods:
            def one_basis(self) -> object | tuple[object, ...]: ...
            def one_from_one_basis(self) -> Element: ...
            def one(self) -> Element: ...
            def from_base_ring(self, r: object) -> Element: ...
            def from_base_ring_from_one_basis(self, r: object) -> Element: ...
    class CartesianProducts:
        def extra_super_categories(self) -> list[Category]: ...
        class ParentMethods:
            def one(self) -> Element: ...
