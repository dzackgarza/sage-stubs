from sage.categories.category import Category
from sage.structure.unique_representation import UniqueRepresentation
from sage.structure.sage_object import SageObject
from typing import ClassVar
from typing import Self

class CovariantFunctorialConstruction(UniqueRepresentation, SageObject): ...

class FunctorialConstructionCategory(Category):
    _base_category_class: ClassVar[tuple[type[Category], ...]]
    def __init__(self, category: Category, *args: object) -> None: ...
    def base_category(self) -> Category: ...
    def extra_super_categories(self) -> list[Category]: ...
    def super_categories(self) -> list[Category]: ...
    def _repr_object_names(self) -> str: ...
    def _latex_(self) -> str: ...
    @classmethod
    def category_of(cls, category: Category, *args: object) -> Category: ...

class CovariantConstructionCategory(FunctorialConstructionCategory):
    @classmethod
    def default_super_categories(cls, category: Category, *args: object) -> Category: ...
    def is_construction_defined_by_base(self) -> bool: ...
    def additional_structure(self) -> Self | None: ...

class RegressiveCovariantConstructionCategory(CovariantConstructionCategory):
    @classmethod
    def default_super_categories(cls, category: Category, *args: object) -> Category: ...
