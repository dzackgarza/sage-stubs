from typing import Self
from sage.structure.parent import Parent
from sage.categories.morphism import Morphism
from sage.categories.homset import Homset
from sage.categories.map import Map

class ConstructionFunctor:
    def __mul__(self, other: ConstructionFunctor) -> ConstructionFunctor: ...
    def pushout(self, other: ConstructionFunctor) -> ConstructionFunctor: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def merge(self, other: ConstructionFunctor) -> Self | None: ...
    def commutes(self, other: ConstructionFunctor) -> bool: ...
    def expand(self) -> list[ConstructionFunctor]: ...
    def common_base(self, other_functor: ConstructionFunctor, self_bases: object, other_bases: object) -> Parent: ...

class CompositeConstructionFunctor(ConstructionFunctor):
    def __init__(self, *args: object) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __mul__(self, other: ConstructionFunctor) -> ConstructionFunctor: ...
    def expand(self) -> list[ConstructionFunctor]: ...

class IdentityConstructionFunctor(ConstructionFunctor):
    def __init__(self) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __mul__(self, other: ConstructionFunctor) -> ConstructionFunctor: ...

class MultivariateConstructionFunctor(ConstructionFunctor):
    def common_base(self, other_functor: ConstructionFunctor, self_bases: object, other_bases: object) -> Parent: ...

