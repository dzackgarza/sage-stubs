        def is_empty(self) -> bool: ...
        def iterator_range(self, start: int | Integer | None = None, stop: int | Integer | None = None, step: int | Integer | None = None) -> Iterator[Element]: ...
        def unrank_range(self, start: int | Integer | None = None, stop: int | Integer | None = None, step: int | Integer | None = None) -> list[Element]: ...
        def random_element(self) -> Element: ...
        def rank(self, x: EnumeratedElementInput) -> Integer | None: ...
        def map(self, f: Callable[[EnumeratedElementInput], EnumeratedElementInput], name: str | None = None, *, is_injective: bool = True) -> Parent: ...
