from collections.abc import Callable, Iterable, Iterator
from sage.categories.category import Category
from sage.categories.category_singleton import Category_singleton
import sage.categories.morphism
from sage.categories.tensor import TensorProductsCategory
from sage.combinat.root_system.cartan_type import CartanType_abstract
from sage.graphs.digraph import DiGraph
from sage.structure.element import Element
from sage.structure.parent import Parent

class HighestWeightCrystals(Category_singleton):
    def super_categories(self) -> list[Category]: ...
    def example(self) -> Parent: ...
    def additional_structure(self) -> None: ...

    class ParentMethods:
        def highest_weight_vectors(self) -> tuple[Element, ...]: ...
        def highest_weight_vector(self) -> Element: ...
        def lowest_weight_vectors(self) -> tuple[Element, ...]: ...
        def __iter__(self, index_set: Iterable[int | str] | None = None, max_depth: float = ...) -> Iterator[Element]: ...
        def q_dimension(self, q: Element | None = None, prec: int | None = None, use_product: bool = False) -> Element: ...

        @property
        def connected_components_generators(self) -> Callable[..., tuple[Element, ...]]: ...
        def _Hom_(self, Y: Parent, category: Category | None = None, **options: object) -> HighestWeightCrystalHomset: ...
        def digraph(self, subset: Iterable[Element] | None = None, index_set: Iterable[int | str] | None = None, depth: float | None = None) -> DiGraph: ...

    class ElementMethods:
        def string_parameters(self, word: Iterable[int] | None = None) -> list[int]: ...

    class TensorProducts(TensorProductsCategory):
        def extra_super_categories(self) -> list[Category]: ...

        class ParentMethods:
            def highest_weight_vectors(self) -> tuple[Element, ...]: ...
            def highest_weight_vectors_iterator(self) -> Iterator[Element]: ...


class HighestWeightCrystalMorphism(sage.categories.morphism.Morphism):
    def __init__(self, parent: Parent, on_gens: Callable[[Element], Element] | dict[Element, Element] | list[Element], cartan_type: CartanType_abstract | None = None, virtualization: dict[int | str, list[int | str]] | None = None, scaling_factors: dict[int | str, int] | None = None, gens: Iterable[Element] | None = None, check: bool = True) -> None: ...
    def _call_(self, x: Element) -> Element | None: ...

class HighestWeightCrystalHomset:
    def __init__(self, X: Parent, Y: Parent, category: Category | None = None) -> None: ...
from collections.abc import Iterable
