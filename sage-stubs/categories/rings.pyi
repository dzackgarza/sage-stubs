from typing import Literal, overload

from .category_with_axiom import CategoryWithAxiom
from sage.modules.free_module import FreeModule_generic, ModuleMorphism
from sage.rings.ideal import Ideal_generic
from sage.rings.integer import Integer
from sage.rings.quotient_ring import QuotientRing_nc
from sage.rings.ring import Ring
from sage.structure.element import Element
from sage.structure.parent import Parent

type _IdealInput = Element | Ideal_generic
type _IdealArg = _IdealInput | list[_IdealInput] | tuple[_IdealInput, ...]
type _IdealKwds = bool | type[Ideal_generic] | Literal["twosided", "left", "right"]
type _Names = str | list[str] | tuple[str, ...] | None
type _QuotientKwds = bool | int | str | type[Parent] | CategoryWithAxiom | None
type _FreeModuleBasis = Element | list[Element] | tuple[Element, ...] | None

class Rings:
    class ElementMethods:
        ...
    class MorphismMethods:
        ...
    class ParentMethods:
        def is_ring(self) -> bool: ...
        def is_commutative(self) -> bool: ...
        def is_integral_domain(self, proof: bool = ...) -> bool: ...
        def is_integrally_closed(self) -> bool: ...
        def is_noetherian(self) -> bool: ...
        def is_prime_field(self) -> bool: ...
        def is_zero(self) -> bool: ...
        def is_subring(self, other: Ring) -> bool: ...
        def is_field(self, proof: bool = ...) -> bool: ...
        @overload
        def zeta(self, n: int | Integer = ..., all: Literal[False] = ...) -> Element: ...
        @overload
        def zeta(self, n: int | Integer = ..., all: Literal[True] = ...) -> list[Element]: ...
        def zeta_order(self) -> Integer: ...
        def bracket(self, x: Element, y: Element) -> Element: ...
        def nilradical(self) -> Ideal_generic: ...
        def unit_ideal(self) -> Ideal_generic: ...
        def characteristic(self) -> Integer: ...
        def ideal(self, *args: _IdealArg, **kwds: _IdealKwds) -> Ideal_generic: ...
        def quotient(self, I: _IdealArg, names: _Names = ..., **kwds: _QuotientKwds) -> QuotientRing_nc: ...
        def quo(self, I: _IdealArg, names: _Names = ..., **kwds: _QuotientKwds) -> QuotientRing_nc: ...
        def quotient_ring(self, I: _IdealArg, names: _Names = ..., **kwds: _QuotientKwds) -> QuotientRing_nc: ...
        @overload
        def free_module(
            self,
            base: Ring | None = ...,
            basis: _FreeModuleBasis = ...,
            map: Literal[False] = ...,
        ) -> FreeModule_generic: ...
        @overload
        def free_module(
            self,
            base: Ring | None = ...,
            basis: _FreeModuleBasis = ...,
            map: Literal[True] = ...,
        ) -> tuple[FreeModule_generic, ModuleMorphism, ModuleMorphism]: ...
        def random_element(self, *args: int | Integer) -> Element: ...
        def epsilon(self) -> Element: ...
    class SubcategoryMethods:
        def Finite(self) -> CategoryWithAxiom: ...
        def Topological(self) -> CategoryWithAxiom: ...
    class Finite(CategoryWithAxiom):
        ...
    class Topological(CategoryWithAxiom):
        ...
