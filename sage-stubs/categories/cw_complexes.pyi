from typing import TYPE_CHECKING
from sage.categories.category_singleton import Category_singleton
from sage.categories.category import Category
from sage.categories.category_with_axiom import CategoryWithAxiom

class CWComplexes(Category_singleton):
    def super_categories(self) -> list[Category]: ...
    class SubcategoryMethods:
        def Connected(self) -> Category: ...
        def FiniteDimensional(self) -> Category: ...
    class Connected(CategoryWithAxiom): ...
    class FiniteDimensional(CategoryWithAxiom): ...
    class Finite(CategoryWithAxiom):
        def extra_super_categories(self) -> list[Category]: ...
        class ParentMethods:
            def dimension(self) -> int: ...
    def Compact_extra_super_categories(self) -> tuple[Category]: ...
    class ElementMethods:
        def dimension(self) -> int: ...
    class ParentMethods:
        def dimension(self) -> int: ...
        def cells(self) -> dict[int, tuple[object, ...]]: ...
