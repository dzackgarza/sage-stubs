from sage.categories.category import Category
from sage.categories.morphism import Morphism
from sage.structure.element import Element

class CoalgebrasWithBasis:
    def Graded(self) -> Category: ...
    class Filtered: ...
    class ParentMethods:
        def coproduct_on_basis(self, i: object) -> Element: ...
        @property
        def coproduct(self) -> Morphism: ...
        def counit_on_basis(self, i: object) -> Element: ...
        @property
        def counit(self) -> Morphism: ...
    class ElementMethods:
        def coproduct_iterated(self, n: int = ...) -> Element: ...
    class Super:
        def extra_super_categories(self) -> list[Category]: ...
