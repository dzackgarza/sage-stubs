from sage.categories.category import Category
from sage.categories.category_types import Category_over_base_ring
from sage.categories.category_with_axiom import CategoryWithAxiom_over_base_ring
from sage.rings.ring import Ring
from sage.structure.parent import Parent

class VectorBundles(Category_over_base_ring):
    def __init__(self, base_space: Parent, base_field: Ring, name: str | None = None) -> None: ...
    def super_categories(self) -> list[Category]: ...
    def base_space(self) -> Parent: ...
    def _repr_object_names(self) -> str: ...

    class SubcategoryMethods:
        def Differentiable(self) -> Category: ...
        def Smooth(self) -> Category: ...

    class Differentiable(CategoryWithAxiom_over_base_ring):
        ...

    class Smooth(CategoryWithAxiom_over_base_ring):
        ...
