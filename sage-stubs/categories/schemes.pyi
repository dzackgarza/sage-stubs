from sage.categories.category import Category
from sage.categories.category_with_axiom import CategoryWithAxiom
from sage.categories.homsets import HomsetsCategory
from sage.schemes.generic.morphism import SchemeMorphism
from sage.schemes.generic.scheme import Scheme

class Schemes(Category):
    def super_categories(self) -> list[Category]: ...
    def _call_(self, x: object) -> Scheme | SchemeMorphism: ...

class Schemes_over_base(Category):
    def base_scheme(self) -> Scheme: ...
    def super_categories(self) -> list[Category]: ...
    def _repr_object_names(self) -> str: ...

class AbelianVarieties(Schemes_over_base):
    def __init__(self, base: object) -> None: ...
    def base_scheme(self) -> Scheme: ...
    def super_categories(self) -> list[Category]: ...
    def _repr_object_names(self) -> str: ...
    class Homsets(HomsetsCategory):
        def extra_super_categories(self) -> list[Category]: ...
        class Endset(CategoryWithAxiom):
            def extra_super_categories(self) -> list[Category]: ...

class Jacobians(Schemes_over_base):
    def __init__(self, base: object) -> None: ...
    def base_scheme(self) -> Scheme: ...
    def super_categories(self) -> list[Category]: ...
    def _repr_object_names(self) -> str: ...
    class ParentMethods:
        def base_curve(self) -> Scheme: ...
