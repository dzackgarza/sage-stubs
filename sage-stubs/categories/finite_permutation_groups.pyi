from sage.categories.category import Category
from sage.categories.category_with_axiom import CategoryWithAxiom
from sage.structure.element import Element

class FinitePermutationGroups(CategoryWithAxiom):
    def example(self) -> Element: ...
    def extra_super_categories(self) -> list[Category]: ...
    class ParentMethods:
        def cycle_index(self, parent: Element | None = None) -> Element: ...
        def profile_series(self, variable: str | Element = 'z') -> Element: ...
        profile_polynomial = profile_series
        def profile(self, n: int, using_polya: bool = True) -> int: ...
    class ElementMethods:
        ...
