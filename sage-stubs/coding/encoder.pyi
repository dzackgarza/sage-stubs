from typing import TYPE_CHECKING
from sage.structure.sage_object import SageObject

if TYPE_CHECKING:
    from sage.coding.linear_code import AbstractLinearCode
    from sage.modules.free_module import VectorSpace
    from sage.modules.free_module_element import FreeModuleElement
    from sage.matrix.matrix import Matrix

class Encoder(SageObject):
    def __init__(self, code: AbstractLinearCode) -> None: ...
    def encode(self, word: object) -> FreeModuleElement: ...
    def __call__(self, m: object) -> FreeModuleElement: ...
    def unencode(self, c: object, nocheck: bool = False) -> FreeModuleElement: ...
    def unencode_nocheck(self, c: object) -> FreeModuleElement: ...
    def code(self) -> AbstractLinearCode: ...
    def message_space(self) -> VectorSpace: ...
    def generator_matrix(self) -> Matrix: ...

class EncodingError(Exception):
    pass
