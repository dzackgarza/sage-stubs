from sage.interfaces.expect import Expect, ExpectElement, ExpectFunction, FunctionElement
from sage.interfaces.tab_completion import ExtraTabCompletion

class Gp(ExtraTabCompletion, Expect):
    def __init__(
        self,
        stacksize: int = ...,
        maxread: int | None = ...,
        script_subdirectory: str | None = ...,
        logfile: str | None = ...,
        server: str | None = ...,
        server_tmpdir: str | None = ...,
        init_list_length: int = ...,
        seed: int | None = ...,
    ) -> None: ...
    def set_seed(self, seed: int | None = ...) -> int: ...
    def get_precision(self) -> int: ...
    def set_precision(self, prec: int) -> int: ...
    def get_series_precision(self) -> int: ...
    def set_series_precision(self, prec: int | None = ...) -> int: ...
    def set_default(self, var: str, value: float | str) -> float | str: ...
    def get_default(self, var: str) -> float | str: ...
    def set(self, var: str, value: float | str) -> None: ...
    def get(self, var: str) -> str: ...
    def kill(self, var: str) -> None: ...
    def console(self) -> None: ...
    def version(self) -> tuple[tuple[int, int, int], str]: ...
    def help(self, command: str) -> str: ...

class GpElement(ExpectElement): ...
class GpFunction(ExpectFunction): ...
class GpFunctionElement(FunctionElement): ...
