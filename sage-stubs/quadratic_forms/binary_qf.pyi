from typing import overload
from sage.matrix.matrix import Matrix
from sage.rings.integer import Integer
from sage.rings.polynomial.multi_polynomial import MPolynomial
from sage.structure.element import Element
from sage.quadratic_forms.bqf_class_group import BQFClassElement

class BinaryQF:
    def __init__(self, a: object, b: object = None, c: object = None) -> None: ...
    def _pari_init_(self) -> str: ...
    @staticmethod
    def principal(D: int) -> BinaryQF: ...
    def __mul__(self, right: BinaryQF | Matrix) -> BinaryQF: ...
    def __getitem__(self, n: int | slice) -> Integer: ...
    @overload
    def __call__(self, args: list[int] | tuple[int, int] | object) -> int: ...
    @overload
    def __call__(self, x: int, y: int) -> int: ...

    def __hash__(self) -> int: ...
    def __eq__(self, right: object) -> bool: ...
    def __ne__(self, right: object) -> bool: ...
    def __lt__(self, right: BinaryQF) -> bool: ...
    def __add__(self, Q: BinaryQF) -> BinaryQF: ...
    def __sub__(self, Q: BinaryQF) -> BinaryQF: ...
    def __neg__(self) -> BinaryQF: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def content(self) -> Integer: ...
    def polynomial(self) -> MPolynomial: ...
    @staticmethod
    def from_polynomial(poly: MPolynomial) -> BinaryQF: ...
    def discriminant(self) -> int: ...
    def determinant(self) -> int: ...
    def has_fundamental_discriminant(self) -> bool: ...
    def is_primitive(self) -> bool: ...
    def is_zero(self) -> bool: ...
    def is_weakly_reduced(self) -> bool: ...
    def is_reducible(self) -> bool: ...
    def _reduce_indef(self, transformation: bool = False) -> BinaryQF | tuple[BinaryQF, Matrix]: ...
    def reduced_form(self, transformation: bool = False, algorithm: str = 'default') -> BinaryQF | tuple[BinaryQF, Matrix]: ...
    def _RhoTau(self) -> tuple[BinaryQF, BinaryQF]: ...
    def _Rho(self) -> BinaryQF: ...
    def _Tau(self) -> BinaryQF: ...
    def cycle(self, proper: bool = False) -> list[BinaryQF]: ...
    def is_positive_definite(self) -> bool: ...
    def is_negative_definite(self) -> bool: ...
    def is_indefinite(self) -> bool: ...
    def is_singular(self) -> bool: ...
    def is_nonsingular(self) -> bool: ...
    def is_equivalent(self, other: BinaryQF, proper: bool = True) -> bool: ...
    def is_reduced(self) -> bool: ...
    def complex_point(self) -> Element: ...
    def matrix_action_left(self, M: Matrix) -> BinaryQF: ...
    def matrix_action_right(self, M: Matrix) -> BinaryQF: ...
    def small_prime_value(self, Bmax: int = 1000) -> int: ...
    def solve_integer(self, n: int, *, algorithm: str = 'general', _flag: int = 2) -> tuple[Integer, Integer] | None: ...
    def form_class(self) -> BQFClassElement: ...

def BinaryQF_reduced_representatives(D: int, primitive_only: bool = False, proper: bool = True) -> list[BinaryQF]: ...
