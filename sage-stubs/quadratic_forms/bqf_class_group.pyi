class BQFClassGroup:
    def __init__(self, D: int) -> None: ...
    def discriminant(self) -> int: ...
    def order(self) -> int: ...
    def abelian_group(self) -> object: ...
    def gens(self) -> list[BQFClassElement]: ...
    def zero(self) -> BQFClassElement: ...
    def __call__(self, form: object) -> BQFClassElement: ...

class BQFClassElement:
    def __init__(self, parent: BQFClassGroup, form: object) -> None: ...
    def form(self) -> object: ...
    def order(self) -> int: ...
    def __add__(self, other: BQFClassElement) -> BQFClassElement: ...
    def __neg__(self) -> BQFClassElement: ...
