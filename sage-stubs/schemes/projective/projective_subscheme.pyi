    def degree(self) -> Integer: ...
    def intersection_multiplicity(self, X: AlgebraicScheme_subscheme_projective, P: _PointLike) -> Integer: ...
    def multiplicity(self, P: _PointLike) -> Integer: ...
    def codimension(self) -> Integer: ...
    def defining_polynomials(self) -> tuple[Polynomial, ...]: ...
    def defining_ideal(self) -> MPolynomialIdeal: ...
    def Jacobian(self) -> MPolynomialIdeal: ...
    def is_irreducible(self) -> bool: ...
    def is_empty(self) -> bool: ...
    def intersection(self, other: AlgebraicScheme_subscheme_projective) -> AlgebraicScheme_subscheme_projective: ...
    def hilbert_polynomial(self) -> Polynomial: ...
    def arithmetic_genus(self) -> Integer: ...
    def base_ring(self) -> Ring: ...
    def ambient_space(self) -> ProjectiveSpace_field: ...
