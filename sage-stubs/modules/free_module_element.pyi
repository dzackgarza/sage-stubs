    def subs(self, in_dict: dict[object, object] | None = ..., **kwds: object) -> FreeModuleElement: ...
    def change_ring(self, R: Ring) -> FreeModuleElement: ...
    def coordinate_ring(self) -> Ring: ...
    def additive_order(self) -> Integer | float: ...
    def items(self) -> list[tuple[int, Element]]: ...
    def __abs__(self) -> Element: ...
    def norm(self, p: Integer | float = ...) -> Element | float: ...
    def __getitem__(self, i: int) -> Element: ...
    def get_unsafe(self, i: int) -> Element: ...
    def get(self, i: int) -> Element: ...
    def __setitem__(self, i: int, value: Element) -> None: ...
    def set(self, i: int, value: Element) -> None: ...
    def __invert__(self) -> FreeModuleElement: ...
    def __len__(self) -> int: ...
    def __mod__(self, p: Element) -> FreeModuleElement: ...
