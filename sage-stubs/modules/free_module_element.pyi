    def element(self) -> FreeModuleElement: ...
    def monic(self) -> FreeModuleElement: ...
    def normalized(self, p: Integer | float = ...) -> FreeModuleElement: ...
    def conjugate(self) -> FreeModuleElement: ...
    def inner_product(self, right: FreeModuleElement) -> Element: ...
