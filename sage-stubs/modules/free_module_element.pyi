    def monomial_coefficients(self, copy: bool = ...) -> dict[int, Element]: ...
    def __pari__(self) -> Element: ...
    def numpy(self, dtype: type | None = ...) -> Element: ...
    def __hash__(self) -> int: ...
    def numerical_approx(self, prec: int | None = ..., digits: int | None = ..., algorithm: str | None = ...) -> FreeModuleElement: ...
    def row(self) -> Matrix: ...
    def column(self) -> Matrix: ...
