from collections.abc import Callable

from sage.structure.sage_object import SageObject

class CalculusMethod(SageObject):
    def __init__(self, current: str | None = None, base_field_type: str = "real") -> None: ...
    def set(self, method: str) -> None: ...
    def reset(self) -> None: ...
    def simplify(self, expression: str) -> str: ...
    def simplify_function(self) -> Callable[[str], str]: ...
    def set_simplify_function(self, function: Callable[[str], str]) -> None: ...
