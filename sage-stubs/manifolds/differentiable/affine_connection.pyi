from collections.abc import Sequence
from typing import TypeAlias

from sage.manifolds.chart import Chart
from sage.manifolds.differentiable.manifold import DifferentiableManifold
from sage.manifolds.differentiable.scalarfield import DiffScalarField
from sage.manifolds.differentiable.tensorfield import TensorField
from sage.manifolds.differentiable.vectorfield import VectorField
from sage.rings.integer import Integer
from sage.structure.element import Element, Expression
from sage.structure.sage_object import SageObject
from sage.tensor.modules.comp import Components
from sage.tensor.modules.format_utilities import FormattedExpansion
from sage.tensor.modules.free_module_basis import FreeModuleBasis

_Name: TypeAlias = str | None
_Scalar: TypeAlias = Element | Expression | Integer | int
_ComponentSet: TypeAlias = Components[_Scalar, _Scalar, int | Integer]

class AffineConnection(SageObject):
    def __init__(
        self,
        domain: DifferentiableManifold,
        name: str,
        latex_name: _Name = None,
        init_coef: bool = True,
    ) -> None: ...
    def domain(self) -> DifferentiableManifold: ...
    def coef(self, frame: FreeModuleBasis | None = None) -> _ComponentSet: ...
    def set_coef(self, frame: FreeModuleBasis | None = None) -> _ComponentSet: ...
    def add_coef(self, frame: FreeModuleBasis | None = None) -> _ComponentSet: ...
    def del_other_coef(self, frame: FreeModuleBasis | None = None) -> None: ...
    def set_immutable(self) -> None: ...
    def is_immutable(self) -> bool: ...
    def is_mutable(self) -> bool: ...
    def copy(self, name: _Name = None, latex_name: _Name = None) -> AffineConnection: ...
    def display(
        self,
        frame: FreeModuleBasis | None = None,
        chart: Chart | None = None,
        only_nonzero: bool = True,
        only_nonredundant: bool = True,
    ) -> FormattedExpansion: ...
    def restrict(self, subdomain: DifferentiableManifold) -> AffineConnection: ...
    def torsion(self) -> TensorField: ...
    def riemann(self) -> TensorField: ...
    def ricci(self) -> TensorField: ...
    def connection_form(self, i: int | Integer, j: int | Integer, frame: FreeModuleBasis | None = None) -> TensorField: ...
    def torsion_form(self, i: int | Integer, frame: FreeModuleBasis | None = None) -> TensorField: ...
    def curvature_form(self, i: int | Integer, j: int | Integer, frame: FreeModuleBasis | None = None) -> TensorField: ...
    def set_calc_order(self, symbol: Expression, order: int, truncate: bool = False) -> None: ...
    def __call__(self, vector: VectorField, tensor: TensorField | DiffScalarField) -> TensorField | DiffScalarField: ...
