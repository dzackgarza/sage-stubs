from collections.abc import Callable, Iterable
from typing import TypeAlias, overload

from sage.manifolds.chart import Chart
from sage.manifolds.differentiable.diff_map import DiffMap
from sage.manifolds.differentiable.manifold import DifferentiableManifold
from sage.manifolds.differentiable.metric import PseudoRiemannianMetric
from sage.manifolds.differentiable.poisson_tensor import PoissonTensorField
from sage.manifolds.differentiable.symplectic_form import SymplecticForm
from sage.manifolds.differentiable.vectorfield_module import VectorFieldModule
from sage.manifolds.point import ManifoldPoint
from sage.rings.integer import Integer
from sage.structure.element import Element, Expression, ModuleElementWithMutability
from sage.tensor.modules.comp import CompWithSym, Components
from sage.tensor.modules.finite_rank_free_module import FiniteRankFreeModule
from sage.tensor.modules.format_utilities import FormattedExpansion
from sage.tensor.modules.free_module_basis import FreeModuleBasis
from sage.tensor.modules.free_module_tensor import FreeModuleTensor
from sage.tensor.modules.tensor_with_indices import TensorWithIndices

TensorType: TypeAlias = tuple[int, int]
_Index: TypeAlias = int | Integer
_IndexBlock: TypeAlias = Iterable[_Index]
_Symmetry: TypeAlias = _IndexBlock | Iterable[_IndexBlock] | None
_Scalar: TypeAlias = Element | Expression | Integer | int
_BasisArg: TypeAlias = FreeModuleBasis | None
_Components: TypeAlias = Components[_Scalar, _Scalar, int | Integer]
_TensorArgument: TypeAlias = TensorField | FreeModuleTensor
_DisplayArgument: TypeAlias = FreeModuleBasis | Chart | int | Integer | None

class TensorField(ModuleElementWithMutability):
    def __init__(
        self,
        vector_field_module: VectorFieldModule,
        tensor_type: TensorType,
        name: str | None = None,
        latex_name: str | None = None,
        sym: _Symmetry = None,
        antisym: _Symmetry = None,
        parent: VectorFieldModule | None = None,
    ) -> None: ...
    def set_name(self, name: str | None = None, latex_name: str | None = None) -> None: ...
    def domain(self) -> DifferentiableManifold: ...
    def base_module(self) -> VectorFieldModule | FiniteRankFreeModule: ...
    def tensor_type(self) -> tuple[int | Integer, int | Integer]: ...
    def tensor_rank(self) -> int | Integer: ...
    def symmetries(self) -> None: ...
    def set_immutable(self) -> None: ...
    def set_restriction(self, rst: TensorField) -> None: ...
    def restrict(self, subdomain: DifferentiableManifold, dest_map: DiffMap | None = None) -> TensorField: ...
    def set_comp(self, basis: _BasisArg = None) -> _Components | CompWithSym[_Scalar, _Scalar, int | Integer]: ...
    def add_comp(self, basis: _BasisArg = None) -> _Components | CompWithSym[_Scalar, _Scalar, int | Integer]: ...
    def add_comp_by_continuation(self, frame: FreeModuleBasis, subdomain: DifferentiableManifold, chart: Chart | None = None) -> None: ...
    def add_expr_from_subdomain(self, tensor: TensorField, frame: FreeModuleBasis | None = None) -> None: ...
    def comp(self, basis: _BasisArg = None, from_basis: _BasisArg = None) -> _Components: ...
    def display(self, *args: _DisplayArgument, **kwds: _DisplayArgument) -> FormattedExpansion: ...
    def disp(self, *args: _DisplayArgument, **kwds: _DisplayArgument) -> FormattedExpansion: ...
    def display_comp(
        self,
        frame: FreeModuleBasis | None = None,
        chart: Chart | None = None,
        coordinate_labels: bool = True,
        only_nonzero: bool = True,
        only_nonredundant: bool = False,
    ) -> FormattedExpansion: ...
    def copy_from(self, other: TensorField) -> None: ...
    def copy(self, name: str | None = None, latex_name: str | None = None) -> TensorField: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __pos__(self) -> TensorField: ...
    def __neg__(self) -> TensorField: ...
    @overload
    def __mul__(self, other: TensorField) -> TensorField: ...
    @overload
    def __mul__(self, other: _Scalar) -> TensorField: ...
    def __truediv__(self, other: _Scalar) -> TensorField: ...
    def __call__(self, *args: _TensorArgument) -> TensorField | _Scalar: ...
    def trace(
        self,
        pos1: int = 0,
        pos2: int = 1,
        using: PseudoRiemannianMetric | SymplecticForm | PoissonTensorField | None = None,
    ) -> TensorField | _Scalar: ...
    def contract(self, *args: int | Integer | TensorField) -> TensorField | _Scalar: ...
    def symmetrize(self, *pos: int | Integer) -> TensorField: ...
    def antisymmetrize(self, *pos: int | Integer) -> TensorField: ...
    def lie_derivative(self, vector: TensorField) -> TensorField: ...
    lie_der = lie_derivative
    def at(self, point: ManifoldPoint) -> FreeModuleTensor: ...
    def up(
        self,
        non_degenerate_form: PseudoRiemannianMetric | SymplecticForm | PoissonTensorField,
        pos: int | None = None,
    ) -> TensorField: ...
    def down(self, non_degenerate_form: PseudoRiemannianMetric | SymplecticForm, pos: int | None = None) -> TensorField: ...
    def divergence(self, metric: PseudoRiemannianMetric | None = None) -> TensorField | _Scalar: ...
    def laplacian(self, metric: PseudoRiemannianMetric | None = None) -> TensorField: ...
    def dalembertian(self, metric: PseudoRiemannianMetric | None = None) -> TensorField: ...
    def along(self, mapping: DiffMap) -> TensorField: ...
    def set_calc_order(self, symbol: Expression, order: int, truncate: bool = False) -> None: ...
    def apply_map(
        self,
        fun: Callable[[_Scalar], _Scalar],
        frame: FreeModuleBasis | None = None,
        chart: Chart | None = None,
        keep_other_components: bool = False,
    ) -> None: ...
