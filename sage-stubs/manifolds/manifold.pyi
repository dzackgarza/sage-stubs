from typing import TYPE_CHECKING, Optional, overload
from sage.rings.cc import CC
from sage.rings.real_mpfr import RR

if TYPE_CHECKING:
    from sage.manifolds.chart import Chart
    from sage.manifolds.scalarfield import ScalarField

class TopologicalManifold:
    _dim: int
    def __init__(
        self,
        n: int,
        name: str,
        field,
        structure,
        base_manifold: Optional[TopologicalManifold] = None,
        latex_name: Optional[str] = None,
        start_index: int = 0,
        category=None,
        unique_tag: Optional[str] = None,
    ) -> None: ...
    def _repr_(self) -> str: ...
    def _an_element_(self):
        """Construct some point on the manifold."""
        ...
    def __contains__(self, point: object) -> bool: ...
    def open_subset(
        self,
        name: str,
        latex_name: Optional[str] = None,
        coord_def: dict = ...,
        supersets=None,
    ) -> TopologicalManifold:
        """Create an open subset of the manifold."""
        ...
    def _init_open_subset(self, resu: TopologicalManifold, coord_def: dict) -> None: ...
    def get_chart(self, coordinates: str, domain: Optional[str] = None) -> Chart: ...
    def dimension(self) -> int: ...
    def dim(self) -> int: ...
    def base_field(self):
        """Return the field on which the manifold is defined."""
        ...
    def base_field_type(self) -> str: ...
    def start_index(self) -> int: ...
    def irange(self, start: Optional[int] = None, end: Optional[int] = None):
        """Single index generator."""
        ...
    def index_generator(self, nb_indices: int):
        """Generator of index series."""
        ...
    def atlas(self) -> list[Chart]:
        """Return the list of charts that have been defined on the manifold."""
        ...
    def top_charts(self) -> list[Chart]:
        """Return the list of top charts (not subcharts of larger domains)."""
        ...
    def default_chart(self) -> Chart:
        """Return the default chart defined on the manifold."""
        ...
    def set_default_chart(self, chart: Chart) -> None: ...
    def coord_change(self, chart1: Chart, chart2: Chart):
        """Return the change of coordinates between two charts."""
        ...
    def coord_changes(self) -> dict:
        """Return the changes of coordinates (transition maps) defined on the manifold."""
        ...
    def is_manifestly_coordinate_domain(self) -> bool: ...
    def chart(
        self,
        coordinates: str = "",
        names=None,
        calc_method: Optional[str] = None,
        coord_restrictions=None,
    ) -> Chart:
        """Define a chart, the domain of which is the manifold."""
        ...
    def is_open(self) -> bool: ...
    def set_orientation(self, orientation) -> None: ...
    def orientation(self) -> list[Chart]: ...
    def has_orientation(self) -> bool: ...
    def _get_min_covering(self, object_list: list):
        """Helper method to return the minimal amount of objects necessary to cover."""
        ...
    def vector_bundle(
        self, rank: int, name: str, field: str = "real", latex_name: Optional[str] = None
    ):
        """Return a topological vector bundle over the given field."""
        ...
    def scalar_field_algebra(self):
        """Return the algebra of scalar fields defined on the manifold."""
        ...
    def scalar_field(
        self,
        coord_expression=None,
        chart: Optional[Chart] = None,
        name: Optional[str] = None,
        latex_name: Optional[str] = None,
    ) -> ScalarField:
        """Define a scalar field on the manifold."""
        ...
    def constant_scalar_field(self, value, name: Optional[str] = None, latex_name: Optional[str] = None) -> ScalarField: ...
    def zero_scalar_field(self) -> ScalarField: ...
    def one_scalar_field(self) -> ScalarField: ...
