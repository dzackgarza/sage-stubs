from collections.abc import Iterable, Iterator, Mapping, Sequence
from typing import Protocol, TypeAlias, overload

from sage.categories.category import Category
from sage.manifolds.chart import Chart, CoordChange
from sage.manifolds.scalarfield import ScalarField
from sage.manifolds.scalarfield_algebra import ScalarFieldAlgebra
from sage.manifolds.structure import TopologicalStructure
from sage.manifolds.subset import ManifoldSubset
from sage.manifolds.vector_bundle import TopologicalVectorBundle
from sage.rings.ring import Field
from sage.structure.element import Element, Expression
from sage.structure.parent import Parent

_Scalar: TypeAlias = Element | Expression | int | float | complex | str
_RestrictionClause: TypeAlias = Expression | Sequence[Expression] | tuple[Expression, ...] | frozenset[Expression]
_RestrictionInput: TypeAlias = _RestrictionClause | None
_CoordDef: TypeAlias = Mapping[Chart, _RestrictionInput]
_ScalarExpression: TypeAlias = _Scalar | Mapping[Chart, _Scalar]

class _PointLike(Protocol):
    def parent(self) -> Parent: ...

class _HasDomain(Protocol):
    def domain(self) -> TopologicalManifold: ...

class TopologicalManifold(ManifoldSubset):
    _dim: int
    def __init__(
        self,
        n: int,
        name: str,
        field: str | Field,
        structure: TopologicalStructure,
        base_manifold: TopologicalManifold | None = None,
        latex_name: str | None = None,
        start_index: int = 0,
        category: Category | None = None,
        unique_tag: str | None = None,
    ) -> None: ...
    def _repr_(self) -> str: ...
    def _an_element_(self) -> _PointLike: ...
    def __contains__(self, point: _PointLike) -> bool: ...
    def open_subset(
        self,
        name: str,
        latex_name: str | None = None,
        coord_def: _CoordDef = ...,
        supersets: Sequence[TopologicalManifold] | None = None,
    ) -> TopologicalManifold: ...
    def _init_open_subset(self, resu: TopologicalManifold, coord_def: _CoordDef) -> None: ...
    def get_chart(self, coordinates: str, domain: str | None = None) -> Chart: ...
    def dimension(self) -> int: ...
    def dim(self) -> int: ...
    def base_field(self) -> Field: ...
    def base_field_type(self) -> str: ...
    def start_index(self) -> int: ...
    def irange(self, start: int | None = None, end: int | None = None) -> Iterator[int]: ...
    def index_generator(self, nb_indices: int) -> Iterator[tuple[int, ...]]: ...
    def atlas(self) -> list[Chart]: ...
    def top_charts(self) -> list[Chart]: ...
    def default_chart(self) -> Chart: ...
    def set_default_chart(self, chart: Chart) -> None: ...
    def coord_change(self, chart1: Chart, chart2: Chart) -> CoordChange: ...
    def coord_changes(self) -> dict[tuple[Chart, Chart], CoordChange]: ...
    def is_manifestly_coordinate_domain(self) -> bool: ...
    def chart(
        self,
        coordinates: str = "",
        names: Sequence[str] | None = None,
        calc_method: str | None = None,
        coord_restrictions: _RestrictionInput = None,
    ) -> Chart: ...
    def is_open(self) -> bool: ...
    def set_orientation(self, orientation: Chart | Sequence[Chart]) -> None: ...
    def orientation(self) -> list[Chart]: ...
    def has_orientation(self) -> bool: ...
    def _get_min_covering(self, object_list: Iterable[_HasDomain]) -> set[_HasDomain]: ...
    def vector_bundle(
        self, rank: int, name: str, field: str = "real", latex_name: str | None = None
    ) -> TopologicalVectorBundle: ...
    def scalar_field_algebra(self) -> ScalarFieldAlgebra: ...
    def scalar_field(
        self,
        coord_expression: _ScalarExpression | None = None,
        chart: Chart | str | None = None,
        name: str | None = None,
        latex_name: str | None = None,
    ) -> ScalarField: ...
    def constant_scalar_field(
        self, value: _Scalar, name: str | None = None, latex_name: str | None = None
    ) -> ScalarField: ...
    def zero_scalar_field(self) -> ScalarField: ...
    def one_scalar_field(self) -> ScalarField: ...
