
from sage.structure.element import Element
from sage.combinat.partition import Partition
from sage.combinat.skew_partition import SkewPartition
from sage.sets.enumerated_set import EnumeratedSet
from sage.sets.set import Set
from sage.rings.ring import Ring
from sage.algebras.specht_module import SpechtModule

class Composition(Element):
    def conjugate(self) -> Composition: ...
    def reversed(self) -> Composition: ...
    def complement(self) -> Composition: ...
    def size(self) -> int: ...
    def sum(self) -> Composition: ...
    def near_concatenation(self, other: Composition | list[int]) -> Composition: ...
    def ribbon_decomposition(self, other: Composition | list[int], check: bool = ...) -> list[Composition]: ...
    def join(self, other: Composition | list[int], check: bool = ...) -> Composition: ...
    def meet(self, other: Composition | list[int], check: bool = ...) -> Composition: ...
    def finer(self) -> EnumeratedSet: ...
    def is_finer(self, co2: Composition | list[int]) -> bool: ...
    def fatten(self, grouping: Composition | list[int] | tuple[int, ...]) -> Composition: ...
    def fatter(self) -> EnumeratedSet: ...
    def refinement_splitting(self, J: Composition | list[int]) -> list[Composition]: ...
    def refinement_splitting_lengths(self, J: Composition | list[int]) -> Composition: ...
    def major_index(self) -> int: ...
    def to_code(self) -> list[int]: ...
    def partial_sums(self, final: bool = ...) -> list[int]: ...
    def to_subset(self, final: bool = ...) -> Set: ...
    def descents(self, final_descent: bool = ...) -> list[int]: ...
    def peaks(self) -> list[int]: ...
    def to_partition(self) -> Partition: ...
    def to_skew_partition(self, overlap: int = ...) -> SkewPartition: ...
    def shuffle_product(self, other: Composition | list[int], overlap: bool = ...) -> list[Composition]: ...
    def wll_gt(self, co2: Composition | list[int]) -> bool: ...
    def count(self, n: int) -> int: ...
    def specht_module(self, base_ring: Ring | None = ...) -> SpechtModule: ...
    def specht_module_dimension(self, base_ring: Ring | None = ...) -> int: ...
    def refinements(self) -> list[Composition]: ...
