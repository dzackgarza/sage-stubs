from typing import Generic, List, TypeVar, overload # noqa: UP006, UP035
from collections.abc import Iterator, Iterable
from sage.structure.parent import Parent

_T = TypeVar('_T')

def Combinations(mset: Iterable[_T], k: int | None = None, *, as_tuples: bool = False) -> Parent: ...

class Combinations_mset(Parent, Generic[_T]):
    def __init__(self, mset: Iterable[_T], as_tuples: bool = False) -> None: ...
    def __contains__(self, cb: object) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __iter__(self) -> Iterator[List[_T] | tuple[_T, ...]]: ... # noqa: UP006, UP035
    def cardinality(self) -> int: ...

class Combinations_set(Combinations_mset[_T]):
    def __iter__(self) -> Iterator[List[_T] | tuple[_T, ...]]: ... # noqa: UP006, UP035
    def unrank(self, r: int) -> List[_T] | tuple[_T, ...]: ... # noqa: UP006, UP035
    def rank(self, sub: Iterable[_T]) -> int: ...
    def cardinality(self) -> int: ...

class Combinations_msetk(Parent, Generic[_T]):
    def __init__(self, mset: Iterable[_T], k: int, as_tuples: bool = False) -> None: ...
    def __contains__(self, cb: object) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __iter__(self) -> Iterator[List[_T] | tuple[_T, ...]]: ... # noqa: UP006, UP035
    def cardinality(self) -> int: ...

class Combinations_setk(Combinations_msetk[_T]):
    def __iter__(self) -> Iterator[List[_T] | tuple[_T, ...]]: ... # noqa: UP006, UP035
    def list(self) -> List[List[_T] | tuple[_T, ...]]: ... # noqa: UP006, UP035
    def unrank(self, r: int) -> List[_T] | tuple[_T, ...]: ... # noqa: UP006, UP035
    def rank(self, sub: Iterable[_T]) -> int: ...
    def cardinality(self) -> int: ...
