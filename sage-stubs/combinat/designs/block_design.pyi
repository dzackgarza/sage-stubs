from sage.matrix.matrix import Matrix

class BlockDesign:
    def num_points(self) -> int: ...
    def num_blocks(self) -> int: ...
    def blocks(self) -> list[list[int]]: ...
    def is_simple(self) -> bool: ...
    def arc(self, size: int | None = None) -> list[int]: ...
    def is_t_design(self, t: int, v: int | None = None, k: int | None = None, l: int | None = None) -> bool: ...
    def is_connected(self) -> bool: ...
    def incidence_matrix(self) -> Matrix: ...
    def complement(self, uniform: bool = False) -> BlockDesign: ...
