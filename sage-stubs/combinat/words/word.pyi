from sage.structure.sage_object import SageObject
from sage.structure.parent import Parent
from typing import TypeAlias, overload
import collections.abc

_WordMorphism: TypeAlias = collections.abc.Callable[[str], str] | collections.abc.Mapping[str, str]

class Word_class(SageObject):
    def parent(self) -> Parent: ...
    def string_rep(self) -> str: ...
    def length(self) -> int: ...
    def is_finite(self) -> bool: ...
    def longest_common_prefix(self, other: Word_class | str, length: int | None = ...) -> Word_class: ...
    def longest_periodic_prefix(self, period: int = ...) -> Word_class: ...
    def is_empty(self) -> bool: ...
    def to_integer_word(self) -> Word_class: ...
    def lex_less(self, other: Word_class | str) -> bool: ...
    def lex_greater(self, other: Word_class | str) -> bool: ...
    def apply_morphism(self, morphism: _WordMorphism) -> Word_class: ...
    def delta(self) -> Word_class: ...
    def iterated_right_palindromic_closure(self, f: _WordMorphism, algorithm: str = ...) -> Word_class: ...
    def prefixes_iterator(self, max_length: int | None = ...) -> collections.abc.Iterator[Word_class]: ...
    def palindrome_prefixes_iterator(self, max_length: int | None = ...) -> collections.abc.Iterator[Word_class]: ...
    def partial_sums(self, start: int | None = ..., mod: int | None = ...) -> Word_class: ...
    def finite_differences(self, mod: int | None = ...) -> Word_class: ...
    def sum_digits(self, base: int = ..., mod: int | None = ...) -> Word_class: ...
    def first_occurrence(self, other: Word_class | str, start: int = ...) -> int | None: ...
    def factor_occurrences_iterator(self, fact: Word_class | str) -> collections.abc.Iterator[int]: ...
    def return_words_iterator(self, fact: Word_class | str) -> collections.abc.Iterator[Word_class]: ...
    def complete_return_words_iterator(self, fact: Word_class | str) -> collections.abc.Iterator[Word_class]: ...
