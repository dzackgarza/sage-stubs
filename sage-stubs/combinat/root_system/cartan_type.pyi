from typing import TYPE_CHECKING

from sage.structure.sage_object import SageObject

if TYPE_CHECKING:
    from sage.graphs.graph import Graph
    from sage.matrix.matrix import Matrix
    from sage.combinat.root_system.root_system import RootSystem

class CartanType_abstract(SageObject):
    def type(self) -> str: ...
    def rank(self) -> int: ...
    def index_set(self) -> tuple[object, ...]: ...
    def coxeter_diagram(self) -> Graph: ...
    def coxeter_matrix(self) -> Matrix: ...
    def coxeter_type(self) -> CartanType_abstract: ...
    def dual(self) -> CartanType_abstract: ...
    def relabel(self, relabelling: object | dict[object, object]) -> CartanType_abstract: ...
    def subtype(self, index_set: list[object]) -> CartanType_abstract: ...
    def marked_nodes(self, marked_nodes: list[object]) -> CartanType_abstract: ...
    def is_reducible(self) -> bool: ...
    def is_irreducible(self) -> bool: ...
    def is_atomic(self) -> bool: ...
    def is_compound(self) -> bool: ...
    def is_finite(self) -> bool: ...
    def is_affine(self) -> bool: ...
    def is_crystallographic(self) -> bool: ...
    def is_simply_laced(self) -> bool: ...
    def is_implemented(self) -> bool: ...
    def root_system(self) -> RootSystem: ...
    def as_folding(self, folding_of: object = ..., sigma: object = ...) -> CartanType_abstract: ...
