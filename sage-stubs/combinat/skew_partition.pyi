
from sage.structure.element import Element
from sage.combinat.partition import Partition
from sage.sets.finite_set import FiniteSet
from sage.combinat.posets.posets import FinitePoset
from sage.graphs.digraph import DiGraph
from sage.combinat.sf.sfa import SymmetricFunction
from sage.algebras.specht_module import SpechtModule
from sage.rings.ring import Ring

class SkewPartition(Element):
    def ferrers_diagram(self) -> str: ...
    def pp(self) -> None: ...
    def inner(self) -> Partition: ...
    def outer(self) -> Partition: ...
    def column_lengths(self) -> list[int]: ...
    def row_lengths(self) -> list[int]: ...
    def size(self) -> int: ...
    def is_connected(self) -> bool: ...
    def overlap(self) -> int: ...
    def is_overlap(self, n: int) -> bool: ...
    def is_ribbon(self) -> bool: ...
    def conjugate(self) -> SkewPartition: ...
    def outer_corners(self) -> list[tuple[int, int]]: ...
    def inner_corners(self) -> list[tuple[int, int]]: ...
    def cell_poset(self, orientation: str = ...) -> FinitePoset: ...
    def frobenius_rank(self) -> int: ...
    def cells(self) -> list[tuple[int, int]]: ...
    def to_list(self) -> list[list[int]]: ...
    def to_dag(self, format: str = ...) -> DiGraph: ...
    def quotient(self, k: int) -> SkewPartition: ...
    def rows_intersection_set(self) -> frozenset[int]: ...
    def columns_intersection_set(self) -> frozenset[int]: ...
    def pieri_macdonald_coeffs(self) -> SymmetricFunction: ...
    def k_conjugate(self, k: int) -> SkewPartition: ...
    def jacobi_trudi(self) -> SymmetricFunction: ...
    def outside_corners(self) -> list[tuple[int, int]]: ...
    def specht_module(self, base_ring: Ring | None = ...) -> SpechtModule: ...
    def specht_module_dimension(self, base_ring: Ring | None = ...) -> int: ...
