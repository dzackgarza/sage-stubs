from typing import Generic, TypeVar, overload
from collections.abc import Iterator, Iterable
from sage.structure.parent import Parent, ParentCallInput
from sage.sets.set import Set_object_enumerated, Set_object
from sage.rings.integer import Integer
from sage.structure.element import Element

_T = TypeVar('_T')
_SubsetElement = TypeVar("_SubsetElement")

def Subsets(s: Iterable[_T] | int | Integer | Set_object, k: int | Integer | None = None, submultiset: bool = False) -> Parent: ...

class Subsets_s(Parent, Generic[_T, _SubsetElement]):
    def __init__(self, s: Iterable[_T] | int | Set_object) -> None: ...
    def underlying_set(self) -> frozenset[_T] | tuple[_T, ...]: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __contains__(self, x: object) -> bool: ...
    def cardinality(self) -> int: ...
    def first(self) -> _SubsetElement: ...
    def last(self) -> _SubsetElement: ...
    def __iter__(self) -> Iterator[_SubsetElement]: ...
    def random_element(self) -> _SubsetElement: ...
    def rank(self, sub: Iterable[_T] | Set_object) -> int: ...
    def unrank(self, r: int) -> _SubsetElement: ...
    @overload
    def __call__(self, el: Iterable[_T] | Set_object) -> _SubsetElement: ...
    @overload
    def __call__(self, x: ParentCallInput = ..., *args: ParentCallInput, **kwds: ParentCallInput) -> Element | Parent: ...
    def lattice(self) -> Parent: ...

class Subsets_sk(Subsets_s[_T, Set_object_enumerated]):
    def __init__(self, s: Iterable[_T] | int | Set_object, k: int | Integer) -> None: ...
    def __contains__(self, x: object) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def cardinality(self) -> int: ...
    def first(self) -> Set_object_enumerated: ...
    def last(self) -> Set_object_enumerated: ...
    def __iter__(self) -> Iterator[Set_object_enumerated]: ...
    def random_element(self) -> Set_object_enumerated: ...
    def rank(self, sub: Iterable[_T] | Set_object) -> int: ...
    def unrank(self, r: int) -> Set_object_enumerated: ...

class SubsetsSorted(Subsets_s[_T, tuple[_T, ...]]):
    def __contains__(self, x: object) -> bool: ...
    def __iter__(self) -> Iterator[tuple[_T, ...]]: ...
    def first(self) -> tuple[_T, ...]: ...
    def last(self) -> tuple[_T, ...]: ...
    def random_element(self) -> tuple[_T, ...]: ...
    def unrank(self, r: int) -> tuple[_T, ...]: ...

class SubMultiset_s(Parent, Generic[_T]):
    def __init__(self, s: Iterable[_T]) -> None: ...
    def __contains__(self, x: object) -> bool: ...
    def cardinality(self) -> int: ...

class SubMultiset_sk(SubMultiset_s[_T]):
    def __init__(self, s: Iterable[_T], k: int | Integer) -> None: ...
    def __contains__(self, x: object) -> bool: ...
    def cardinality(self) -> int: ...
