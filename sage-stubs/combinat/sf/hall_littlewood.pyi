from collections.abc import Callable

from sage.combinat.partition import Partition
from sage.rings.ring import Ring
from sage.structure.parent import Parent
from sage.matrix.matrix import Matrix
class HallLittlewood:
    t: object
    _sym: object
    _name_suffix: str
    _name: str

    @staticmethod
    def __classcall__(cls: type[HallLittlewood], Sym: object, t: str | object = ...) -> HallLittlewood: ...
    def __init__(self, Sym: object, t: object) -> None: ...
    def symmetric_function_ring(self) -> Parent: ...
    def base_ring(self) -> Ring: ...
    def P(self) -> HallLittlewood_p: ...
    def Q(self) -> HallLittlewood_q: ...
    def Qp(self) -> HallLittlewood_qp: ...

class HallLittlewood_generic:
    t: object
    _sym: object
    _hall_littlewood: HallLittlewood
    _s: object
    _basis_name: str

    def __init__(self, hall_littlewood: HallLittlewood) -> None: ...
    def construction(self) -> tuple[object, Ring]: ...
    def _s_to_self(self, x: object) -> HallLittlewood_generic.Element: ...
    def _self_to_s(self, x: object) -> HallLittlewood_generic.Element: ...
    def transition_matrix(self, basis: object, n: int) -> Matrix: ...
    def product(self, left: object, right: object) -> HallLittlewood_generic.Element: ...
    def hall_littlewood_family(self) -> HallLittlewood: ...
    def base_ring(self) -> Ring: ...
    def basis_name(self) -> str: ...

    class Element:
        def expand(self, n: int, alphabet: str = 'x') -> Ring: ...
        def scalar(self, x: object, zee: Callable[[Partition], object] | None = None) -> Ring: ...
        def scalar_hl(self, x: object, t: object | None = None) -> Ring: ...

class HallLittlewood_p(HallLittlewood_generic):
    _self_to_s_cache: dict[object, object]
    _s_to_self_cache: dict[object, object]

    def __init__(self, hall_littlewood: HallLittlewood) -> None: ...
    def _q_to_p_normalization(self, m: Partition) -> Ring: ...
    def _s_to_self_base(self, part: Partition) -> Callable[[Partition], Ring]: ...
    def _s_cache(self, n: int) -> None: ...

    class Element(HallLittlewood_generic.Element):
        ...

class HallLittlewood_q(HallLittlewood_generic):
    _P: HallLittlewood_p

    def __init__(self, hall_littlewood: HallLittlewood) -> None: ...
    def _p_to_q_normalization(self, m: Partition) -> Ring: ...

    class Element(HallLittlewood_generic.Element):
        ...

class HallLittlewood_qp(HallLittlewood_generic):
    _self_to_s_cache: dict[object, object]
    _s_to_self_cache: dict[object, object]

    def __init__(self, hall_littlewood: HallLittlewood) -> None: ...
    def _to_s(self, part: Partition) -> Callable[[Partition], Ring]: ...
    def _s_cache(self, n: int) -> None: ...

    class Element(HallLittlewood_generic.Element):
        ...
