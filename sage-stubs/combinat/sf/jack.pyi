from collections.abc import Callable

from sage.combinat.partition import Partition
from sage.rings.ring import Ring
from sage.structure.parent import Parent
from sage.matrix.matrix import Matrix
class Jack:
    t: object
    _sym: object
    _name_suffix: str
    _name: str

    @staticmethod
    def __classcall__(cls: type[Jack], Sym: object, t: str | object = ...) -> Jack: ...
    def __init__(self, Sym: object, t: object) -> None: ...
    def base_ring(self) -> Ring: ...
    def symmetric_function_ring(self) -> Parent: ...
    def P(self) -> JackPolynomials_p: ...
    def Q(self) -> JackPolynomials_q: ...
    def J(self) -> JackPolynomials_j: ...
    def Qp(self) -> JackPolynomials_qp: ...

def c1(part: Partition, t: object) -> Ring: ...
def c2(part: Partition, t: object) -> Ring: ...
def normalize_coefficients(self: JackPolynomials_generic, c: object) -> Ring: ...
def part_scalar_jack(part1: Partition, part2: Partition, t: object) -> Ring: ...

class JackPolynomials_generic:
    t: object
    _sym: object
    _jack: Jack
    _m: object
    _h: object
    _P: JackPolynomials_p

    def __init__(self, jack: Jack) -> None: ...
    def construction(self) -> tuple[object, Ring]: ...
    def _m_to_self(self, x: object) -> JackPolynomials_generic.Element: ...
    def _self_to_m(self, x: object) -> JackPolynomials_generic.Element: ...
    def c1(self, part: Partition) -> Ring: ...
    def c2(self, part: Partition) -> Ring: ...
    def _normalize_coefficients(self, c: object) -> Ring: ...
    def _normalize(self, x: object) -> JackPolynomials_generic.Element: ...
    def _normalize_morphism(self, category: object) -> Parent: ...
    def product(self, left: object, right: object) -> JackPolynomials_generic.Element: ...
    def jack_family(self) -> Jack: ...
    def coproduct_by_coercion(self, elt: object) -> Parent: ...
    def base_ring(self) -> Ring: ...
    def basis_name(self) -> str: ...

    class Element:
        def scalar_jack(self, x: object, t: object | None = None) -> Ring: ...

class JackPolynomials_p(JackPolynomials_generic):
    _m_to_self_cache: dict[object, object]
    _self_to_m_cache: dict[object, object]

    def __init__(self, jack: Jack) -> None: ...
    def _m_cache(self, n: int) -> None: ...
    def _to_m(self, part: Partition) -> Callable[[Partition], Ring]: ...
    def product(self, left: object, right: object) -> JackPolynomials_p.Element: ...
    def scalar_jack_basis(self, part1: Partition, part2: Partition | None = None) -> Ring: ...

    class Element(JackPolynomials_generic.Element):
        def scalar_jack(self, x: object, t: object | None = None) -> Ring: ...

class JackPolynomials_j(JackPolynomials_generic):
    def __init__(self, jack: Jack) -> None: ...

    class Element(JackPolynomials_generic.Element):
        ...

class JackPolynomials_q(JackPolynomials_generic):
    def __init__(self, jack: Jack) -> None: ...

    class Element(JackPolynomials_generic.Element):
        ...

class JackPolynomials_qp(JackPolynomials_generic):
    _self_to_h_cache: dict[object, object]
    _h_to_self_cache: dict[object, object]

    def __init__(self, jack: Jack) -> None: ...
    def product(self, left: object, right: object) -> JackPolynomials_qp.Element: ...
    def _h_cache(self, n: int) -> None: ...
    def _self_to_h(self, x: object) -> JackPolynomials_qp.Element: ...
    def _h_to_self(self, x: object) -> JackPolynomials_qp.Element: ...
    def coproduct_by_coercion(self, elt: object) -> Parent: ...

    class Element(JackPolynomials_generic.Element):
        ...

class SymmetricFunctionAlgebra_zonal:
    _sym: object
    _jack: Jack
    _P: JackPolynomials_p

    def __init__(self, Sym: object) -> None: ...
    def product(self, left: object, right: object) -> SymmetricFunctionAlgebra_zonal.Element: ...

    class Element:
        def scalar_zonal(self, x: object) -> Ring: ...
