from __future__ import annotations
from typing import TYPE_CHECKING
from collections.abc import Callable

if TYPE_CHECKING:
    from sage.combinat.partition import Partition
    from sage.rings.ring import Ring
    from sage.structure.parent import Parent
    from sage.rings.commutative_ring_element import CommutativeRingElement

class Macdonald:
    q: CommutativeRingElement
    t: CommutativeRingElement
    _sym: object
    _s: object
    _name_suffix: str
    _name: str

    def __repr__(self) -> str: ...
    @staticmethod
    def __classcall__(cls, Sym: object, q: str | CommutativeRingElement = 'q', t: str | CommutativeRingElement = 't') -> Macdonald: ...
    def __init__(self, Sym: object, q: CommutativeRingElement, t: CommutativeRingElement) -> None: ...
    def base_ring(self) -> Ring: ...
    def symmetric_function_ring(self) -> Parent: ...
    def P(self) -> MacdonaldPolynomials_p: ...
    def Q(self) -> MacdonaldPolynomials_q: ...
    def J(self) -> MacdonaldPolynomials_j: ...
    def H(self) -> MacdonaldPolynomials_h: ...
    def Ht(self) -> MacdonaldPolynomials_ht: ...
    def S(self) -> MacdonaldPolynomials_s: ...

def c1(part: Partition, q: CommutativeRingElement, t: CommutativeRingElement) -> CommutativeRingElement: ...
def c2(part: Partition, q: CommutativeRingElement, t: CommutativeRingElement) -> CommutativeRingElement: ...
def cmunu1(mu: Partition, nu: Partition) -> CommutativeRingElement: ...
def cmunu(mu: Partition, nu: Partition) -> CommutativeRingElement: ...

class MacdonaldPolynomials_generic:
    q: CommutativeRingElement
    t: CommutativeRingElement
    _macdonald: Macdonald
    _s: object

    def __init__(self, macdonald: Macdonald) -> None: ...
    def construction(self) -> tuple[object, Ring]: ...
    def _s_to_self(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _self_to_s(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def c1(self, part: Partition) -> CommutativeRingElement: ...
    def c2(self, part: Partition) -> CommutativeRingElement: ...
    def product(self, left: object, right: object) -> MacdonaldPolynomials_generic.Element: ...
    def macdonald_family(self) -> Macdonald: ...
    def base_ring(self) -> Ring: ...

    class Element:
        def nabla(self, q: CommutativeRingElement | None = None, t: CommutativeRingElement | None = None, power: int = 1) -> MacdonaldPolynomials_generic.Element: ...

class MacdonaldPolynomials_p(MacdonaldPolynomials_generic):
    _J: MacdonaldPolynomials_j

    def __init__(self, macdonald: Macdonald) -> None: ...
    def scalar_qt_basis(self, part1: Partition, part2: Partition | None = None) -> CommutativeRingElement: ...

    class Element(MacdonaldPolynomials_generic.Element):
        pass

class MacdonaldPolynomials_q(MacdonaldPolynomials_generic):
    _J: MacdonaldPolynomials_j
    _P: MacdonaldPolynomials_p

    def __init__(self, macdonald: Macdonald) -> None: ...

    class Element(MacdonaldPolynomials_generic.Element):
        pass

class MacdonaldPolynomials_j(MacdonaldPolynomials_generic):
    _self_to_s_cache: dict[object, object]
    _s_to_self_cache: dict[object, object]

    def __init__(self, macdonald: Macdonald) -> None: ...
    def _s_cache(self, n: int) -> None: ...
    def _to_s(self, part: Partition) -> Callable[[Partition], CommutativeRingElement]: ...

    class Element(MacdonaldPolynomials_generic.Element):
        pass

class MacdonaldPolynomials_h(MacdonaldPolynomials_generic):
    _m: object
    _Lmunu: Callable[[Partition, Partition], CommutativeRingElement]
    _Qp: object

    def __init__(self, macdonald: Macdonald) -> None: ...
    def _self_to_s(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _s_to_self(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _self_to_m(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _m_to_self(self, f: object) -> MacdonaldPolynomials_generic.Element: ...

    class Element(MacdonaldPolynomials_generic.Element):
        pass

class MacdonaldPolynomials_ht(MacdonaldPolynomials_generic):
    _self_to_m_cache: dict[tuple[Partition, Partition], CommutativeRingElement]
    _m: object

    def __init__(self, macdonald: Macdonald) -> None: ...
    def _self_to_s(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _s_to_self(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _Lmunu(self, nu: Partition, mu: Partition) -> CommutativeRingElement: ...
    def _self_to_m(self, x: object) -> MacdonaldPolynomials_generic.Element: ...
    def _m_to_self(self, f: object) -> MacdonaldPolynomials_generic.Element: ...

    class Element(MacdonaldPolynomials_generic.Element):
        pass

class MacdonaldPolynomials_s(MacdonaldPolynomials_generic):
    class Element(MacdonaldPolynomials_generic.Element):
        pass
