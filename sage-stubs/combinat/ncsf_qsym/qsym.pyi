from sage.rings.ring import Ring
from sage.structure.unique_representation import UniqueRepresentation
from sage.combinat.ncsf_qsym.ncsf import NonCommutativeSymmetricFunctions
from sage.combinat.free_module import CombinatorialFreeModule

class QuasiSymmetricFunctions(UniqueRepresentation):
    def __init__(self, R: Ring) -> None: ...
    def base_ring(self) -> Ring: ...
    def M(self) -> QuasiSymmetricFunctions.Monomial: ...
    def a_realization(self) -> QuasiSymmetricFunctions.Monomial: ...
    def dual(self) -> NonCommutativeSymmetricFunctions: ...
    def from_polynomial(self, f: object, check: bool = ...) -> QuasiSymmetricFunctions.Monomial: ...

    class Monomial:
        class Element(CombinatorialFreeModule.Element): ...
