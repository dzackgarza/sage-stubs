from sage.rings.ring import Ring
from sage.structure.unique_representation import UniqueRepresentation
from sage.combinat.ncsf_qsym.qsym import QuasiSymmetricFunctions

class NonCommutativeSymmetricFunctions(UniqueRepresentation):
    def __init__(self, R: Ring) -> None: ...
    def base_ring(self) -> Ring: ...
    def S(self) -> NonCommutativeSymmetricFunctions.Complete: ...
    def R(self) -> NonCommutativeSymmetricFunctions.Ribbon: ...
    def a_realization(self) -> NonCommutativeSymmetricFunctions.Complete: ...
    def dual(self) -> QuasiSymmetricFunctions: ...

    class Ribbon: ...
    class Complete: ...
