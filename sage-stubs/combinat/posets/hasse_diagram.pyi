from collections.abc import Callable, Iterable, Iterator
from typing import Protocol

from sage.combinat.posets.posets import FinitePoset
from sage.combinat.set_partition import SetPartition
from sage.graphs.digraph import DiGraph
from sage.matrix.matrix import Matrix
from sage.rings.integer import Integer
from sage.rings.polynomial.polynomial_element import Polynomial


class _DisjointSet(Protocol):
    def copy(self) -> _DisjointSet: ...
    def find(self, x: int) -> int: ...
    def union(self, x: int, y: int) -> None: ...
    def number_of_subsets(self) -> int: ...
    def root_to_elements_dict(self) -> dict[int, set[int]]: ...


class _FiniteEnumeratedIntCollection(Protocol):
    def __iter__(self) -> Iterator[list[int]]: ...
    def cardinality(self) -> int: ...


class LatticeError(ValueError):
    fail: str
    x: int
    y: int

    def __init__(self, fail: str, x: int, y: int) -> None: ...


class HasseDiagram(DiGraph):
    def _repr_(self) -> str: ...
    def linear_extension(self) -> list[int]: ...
    def linear_extensions(self) -> Iterator[list[int]]: ...
    def greedy_linear_extensions_iterator(self) -> Iterator[list[int]]: ...
    def supergreedy_linear_extensions_iterator(self) -> Iterator[list[int]]: ...
    def is_linear_extension(self, lin_ext: list[int] | None = ...) -> bool: ...
    def cover_relations_iterator(self) -> Iterator[tuple[int, int]]: ...
    def cover_relations(self) -> list[tuple[int, int]]: ...
    def is_lequal(self, i: int, j: int) -> bool: ...
    def is_less_than(self, x: int, y: int) -> bool: ...
    def is_gequal(self, x: int, y: int) -> bool: ...
    def is_greater_than(self, x: int, y: int) -> bool: ...
    def minimal_elements(self) -> list[int]: ...
    def maximal_elements(self) -> list[int]: ...
    def bottom(self) -> int | None: ...
    def has_bottom(self) -> bool: ...
    def top(self) -> int | None: ...
    def has_top(self) -> bool: ...
    def is_bounded(self) -> bool: ...
    def is_chain(self) -> bool: ...
    def is_antichain_of_poset(self, elms: Iterable[int]) -> bool: ...
    def dual(self) -> HasseDiagram: ...
    def _precompute_intervals(self) -> None: ...
    def interval(self, x: int, y: int) -> list[int]: ...
    def interval_iterator(self, x: int, y: int) -> Iterator[int]: ...
    def open_interval(self, x: int, y: int) -> list[int]: ...
    def rank_function(self) -> Callable[[int], int] | None: ...
    def _rank(self) -> list[int] | None: ...
    def rank(self, element: int | None = ...) -> int: ...
    def is_ranked(self) -> bool: ...
    def covers(self, x: int, y: int) -> bool: ...
    def upper_covers_iterator(self, element: int) -> Iterator[int]: ...
    def lower_covers_iterator(self, element: int) -> Iterator[int]: ...
    def cardinality(self) -> int: ...
    def moebius_function(self, i: int, j: int) -> Integer: ...
    def bottom_moebius_function(self, j: int) -> Integer: ...
    def moebius_function_matrix(self, algorithm: str = ...) -> Matrix: ...
    def _moebius_function_from_matrix(self, i: int, j: int) -> Integer: ...
    def coxeter_transformation(self, algorithm: str = ...) -> Matrix: ...
    def order_filter(self, elements: Iterable[int]) -> list[int]: ...
    def principal_order_filter(self, i: int) -> list[int]: ...
    def order_ideal(self, elements: Iterable[int]) -> list[int]: ...
    def order_ideal_cardinality(self, elements: Iterable[int]) -> Integer: ...
    def principal_order_ideal(self, i: int) -> list[int]: ...
    def _leq_storage(self) -> list[set[int]]: ...
    def _leq_matrix_boolean(self) -> Matrix: ...
    def _leq_matrix(self) -> Matrix: ...
    def lequal_matrix(self, boolean: bool = ...) -> Matrix: ...
    def prime_elements(self) -> tuple[list[int], list[int]]: ...
    def _meet(self) -> Matrix: ...
    def meet_matrix(self) -> Matrix: ...
    def is_meet_semilattice(self) -> bool: ...
    def _join(self) -> Matrix: ...
    def join_matrix(self) -> Matrix: ...
    def is_join_semilattice(self) -> bool: ...
    def find_nonsemidistributive_elements(
        self, meet_or_join: str
    ) -> tuple[int, int, int, int] | None: ...
    def vertical_decomposition(self, return_list: bool = ...) -> int | list[int] | None: ...
    def is_complemented(self) -> int | None: ...
    def pseudocomplement(self, element: int) -> int | None: ...
    def orthocomplementations_iterator(self) -> Iterator[list[int]]: ...
    def find_nonsemimodular_pair(self, upper: bool) -> tuple[int, int] | None: ...
    def antichains_iterator(self) -> Iterator[list[int]]: ...
    def are_incomparable(self, i: int, j: int) -> bool: ...
    def are_comparable(self, i: int, j: int) -> bool: ...
    def antichains(self, element_class: type = ...) -> _FiniteEnumeratedIntCollection: ...
    def chains(
        self,
        element_class: type = ...,
        exclude: Iterable[int] | None = ...,
        conversion: Iterable[int] | None = ...,
    ) -> _FiniteEnumeratedIntCollection: ...
    def chain_polynomial(self) -> Polynomial: ...
    def linear_intervals_count(self) -> Iterator[int]: ...
    def is_linear_interval(self, t_min: int, t_max: int) -> bool: ...
    def diamonds(self) -> tuple[list[tuple[int, int, int, int]], bool]: ...
    def common_upper_covers(self, vertices: list[int]) -> list[int]: ...
    def common_lower_covers(self, vertices: list[int]) -> list[int]: ...
    def _trivial_nonregular_congruence(self) -> tuple[int, int] | None: ...
    def sublattices_iterator(self, elms: set[int], min_e: int) -> Iterator[set[int]]: ...
    def maximal_sublattices(self) -> list[set[int]]: ...
    def frattini_sublattice(self) -> list[int]: ...
    def kappa_dual(self, a: int) -> int | None: ...
    def skeleton(self) -> list[int]: ...
    def spine(self) -> tuple[set[int], int]: ...
    def is_convex_subset(self, S: Iterable[int]) -> bool: ...
    def neutral_elements(self) -> set[int]: ...
    def kappa(self, a: int) -> int | None: ...
    def atoms_of_congruence_lattice(self) -> list[SetPartition]: ...
    def congruence(
        self,
        parts: list[list[int]],
        start: _DisjointSet | None = ...,
        stop_pairs: list[tuple[int, int]] | None = ...,
    ) -> _DisjointSet: ...
    def find_nontrivial_congruence(self) -> _DisjointSet | None: ...
    def principal_congruences_poset(self) -> tuple[FinitePoset, dict[tuple[int, int], _DisjointSet]]: ...
    def congruences_iterator(self) -> Iterator[_DisjointSet]: ...
    def is_congruence_normal(self) -> bool: ...
    @staticmethod
    def _glue_spectra(a_spec: list[int], b_spec: list[int], orientation: bool) -> list[int]: ...
    def _split(self, a: int, b: int) -> list[HasseDiagram]: ...
    def _spectrum_of_tree(self, a: int) -> list[int]: ...
