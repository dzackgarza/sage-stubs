from collections.abc import Callable, Hashable, Iterable, Mapping, Sequence
from typing import Literal, TypeAlias, overload

from sage.categories.category import Category
from sage.combinat.posets.linear_extensions import LinearExtensionOfPoset
from sage.graphs.digraph import DiGraph
from sage.rings.integer import Integer
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.topology.simplicial_complex import SimplicialComplex

_PosetElement: TypeAlias = Element | Hashable
_PosetRelation: TypeAlias = tuple[_PosetElement, _PosetElement]
_PosetData: TypeAlias = (
    DiGraph
    | Mapping[_PosetElement, Iterable[_PosetElement]]
    | Iterable[Iterable[_PosetElement]]
    | tuple[Iterable[_PosetElement], Iterable[_PosetRelation]]
    | tuple[Iterable[_PosetElement], Callable[[_PosetElement, _PosetElement], bool]]
)

def Poset(
    data: _PosetData | FinitePoset | None = ...,
    element_labels: Sequence[_PosetElement] | Mapping[_PosetElement, _PosetElement] | None = ...,
    cover_relations: bool = ...,
    linear_extension: bool = ...,
    category: Category | None = ...,
    facade: bool | None = ...,
    key: Callable[..., Hashable] | None = ...,
) -> FinitePoset: ...

class FinitePoset(Parent):
    def cover_relations(self) -> list[_PosetRelation]: ...
    def linear_extensions(self, facade: bool | None = ...) -> list[LinearExtensionOfPoset]: ...
    def is_graded(self) -> bool: ...
    def rank_function(self) -> Callable[..., int] | None: ...
    def rank(self, element: _PosetElement | None = ...) -> int: ...
    def is_lattice(self) -> bool: ...
    def is_distributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    @overload
    def is_meet_semilattice(self, certificate: Literal[False] = ...) -> bool: ...
    @overload
    def is_meet_semilattice(self, certificate: Literal[True]) -> tuple[bool, _PosetRelation | None]: ...
    @overload
    def is_meet_semilattice(self, certificate: bool = ...) -> bool | tuple[bool, _PosetRelation | None]: ...
    @overload
    def is_join_semilattice(self, certificate: Literal[False] = ...) -> bool: ...
    @overload
    def is_join_semilattice(self, certificate: Literal[True]) -> tuple[bool, _PosetRelation | None]: ...
    @overload
    def is_join_semilattice(self, certificate: bool = ...) -> bool | tuple[bool, _PosetRelation | None]: ...
    def is_connected(self) -> bool: ...
    @overload
    def height(self, certificate: Literal[False] = ...) -> int: ...
    @overload
    def height(self, certificate: Literal[True]) -> tuple[int, list[_PosetElement]]: ...
    @overload
    def height(self, certificate: bool = ...) -> int | tuple[int, list[_PosetElement]]: ...
    @overload
    def width(self, certificate: Literal[False] = ...) -> Integer: ...
    @overload
    def width(self, certificate: Literal[True]) -> tuple[Integer, list[_PosetElement]]: ...
    @overload
    def width(self, certificate: bool = ...) -> Integer | tuple[Integer, list[_PosetElement]]: ...
    def cardinality(self) -> int: ...
    def hasse_diagram(self) -> DiGraph: ...
    def minimal_elements(self) -> list[_PosetElement]: ...
    def maximal_elements(self) -> list[_PosetElement]: ...
    def order_complex(self, on_ints: bool = False) -> SimplicialComplex: ...
    def zeta_polynomial(self) -> Polynomial: ...
    def moebius_function(self, x: _PosetElement, y: _PosetElement) -> int: ...
