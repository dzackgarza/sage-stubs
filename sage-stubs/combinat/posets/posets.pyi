from collections.abc import Callable

from sage.categories.category import Category
from sage.combinat.posets.linear_extensions import LinearExtensionOfPoset
from sage.graphs.digraph import DiGraph
from sage.rings.polynomial.polynomial_element import Polynomial
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.topology.simplicial_complex import SimplicialComplex

def Poset(
    data: object | None = ...,
    element_labels: object | None = ...,
    cover_relations: bool = ...,
    linear_extension: bool = ...,
    category: Category | None = ...,
    facade: bool | None = ...,
    key: Callable[[object], object] | None = ...,
) -> FinitePoset: ...

class FinitePoset(Parent):
    def cover_relations(self) -> list[tuple[object, object]]: ...
    def linear_extensions(self, facade: object = ...) -> list[LinearExtensionOfPoset]: ...
    def is_graded(self) -> bool: ...
    def rank_function(self) -> Callable[..., int] | None: ...
    def rank(self, element: object | None = ...) -> int: ...
    def is_lattice(self) -> bool: ...
    def is_distributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_connected(self) -> bool: ...
    def height(self) -> int: ...
    def width(self) -> int: ...
    def cardinality(self) -> int: ...
    def hasse_diagram(self) -> DiGraph: ...
    def minimal_elements(self) -> list[object]: ...
    def maximal_elements(self) -> list[object]: ...
    def order_complex(self, on_ints: bool = False) -> SimplicialComplex: ...
    def zeta_polynomial(self) -> Polynomial: ...
    def moebius_function(self, x: object, y: object) -> int: ...
