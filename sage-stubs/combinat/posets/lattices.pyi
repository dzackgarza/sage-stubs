from collections.abc import Iterator

from sage.combinat.posets.posets import FinitePoset
from sage.matrix.matrix import Matrix
from sage.structure.element import Element
from sage.structure.parent import Parent

def MeetSemilattice(data: object | None = ..., *args: object, **options: object) -> FiniteMeetSemilattice: ...

class FiniteMeetSemilattice(FinitePoset):
    def meet_matrix(self) -> Matrix: ...
    def meet(self, x: object, y: object | None = ...) -> Element: ...
    def atoms(self) -> list[Element]: ...
    def submeetsemilattice(self, elms: list[object], **kwds: object) -> FiniteMeetSemilattice: ...
    def subjoinsemilattice(self, elms: list[object], **kwds: object) -> FiniteJoinSemilattice: ...
    def pseudocomplement(self, element: object) -> Element | None: ...

class FiniteJoinSemilattice(FinitePoset):
    def join_matrix(self) -> Matrix: ...
    def join(self, x: object, y: object | None = ...) -> Element: ...
    def coatoms(self) -> list[Element]: ...

class FiniteLatticePoset(FiniteMeetSemilattice, FiniteJoinSemilattice):
    def double_irreducibles(self) -> list[Element]: ...
    def join_primes(self) -> list[Element]: ...
    def meet_primes(self) -> list[Element]: ...
    def neutral_elements(self) -> list[Element]: ...
    def is_join_distributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_meet_distributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_stone(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_distributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_semidistributive(self) -> bool: ...
    def is_meet_semidistributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_join_semidistributive(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_extremal(self) -> bool: ...
    def is_trim(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_left_modular(self, H: object | None = ..., certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_complemented(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_cosectionally_complemented(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_relatively_complemented(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_sectionally_complemented(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def breadth(self, certificate: bool = ...) -> int | tuple[int, Element]: ...
    def complements(self, element: object | None = ...) -> list[Element]: ...
    def is_pseudocomplemented(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_join_pseudocomplemented(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def skeleton(self) -> FinitePoset: ...
    def is_orthocomplemented(self, unique: bool = ...) -> bool: ...
    def is_atomic(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_coatomic(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_geometric(self) -> bool: ...
    def is_planar(self) -> bool: ...
    def is_modular(self, L: object | None = ..., certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_modular_element(self, x: object) -> bool: ...
    def is_left_modular_element(self, x: object) -> bool: ...
    def is_upper_semimodular(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_lower_semimodular(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_supersolvable(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def vertical_composition(self, other: FiniteLatticePoset, labels: str = ...) -> FiniteLatticePoset: ...
    def vertical_decomposition(self, elements_only: bool = ...) -> list[FiniteLatticePoset]: ...
    def is_vertically_decomposable(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def sublattice(self, elms: list[object], **kwds: object) -> FiniteLatticePoset: ...
    def is_sublattice(self, other: FiniteLatticePoset) -> bool: ...
    def sublattices(self) -> Iterator[FiniteLatticePoset]: ...
    def sublattices_lattice(self, labels: str = ...) -> FiniteLatticePoset: ...
    def isomorphic_sublattices_iterator(self, other: FiniteLatticePoset) -> Iterator[FiniteLatticePoset]: ...
    def maximal_sublattices(self) -> list[FiniteLatticePoset]: ...
    def frattini_sublattice(self) -> FiniteLatticePoset: ...
    def moebius_algebra(self, R: object) -> Parent: ...
    def quantum_moebius_algebra(self, q: object | None = ...) -> Parent: ...
    def day_doubling(self, S: object) -> FiniteLatticePoset: ...
    def adjunct(self, other: FiniteLatticePoset, a: object, b: object) -> FiniteLatticePoset: ...
    def center(self) -> list[Element]: ...
    def is_dismantlable(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_interval_dismantlable(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_sublattice_dismantlable(self) -> bool: ...
    def is_subdirectly_reducible(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def canonical_meetands(self, e: object) -> list[Element]: ...
    def canonical_joinands(self, e: object) -> list[Element]: ...
    def is_constructible_by_doublings(self, type: str) -> bool: ...
    def is_congruence_uniform(self) -> bool: ...
    def is_isoform(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_uniform(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_regular(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...
    def is_simple(self, certificate: bool = ...) -> bool | tuple[bool, Element]: ...

def JoinSemilattice(data: object | None = ..., *args: object, **options: object) -> FiniteJoinSemilattice: ...
def LatticePoset(data: object | None = ..., *args: object, **options: object) -> FiniteLatticePoset: ...
