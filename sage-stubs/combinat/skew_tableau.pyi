from sage.structure.list_clone import ClonableList
from sage.structure.parent import Parent
from sage.structure.unique_representation import UniqueRepresentation
from typing import TYPE_CHECKING, overload

if TYPE_CHECKING:
    import sage.combinat.partition
    import sage.combinat.skew_partition
    import sage.combinat.words.word
    import sage.combinat.permutation
    import sage.combinat.tableau

class SkewTableau(ClonableList):
    def check(self) -> None: ...
    def outer_shape(self) -> sage.combinat.partition.Partition: ...
    def inner_shape(self) -> sage.combinat.partition.Partition: ...
    def shape(self) -> sage.combinat.skew_partition.SkewPartition: ...
    def outer_size(self) -> int: ...
    def inner_size(self) -> int: ...
    def size(self) -> int: ...
    def conjugate(self) -> SkewTableau: ...
    def to_word_by_row(self) -> sage.combinat.words.word.Word_class: ...
    def to_word_by_column(self) -> sage.combinat.words.word.Word_class: ...
    def to_word(self) -> sage.combinat.words.word.Word_class: ...
    def to_permutation(self) -> sage.combinat.permutation.Permutation: ...
    def weight(self) -> list[int]: ...
    def evaluation(self) -> list[int]: ...
    def is_standard(self) -> bool: ...
    def is_semistandard(self) -> bool: ...
    def to_tableau(self) -> sage.combinat.tableau.Tableau: ...
    def pp(self) -> None: ...
    def to_list(self) -> list[list[int | None]]: ...
    def to_chain(self, max_entry: int | None = ...) -> list[sage.combinat.partition.Partition]: ...
    def slide(self, corner: tuple[int, int] | None = ..., return_vacated: bool = ...) -> SkewTableau | tuple[SkewTableau, tuple[int, int]]: ...
    def backward_slide(self, corner: tuple[int, int] | None = ...) -> SkewTableau: ...
    def reverse_slide(self, corner: tuple[int, int] | None = ...) -> SkewTableau: ...
    def rectify(self, algorithm: str | None = ...) -> sage.combinat.tableau.Tableau | sage.combinat.tableau.StandardTableau | sage.combinat.tableau.SemistandardTableau: ...
    def add_entry(self, cell: tuple[int, int], m: int) -> SkewTableau: ...
    def anti_restrict(self, n: int) -> SkewTableau: ...
    def restriction_outer_shape(self, n: int) -> sage.combinat.partition.Partition: ...

class SkewTableaux(UniqueRepresentation, Parent):
    Element: type[SkewTableau]
    def _element_constructor_(self, st: object) -> SkewTableau: ...
    def __contains__(self, x: object) -> bool: ...
    def from_expr(self, expr: list[object]) -> SkewTableau: ...
    def from_chain(self, chain: list[sage.combinat.partition.Partition]) -> SkewTableau: ...
    def from_shape_and_word(self, shape: sage.combinat.skew_partition.SkewPartition, word: list[int]) -> SkewTableau: ...

class StandardSkewTableaux(SkewTableaux):
    @staticmethod
    def __classcall_private__(cls, skp: object = ...) -> StandardSkewTableaux_all | StandardSkewTableaux_size | StandardSkewTableaux_shape: ...
    def __contains__(self, x: object) -> bool: ...

class StandardSkewTableaux_all(StandardSkewTableaux):
    def _repr_(self) -> str: ...
    def __iter__(self): ...

class StandardSkewTableaux_size(StandardSkewTableaux):
    def _repr_(self) -> str: ...
    def cardinality(self) -> int: ...

class StandardSkewTableaux_shape(StandardSkewTableaux):
    def _repr_(self) -> str: ...
    def cardinality(self) -> int: ...

class SemistandardSkewTableaux(SkewTableaux):
    @staticmethod
    def __classcall_private__(cls, skp: object = ..., max_entry: int | None = ...) -> SemistandardSkewTableaux_all | SemistandardSkewTableaux_size | SemistandardSkewTableaux_shape: ...
    def __contains__(self, x: object) -> bool: ...

class SemistandardSkewTableaux_all(SemistandardSkewTableaux):
    def _repr_(self) -> str: ...
    def __iter__(self): ...

class SemistandardSkewTableaux_size(SemistandardSkewTableaux):
    def _repr_(self) -> str: ...

class SemistandardSkewTableaux_shape(SemistandardSkewTableaux):
    def _repr_(self) -> str: ...
    def cardinality(self) -> int: ...
