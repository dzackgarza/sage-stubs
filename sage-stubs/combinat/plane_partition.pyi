from collections.abc import Iterator, Sequence
from typing import TypeAlias

from sage.categories.category import Category
from sage.combinat.posets.posets import FinitePoset
from sage.combinat.tableau import Tableau
from sage.plot.graphics import Graphics
from sage.plot.plot3d.base import Graphics3d
from sage.rings.integer import Integer
from sage.structure.list_clone import ClonableArray
from sage.structure.parent import Parent
from sage.structure.unique_representation import UniqueRepresentation
from sage.typeset.ascii_art import AsciiArt
from sage.typeset.unicode_art import UnicodeArt

_PlanePartitionRows: TypeAlias = Sequence[Sequence[int | Integer]]
_PlanePartitionRow: TypeAlias = tuple[int | Integer, ...]
_BoxSize: TypeAlias = tuple[int, int, int]
_Cell: TypeAlias = tuple[int, int, int]
_TableauRows: TypeAlias = list[list[int | Integer]]

class PlanePartition(ClonableArray[_PlanePartitionRow]):
    

    def __init__(self, parent: PlanePartitions, pp: PlanePartition | _PlanePartitionRows, check: bool = ...) -> None: ...
    def check(self) -> None: ...
    def _repr_(self) -> str: ...
    def to_tableau(self) -> Tableau: ...
    def z_tableau(self, tableau: bool = ...) -> Tableau | _TableauRows: ...
    def y_tableau(self, tableau: bool = ...) -> Tableau | _TableauRows: ...
    def x_tableau(self, tableau: bool = ...) -> Tableau | _TableauRows: ...
    def cells(self) -> list[tuple[int, int, int]]: ...
    def number_of_boxes(self) -> Integer: ...
    def _repr_diagram(self, show_box: bool = ..., use_unicode: bool = ...) -> str: ...
    def _ascii_art_(self) -> AsciiArt: ...
    def _unicode_art_(self) -> UnicodeArt: ...
    def pp(self, show_box: bool = ...) -> None: ...
    def _repr_svg_(self) -> str: ...
    def _latex_(
        self, show_box: bool = ..., colors: list[str] | None = None
    ) -> str: ...
    def plot(self, show_box: bool = ..., colors: list[str] | None = None) -> Graphics: ...
    def contains(self, PP: PlanePartition | _PlanePartitionRows) -> bool: ...
    def plot3d(self, colors: list[str] | None = None) -> Graphics3d: ...
    def complement(self, tableau_only: bool = ...) -> PlanePartition | _TableauRows: ...
    def transpose(self, tableau_only: bool = ...) -> PlanePartition | _TableauRows: ...
    def is_SPP(self) -> bool: ...
    def is_CSPP(self) -> bool: ...
    def is_TSPP(self) -> bool: ...
    def is_SCPP(self) -> bool: ...
    def is_TCPP(self) -> bool: ...
    def is_SSCPP(self) -> bool: ...
    def is_CSTCPP(self) -> bool: ...
    def is_CSSCPP(self) -> bool: ...
    def is_TSSCPP(self) -> bool: ...
    def to_order_ideal(self) -> list[_Cell]: ...
    def maximal_boxes(self) -> list[list[int | Integer]]: ...
    def cyclically_rotate(self, preserve_parent: bool = ...) -> PlanePartition: ...
    def bounding_box(self) -> _BoxSize: ...

class PlanePartitions(UniqueRepresentation, Parent):
    
    Element: type[PlanePartition]
    element_class: type[PlanePartition]

    def __init__(
        self, box_size: _BoxSize | None = None, symmetry: str | None = None, category: Category | None = None
    ) -> None: ...
    def __contains__(self, pp: PlanePartition | _PlanePartitionRows) -> bool: ...
    def box(self) -> _BoxSize | None: ...
    def symmetry(self) -> str | None: ...

class PlanePartitions_all(PlanePartitions):
    

    def __init__(self) -> None: ...
    def _repr_(self) -> str: ...
    def an_element(self) -> PlanePartition: ...

class PlanePartitions_box(PlanePartitions):
    

    def __init__(self, box_size: _BoxSize) -> None: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def to_poset(self) -> FinitePoset: ...
    def from_order_ideal(self, I: list[_Cell]) -> PlanePartition: ...
    def from_antichain(self, A: list[_Cell]) -> PlanePartition: ...
    def __iter__(self) -> Iterator[PlanePartition]: ...
    def cardinality(self) -> Integer: ...
    def random_element(self) -> PlanePartition: ...

class PlanePartitions_n(PlanePartitions):
    

    def __init__(self, n: int) -> None: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def __iter__(self) -> Iterator[PlanePartition]: ...
    def cardinality(self) -> Integer: ...

class PlanePartitions_SPP(PlanePartitions):
    ...

class PlanePartitions_CSPP(PlanePartitions):
    ...

class PlanePartitions_TSPP(PlanePartitions):
    ...

class PlanePartitions_SCPP(PlanePartitions):
    ...

class PlanePartitions_TCPP(PlanePartitions):
    ...

class PlanePartitions_SSCPP(PlanePartitions):
    ...

class PlanePartitions_CSTCPP(PlanePartitions):
    ...

class PlanePartitions_CSSCPP(PlanePartitions):
    ...

class PlanePartitions_TSSCPP(PlanePartitions):
    ...
