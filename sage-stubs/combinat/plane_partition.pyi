from typing import TYPE_CHECKING, NewType
from sage.structure.list_clone import ClonableArray
from sage.structure.parent import Parent
from sage.structure.unique_representation import UniqueRepresentation
from sage.rings.integer import Integer
from sage.combinat.tableau import Tableau

if TYPE_CHECKING:
    from collections.abc import Iterator

PP = NewType('PP', 'PlanePartition')

class PlanePartition(ClonableArray):
    """A plane partition."""

    def __init__(self, parent, pp: list | tuple, check: bool = ...) -> None: ...
    def check(self) -> None: ...
    def _repr_(self) -> str: ...
    def to_tableau(self) -> Tableau: ...
    def z_tableau(self, tableau: bool = ...) -> Tableau | list: ...
    def y_tableau(self, tableau: bool = ...) -> Tableau | list: ...
    def x_tableau(self, tableau: bool = ...) -> Tableau | list: ...
    def cells(self) -> list[tuple[int, int, int]]: ...
    def number_of_boxes(self) -> Integer: ...
    def _repr_diagram(self, show_box: bool = ..., use_unicode: bool = ...) -> str: ...
    def _ascii_art_(self): ...
    def _unicode_art_(self): ...
    def pp(self, show_box: bool = ...) -> None: ...
    def _repr_svg_(self) -> str: ...
    def _latex_(
        self, show_box: bool = ..., colors: list[str] | None = None
    ) -> str: ...
    def plot(self, show_box: bool = ..., colors: list[str] | None = None): ...
    def contains(self, PP: 'PlanePartition' | list) -> bool: ...
    def plot3d(self, colors: list[str] | None = None): ...
    def complement(self, tableau_only: bool = ...) -> PP | list: ...
    def transpose(self, tableau_only: bool = ...) -> PP | list: ...
    def is_SPP(self) -> bool: ...
    def is_CSPP(self) -> bool: ...
    def is_TSPP(self) -> bool: ...
    def is_SCPP(self) -> bool: ...
    def is_TCPP(self) -> bool: ...
    def is_SSCPP(self) -> bool: ...
    def is_CSTCPP(self) -> bool: ...
    def is_CSSCPP(self) -> bool: ...
    def is_TSSCPP(self) -> bool: ...
    def to_order_ideal(self): ...
    def maximal_boxes(self) -> list: ...
    def cyclically_rotate(self, preserve_parent: bool = ...) -> PP: ...
    def bounding_box(self) -> tuple[int, int, int]: ...

class PlanePartitions(UniqueRepresentation, Parent):
    """Plane partitions."""

    def __init__(
        self, box_size: tuple[int, int, int] | None = None, symmetry: str | None = None, category=None
    ) -> None: ...
    def __contains__(self, pp: 'PlanePartition' | list | tuple) -> bool: ...
    def box(self) -> tuple[int, int, int] | None: ...
    def symmetry(self) -> str | None: ...
    def element_class(self, *args, **kwargs) -> PlanePartition: ...

class PlanePartitions_all(PlanePartitions):
    """All plane partitions."""

    def __init__(self) -> None: ...
    def _repr_(self) -> str: ...
    def an_element(self) -> PlanePartition: ...

class PlanePartitions_box(PlanePartitions):
    """All plane partitions that fit inside a box of a specified size."""

    def __init__(self, box_size: tuple[int, int, int]) -> None: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def to_poset(self): ...
    def from_order_ideal(self, I: list) -> PP: ...
    def from_antichain(self, A: list) -> PP: ...
    def __iter__(self) -> 'Iterator[PlanePartition]': ...
    def cardinality(self) -> Integer: ...
    def random_element(self) -> PP: ...

class PlanePartitions_n(PlanePartitions):
    """Plane partitions with a fixed number of boxes."""

    def __init__(self, n: int) -> None: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def __iter__(self) -> 'Iterator[PlanePartition]': ...
    def cardinality(self) -> Integer: ...

class PlanePartitions_SPP(PlanePartitions):
    """Symmetric plane partitions."""
    pass

class PlanePartitions_CSPP(PlanePartitions):
    """Cyclically symmetric plane partitions."""
    pass

class PlanePartitions_TSPP(PlanePartitions):
    """Totally symmetric plane partitions."""
    pass

class PlanePartitions_SCPP(PlanePartitions):
    """Self-complementary plane partitions."""
    pass

class PlanePartitions_TCPP(PlanePartitions):
    """Transpose-complementary plane partitions."""
    pass

class PlanePartitions_SSCPP(PlanePartitions):
    """Symmetric self-complementary plane partitions."""
    pass

class PlanePartitions_CSTCPP(PlanePartitions):
    """Cyclically symmetric transpose-complementary plane partitions."""
    pass

class PlanePartitions_CSSCPP(PlanePartitions):
    """Cyclically symmetric self-complementary plane partitions."""
    pass

class PlanePartitions_TSSCPP(PlanePartitions):
    """Totally symmetric self-complementary plane partitions."""
    pass
