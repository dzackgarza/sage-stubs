from typing import overload, TypeVar
from collections.abc import Iterator, Callable

from sage.structure.unique_representation import UniqueRepresentation
from sage.structure.parent import Parent
from sage.combinat.combinat import CombinatorialElement
from sage.combinat.dyck_word import DyckWord
from sage.combinat.ordered_tree import OrderedTree
from sage.structure.element import Element

class Graph: ...
class LabelledBinaryTree: ...
class TamariIntervalPoset: ...
class Permutation: ...
class Poset: ...


class BinaryTree(CombinatorialElement):
    def __classcall_private__(cls, t: object = ..., check: bool = ...) -> BinaryTree: ...
    def __init__(self, parent: object, t: object, check: bool = ...) -> None: ...
    def check(self) -> None: ...
    def is_empty(self) -> bool: ...
    def graph(self, with_leaves: bool = ...) -> Graph: ...
    def canonical_labelling(self, shift: int = ...) -> LabelledBinaryTree: ...
    def show(self, with_leaves: bool = ...) -> None: ...
    def make_node(self, child_list: tuple[BinaryTree, BinaryTree]) -> BinaryTree: ...
    def make_leaf(self) -> BinaryTree: ...
    def to_dyck_word_tamari(self) -> DyckWord: ...
    def tamari_interval(self, other: BinaryTree) -> TamariIntervalPoset: ...
    def tamari_join(self, other: BinaryTree) -> BinaryTree: ...
    def tamari_meet(self, other: BinaryTree, side: str = ...) -> BinaryTree: ...
    def to_dyck_word(self, usemap: str = ...) -> DyckWord: ...
    def to_ordered_tree_left_branch(self) -> OrderedTree: ...
    def to_ordered_tree_right_branch(self) -> OrderedTree: ...
    def tamari_sorting_tuple(self, reverse: bool = ...) -> tuple[int, ...]: ...
    def to_312_avoiding_permutation(self) -> Permutation: ...
    def as_ordered_tree(self, with_leaves: bool = ...) -> OrderedTree: ...
    def to_undirected_graph(self, with_leaves: bool = ...) -> Graph: ...
    def to_tilting(self) -> list[tuple[int, int]]: ...
    def to_poset(self, with_leaves: bool = ..., root_to_leaf: bool = ...) -> Poset: ...
    def to_132_avoiding_permutation(self) -> Permutation: ...
    def number_of_left_nodes(self, direction: str = ...) -> int: ...
    def left_right_symmetry(self) -> BinaryTree: ...
    def left_border_symmetry(self) -> BinaryTree: ...
    def canopee(self) -> list[int]: ...
    def in_order_traversal_iter(self) -> Iterator[BinaryTree]: ...
    def in_order_traversal(self, node_action: Callable[..., object] | None = ..., leaf_action: Callable[..., object] | None = ...) -> None: ...
    def tamari_lequal(self, t2: BinaryTree) -> bool: ...
    def tamari_greater(self) -> list[BinaryTree]: ...
    def tamari_pred(self) -> list[BinaryTree]: ...
    def tamari_smaller(self) -> list[BinaryTree]: ...
    def tamari_succ(self) -> list[BinaryTree]: ...
    def single_edge_cut_shapes(self) -> list[tuple[BinaryTree, BinaryTree]]: ...
    def comb(self, side: str = ...) -> BinaryTree: ...
    def hook_number(self) -> int: ...
    def twisting_number(self) -> int: ...
    def q_hook_length_fraction(self, q: object | None = ..., q_factor: object | None = ...) -> Element | int: ...
    def right_rotate(self) -> BinaryTree: ...
    def left_rotate(self) -> BinaryTree: ...
    def over(self, bt: BinaryTree) -> BinaryTree: ...
    def under(self, bt: BinaryTree) -> BinaryTree: ...
    def under_decomposition(self) -> list[BinaryTree]: ...
    def over_decomposition(self) -> list[BinaryTree]: ...
    def dendriform_shuffle(self, other: BinaryTree) -> list[BinaryTree]: ...
    def sylvester_class(self, left_to_right: bool = ...) -> list[Permutation]: ...
    def is_full(self) -> bool: ...
    def to_full(self) -> BinaryTree: ...
    def prune(self) -> BinaryTree: ...
    def is_perfect(self) -> bool: ...
    def is_complete(self) -> bool: ...

class BinaryTrees(UniqueRepresentation, Parent):
    def __classcall_private__(cls, size: object = ...) -> Parent: ...
    def leaf(self) -> BinaryTree: ...
