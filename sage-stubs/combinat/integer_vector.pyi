from collections.abc import Iterable
from typing import ClassVar

from sage.modules.specht_module import SpechtModule
from sage.rings.commutative_ring import CommutativeRing
from sage.structure.list_clone import ClonableArray

class IntegerVector(ClonableArray):
    def check(self) -> None: ...
    def trim(self) -> IntegerVector: ...
    def specht_module(self, base_ring: CommutativeRing | None = ...) -> SpechtModule: ...
    def specht_module_dimension(self, base_ring: CommutativeRing | None = ...) -> int: ...
    
    def sum(self) -> int: ...
    def weight(self) -> int: ...
    def length(self) -> int: ...
    def is_zero(self) -> bool: ...

