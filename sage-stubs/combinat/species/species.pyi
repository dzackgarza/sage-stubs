from typing import overload
from collections.abc import Callable
from sage.structure.sage_object import SageObject
from sage.rings.rational_field import RationalField
from sage.combinat.species.structure import StructuresWrapper, IsotypesWrapper

from sage.combinat.species.generating_series import (
    OrdinaryGeneratingSeries,
    ExponentialGeneratingSeries,
    CycleIndexSeries,
)
from sage.rings.ring import Ring
from sage.graphs.digraph import DiGraph
from sage.rings.polynomial.polynomial_element import Polynomial
class GenericCombinatorialSpecies(SageObject):
    _weight: object
    _min: int | None
    _max: int | None

    def __init__(self, min: int | None = ..., max: int | None = ..., weight: object | None = ...) -> None: ...
    def __hash__(self) -> int: ...
    def _unique_info(self) -> tuple[type, int | None, int | None, object]: ...
    def __eq__(self, x: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def _getstate_(self) -> tuple[dict[int, object], dict[str, object]]: ...
    def _setstate_(self, state: tuple[dict[int, object], dict[str, object]]) -> None: ...
    def weighted(self, weight: object) -> GenericCombinatorialSpecies: ...
    def __add__(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def sum(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def __mul__(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def product(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def __call__(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def composition(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def functorial_composition(self, g: GenericCombinatorialSpecies) -> GenericCombinatorialSpecies: ...
    def restricted(self, min: int | None = ..., max: int | None = ...) -> GenericCombinatorialSpecies: ...
    def structures(self, labels: list[int], structure_class: type | None = ...) -> StructuresWrapper: ...
    def isotypes(self, labels: list[int], structure_class: type | None = ...) -> IsotypesWrapper: ...
    def _check(self, n: int = ...) -> bool: ...
    def __pow__(self, n: int) -> GenericCombinatorialSpecies: ...
    def _get_series(self, series_ring_class: type, prefix: str, base_ring: Ring | None = ...) -> ExponentialGeneratingSeries | OrdinaryGeneratingSeries | CycleIndexSeries: ...
    def _series_helper(self, series_ring_class: type, prefix: str, base_ring: Ring | None = ...) -> ExponentialGeneratingSeries | OrdinaryGeneratingSeries | CycleIndexSeries: ...
    def generating_series(self, base_ring: Ring | None = ...) -> ExponentialGeneratingSeries: ...
    def isotype_generating_series(self, base_ring: Ring | None = ...) -> OrdinaryGeneratingSeries: ...
    def cycle_index_series(self, base_ring: Ring | None = ...) -> CycleIndexSeries: ...
    def is_weighted(self) -> bool: ...
    def weight_ring(self) -> RationalField: ...
    def _common_parent(self, parents: list[Ring]) -> Ring: ...
    def digraph(self) -> DiGraph: ...
    def _add_to_digraph(self, d: DiGraph) -> None: ...
    def algebraic_equation_system(self) -> list[Polynomial]: ...
