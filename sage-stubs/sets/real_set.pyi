from collections.abc import Iterable, Iterator

from sage.categories.sets_cat import _SympySetLike
from sage.rings.infinity import PlusInfinity
from sage.rings.integer import Integer
from sage.rings.rational import Rational
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.structure.unique_representation import UniqueRepresentation

from .set import Set_add_sub_operators, Set_base, Set_boolean_operators, Set_generic

class InternalRealInterval(UniqueRepresentation, Parent):
    def __init__(
        self,
        lower: Rational | Integer | float | None = ...,
        upper: Rational | Integer | float | None = ...,
        *,
        lower_closed: bool = ...,
        upper_closed: bool = ...,
    ) -> None: ...
    def is_empty(self) -> bool: ...
    def is_point(self) -> bool: ...
    def lower(self) -> Rational | Integer | None: ...
    def upper(self) -> Rational | Integer | None: ...
    def lower_closed(self) -> bool: ...
    def upper_closed(self) -> bool: ...
    def lower_open(self) -> bool: ...
    def upper_open(self) -> bool: ...
    def __richcmp__(self, other: object, op: int) -> bool: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def _sympy_condition_(self) -> _SympySetLike: ...
    def _sympy_(self) -> _SympySetLike: ...
    def _giac_condition_(self) -> str: ...
    def closure(self) -> InternalRealInterval: ...
    def interior(self) -> InternalRealInterval: ...
    def boundary_points(self) -> list[Rational | Integer]: ...
    def is_connected(self) -> bool: ...
    def convex_hull(self) -> InternalRealInterval: ...
    def intersection(self, other: InternalRealInterval) -> InternalRealInterval: ...
    def contains(self, x: Rational | Integer | float) -> bool: ...
    def __mul__(self, other: Rational | Integer | float) -> InternalRealInterval: ...
    def __rmul__(self, other: Rational | Integer | float) -> InternalRealInterval: ...
    def _scan_lower(self, x: Rational | Integer | float) -> bool: ...
    def _scan_upper(self, x: Rational | Integer | float) -> bool: ...

class RealSet(
    UniqueRepresentation,
    Parent,
    Set_base,
    Set_boolean_operators,
    Set_add_sub_operators,
):
    def __classcall__(cls, *args: object, **options: object) -> RealSet: ...
    def __init__(self, *args: object, **kwargs: object) -> None: ...
    def __richcmp__(self, other: object, op: int) -> bool: ...
    def __iter__(self) -> Iterator[InternalRealInterval]: ...
    def n_components(self) -> int: ...
    def cardinality(self) -> int | PlusInfinity: ...
    def is_empty(self) -> bool: ...
    def is_universe(self) -> bool: ...
    def get_interval(self, i: int) -> InternalRealInterval: ...
    def __bool__(self) -> bool: ...
    def ambient(self) -> Parent: ...
    def lift(self, x: Element) -> Element: ...
    def retract(self, x: Element) -> Element: ...
    def normalize(self) -> RealSet: ...
    def _repr_(self) -> str: ...
    def _latex_(self) -> str: ...
    def _sympy_condition_(self, variable: Element) -> _SympySetLike: ...
    def _giac_condition_(self) -> str: ...
    def _prep(self, x: Rational | Integer | float) -> Rational | Integer: ...
    def interval(
        self,
        lower: Rational | Integer | float | None = ...,
        upper: Rational | Integer | float | None = ...,
        *,
        lower_closed: bool = ...,
        upper_closed: bool = ...,
    ) -> InternalRealInterval: ...
    def open(
        self,
        lower: Rational | Integer | float,
        upper: Rational | Integer | float,
    ) -> InternalRealInterval: ...
    def closed(
        self,
        lower: Rational | Integer | float,
        upper: Rational | Integer | float,
    ) -> InternalRealInterval: ...
    def point(self, x: Rational | Integer | float) -> InternalRealInterval: ...
    def open_closed(
        self,
        lower: Rational | Integer | float,
        upper: Rational | Integer | float,
    ) -> InternalRealInterval: ...
    def closed_open(
        self,
        lower: Rational | Integer | float,
        upper: Rational | Integer | float,
    ) -> InternalRealInterval: ...
    def unbounded_below_closed(
        self, upper: Rational | Integer | float
    ) -> InternalRealInterval: ...
    def unbounded_below_open(
        self, upper: Rational | Integer | float
    ) -> InternalRealInterval: ...
    def unbounded_above_closed(
        self, lower: Rational | Integer | float
    ) -> InternalRealInterval: ...
    def unbounded_above_open(
        self, lower: Rational | Integer | float
    ) -> InternalRealInterval: ...
    def real_line(self) -> InternalRealInterval: ...
    def _scan(self, x: Rational | Integer | float) -> bool: ...
    def _scan_to_intervals(
        self, points: Iterable[Rational | Integer | int | float]
    ) -> list[InternalRealInterval]: ...
    def union(self, other: Set_generic | Set_base) -> Set_generic: ...
    def intersection(self, other: Set_generic | Set_base) -> Set_generic: ...
    def inf(self) -> Rational | Integer | None: ...
    def sup(self) -> Rational | Integer | None: ...
    def complement(self) -> RealSet: ...
    def difference(self, other: Set_generic | Set_base) -> Set_generic: ...
    def symmetric_difference(self, other: Set_generic | Set_base) -> Set_generic: ...
    def contains(self, x: Rational | Integer | float) -> bool: ...
    def is_subset(self, other: RealSet) -> bool: ...
    def _an_element_(self) -> Element: ...
    def is_open(self) -> bool: ...
    def is_closed(self) -> bool: ...
    def closure(self) -> RealSet: ...
    def interior(self) -> RealSet: ...
    def boundary(self) -> RealSet: ...
    def convex_hull(self) -> RealSet: ...
    def is_connected(self) -> bool: ...
    def is_disjoint(self, other: RealSet) -> bool: ...
    def are_pairwise_disjoint(self, others: Iterable[RealSet]) -> bool: ...
    def simplest_rational(self, x: Rational | Integer | float) -> Rational: ...
    def _sage_input_(self) -> tuple[str, dict[str, object]]: ...
    def __mul__(self, other: Rational | Integer | float) -> RealSet: ...
    def __rmul__(self, other: Rational | Integer | float) -> RealSet: ...
    def _sympy_(self) -> _SympySetLike: ...
