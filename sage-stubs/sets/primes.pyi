from collections.abc import Iterable, Iterator, Sequence

from sage.categories.category import Category
from sage.categories.sets_cat import EmptySetError
from sage.rings.integer import Integer
from sage.rings.rational import Rational
from sage.rings.infinity import PlusInfinity
from sage.structure.unique_representation import UniqueRepresentation

from .set import Set_generic

def _repr_items(items: Sequence[object], left: int = ..., right: int = ...) -> str: ...

class Primes(Set_generic, UniqueRepresentation):
    def __classcall__(cls, *args: object, **options: object) -> Primes: ...
    def __init__(
        self,
        modulus: Integer | int = ...,
        classes: Iterable[Integer | int] | None = ...,
        *,
        included: Iterable[Integer | int] | None = ...,
        excluded: Iterable[Integer | int] | None = ...,
        category: Category | None = ...,
    ) -> None: ...
    def congruence_classes(self) -> tuple[Integer, ...]: ...
    def included(self) -> frozenset[Integer]: ...
    def excluded(self) -> frozenset[Integer]: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def cardinality(self) -> int | PlusInfinity: ...
    def first(self) -> Integer: ...
    def next(self, p: Integer) -> Integer: ...
    def _an_element_(self) -> Integer: ...
    def unrank(self, r: int) -> Integer: ...
    def is_empty(self) -> bool: ...
    def is_finite(self) -> bool: ...
    def is_cofinite(self) -> bool: ...
    def density(self) -> Rational: ...
    def include(
        self,
        elements: Integer | int | Iterable[Integer | int],
        check: bool = ...,
    ) -> Primes: ...
    def exclude(
        self,
        elements: Integer | int | Iterable[Integer | int],
        check: bool = ...,
    ) -> Primes: ...
    def complement_in_primes(self) -> Primes: ...
    def intersection(self, other: Primes) -> Primes: ...
    def union(self, other: Primes) -> Primes: ...
    def is_almost_equal(self, other: Primes) -> bool: ...
    def is_subset(self, other: Primes) -> bool: ...
    def is_superset(self, other: Primes) -> bool: ...
    def is_disjoint(self, other: Primes) -> bool: ...
