from collections.abc import Hashable, Iterable, Iterator
from typing import TypeAlias

from sage.categories.category import Category
from sage.rings.integer import Integer
from sage.structure.category_object import CategoryObject
from sage.structure.element import Element
from sage.structure.parent import Parent

_SetElement: TypeAlias = Element | Hashable | list[Hashable]
_SetInput: TypeAlias = CategoryObject | Iterable[_SetElement] | None
_SetOperand: TypeAlias = Set_base | Set_object

def has_finite_length(obj: Iterable[_SetElement]) -> bool: ...
def Set(X: _SetInput = None, category: Category | None = None) -> Set_object: ...

class Set_base:
    def union(self, X: _SetOperand) -> Set_object: ...
    def intersection(self, X: _SetOperand) -> Set_object: ...
    def difference(self, X: _SetOperand) -> Set_object: ...
    def symmetric_difference(self, X: _SetOperand) -> Set_object: ...

class Set_boolean_operators:
    def __or__(self, X: _SetOperand) -> Set_object: ...
    def __and__(self, X: _SetOperand) -> Set_object: ...
    def __xor__(self, X: _SetOperand) -> Set_object: ...

class Set_add_sub_operators:
    def __add__(self, X: _SetOperand) -> Set_object: ...
    def __sub__(self, X: _SetOperand) -> Set_object: ...

class Set_generic(Parent):
    def object(self) -> Set_generic | _SetInput: ...
    def __bool__(self) -> bool: ...

class Set_object(Set_generic, Set_base, Set_boolean_operators, Set_add_sub_operators):
    def __init__(self, X: _SetInput, category: Category | None = None) -> None: ...
    def __hash__(self) -> int: ...
    def __iter__(self) -> Iterator[_SetElement]: ...
    def _an_element_(self) -> _SetElement: ...
    def __contains__(self, x: object) -> bool: ...
    def cardinality(self) -> Integer: ...
    def is_empty(self) -> bool: ...
    def is_finite(self) -> bool: ...
    def object(self) -> _SetInput: ...
    def subsets(self, size: int | Integer | None = None) -> Parent: ...
    def subsets_lattice(self) -> Parent: ...

class Set_object_enumerated(Set_object):
    def __init__(self, X: _SetInput, category: Category | None = None) -> None: ...
    def random_element(self) -> _SetElement: ...
    def is_finite(self) -> bool: ...
    def cardinality(self) -> Integer: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[_SetElement]: ...
    def list(self) -> list[_SetElement]: ...
    def set(self) -> set[_SetElement]: ...
    def frozenset(self) -> frozenset[_SetElement]: ...
    def __hash__(self) -> int: ...
    def isdisjoint(self, other: Iterable[_SetElement]) -> bool: ...
    def is_disjoint(self, other: Iterable[_SetElement]) -> bool: ...
    def issubset(self, other: Iterable[_SetElement]) -> bool: ...
    def is_subset(self, other: Iterable[_SetElement]) -> bool: ...
    def issuperset(self, other: Iterable[_SetElement]) -> bool: ...
    def is_superset(self, other: Iterable[_SetElement]) -> bool: ...
    def union(self, other: _SetOperand | Iterable[_SetElement]) -> Set_object: ...
    def intersection(self, other: _SetOperand | Iterable[_SetElement]) -> Set_object: ...
    def difference(self, other: _SetOperand | Iterable[_SetElement]) -> Set_object: ...
    def symmetric_difference(self, other: _SetOperand | Iterable[_SetElement]) -> Set_object: ...
