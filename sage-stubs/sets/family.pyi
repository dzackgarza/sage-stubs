from collections.abc import Callable, Iterable, Iterator
from typing import Self

from sage.rings.integer import Integer
from sage.structure.element import Element
from sage.structure.parent import Parent

class AbstractFamily(Parent):
    def hidden_keys(self) -> list[object]: ...
    def keys(self) -> Iterable[object]: ...
    def values(self) -> Iterable[Element]: ...
    def items(self) -> Iterable[tuple[object, Element]]: ...
    def zip(
        self,
        f: Callable[[object, object], Element],
        other: AbstractFamily,
        name: str | None = ...,
    ) -> AbstractFamily: ...
    def map(
        self,
        f: Callable[[object], Element],
        name: str | None = ...,
    ) -> AbstractFamily: ...
    def inverse_family(self) -> AbstractFamily: ...

class Family(AbstractFamily):
    def __new__(
        cls,
        indices: object,
        function: Callable[[object], Element] | None = ...,
        hidden_keys: list[object] = ...,
        hidden_function: Callable[[object], Element] | None = ...,
        lazy: bool = ...,
        name: str | None = ...,
    ) -> Family: ...

class FiniteFamily(AbstractFamily):
    def __init__(
        self,
        dictionary: dict[object, Element],
        keys: Iterable[object] | None = ...,
    ) -> None: ...
    def __hash__(self) -> int: ...
    def __bool__(self) -> bool: ...
    def keys(self) -> Iterable[object]: ...
    def values(self) -> Iterable[Element]: ...
    def has_key(self, k: object) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def __len__(self) -> int: ...
    def cardinality(self) -> int: ...
    def __iter__(self) -> Iterator[Element]: ...
    def __getitem__(self, i: object) -> Element: ...
    def __getstate__(self) -> dict[str, object]: ...
    def __setstate__(self, state: dict[str, object]) -> None: ...

class FiniteFamilyWithHiddenKeys(FiniteFamily):
    def __init__(
        self,
        dictionary: dict[object, Element],
        hidden_keys: list[object],
        hidden_function: Callable[[object], Element],
        keys: Iterable[object] | None = ...,
    ) -> None: ...
    def __getitem__(self, i: object) -> Element: ...
    def hidden_keys(self) -> list[object]: ...
    def __getstate__(self) -> dict[str, object]: ...
    def __setstate__(self, d: dict[str, object]) -> None: ...

class LazyFamily(AbstractFamily):
    def __init__(
        self,
        set: Parent,
        function: Callable[[object], Element],
        name: str | None = ...,
    ) -> None: ...
    def __bool__(self) -> bool: ...
    def __hash__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def _repr_(self) -> str: ...
    def keys(self) -> Iterable[object]: ...
    def cardinality(self) -> int | Integer: ...
    def __iter__(self) -> Iterator[Element]: ...
    def __contains__(self, x: object) -> bool: ...
    def __getitem__(self, i: object) -> Element: ...
    def __getstate__(self) -> dict[str, object]: ...
    def __setstate__(self, d: dict[str, object]) -> None: ...

class TrivialFamily(AbstractFamily):
    def __init__(self, enumeration: Iterable[Element]) -> None: ...
    def __bool__(self) -> bool: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def _repr_(self) -> str: ...
    def keys(self) -> Iterable[object]: ...
    def cardinality(self) -> int: ...
    def __iter__(self) -> Iterator[Element]: ...
    def __contains__(self, x: object) -> bool: ...
    def __getitem__(self, i: object) -> Element: ...
    def __getstate__(self) -> dict[str, object]: ...
    def __setstate__(self, state: dict[str, object]) -> None: ...
    def map(
        self,
        f: Callable[[object], Element],
        name: str | None = ...,
    ) -> AbstractFamily: ...

class EnumeratedFamily(LazyFamily):
    def __init__(self, enumset: Parent) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __repr__(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def cardinality(self) -> int | Integer: ...
    def __iter__(self) -> Iterator[Element]: ...
    def __getitem__(self, i: object) -> Element: ...
    def __getstate__(self) -> dict[str, object]: ...
    def __setstate__(self, state: dict[str, object]) -> None: ...
