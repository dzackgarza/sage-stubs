from collections.abc import Callable, Hashable, Iterable, Iterator
from typing import Protocol, TypeAlias

from sage.categories.category import Category
from sage.categories.map import Map
from sage.rings.integer import Integer
from sage.sets.set import Set_add_sub_operators, Set_base, Set_boolean_operators
from sage.structure.element import Element
from sage.structure.parent import Parent

_ImageElement: TypeAlias = Element | Hashable | list[Hashable]
_ImageMap: TypeAlias = Map | Callable[[Element | Hashable], _ImageElement]

class SympySet(Protocol):
    def _sage_(self) -> Parent: ...

class ImageSubobject(Parent):
    def __init__(
        self,
        map: _ImageMap,
        domain_subset: Parent | Iterable[Element | Hashable],
        *,
        category: Category | None = ...,
        is_injective: bool | str | None = ...,
        inverse: Callable[[_ImageElement], Element | Hashable] | None = ...,
    ) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def _element_constructor_(self, x: _ImageElement) -> _ImageElement: ...
    def ambient(self) -> Parent | None: ...
    def lift(self, x: _ImageElement) -> _ImageElement: ...
    def retract(self, x: _ImageElement) -> _ImageElement: ...
    def cardinality(self) -> Integer: ...
    def __iter__(self) -> Iterator[_ImageElement]: ...
    def __contains__(self, x: object) -> bool: ...
    def _an_element_(self) -> _ImageElement: ...
    def _sympy_(self) -> SympySet: ...

class ImageSet(ImageSubobject, Set_base, Set_add_sub_operators, Set_boolean_operators): ...
