from collections.abc import Callable, Iterator

from sage.categories.map import Map
from sage.categories.sets_cat import _SympySetLike
from sage.rings.infinity import PlusInfinity
from sage.structure.element import Element
from sage.structure.parent import Parent

from .set import Set_add_sub_operators, Set_base, Set_boolean_operators

class ImageSubobject(Parent):
    def __init__(
        self,
        map: Map | Callable[[object], object],
        domain_subset: Parent | object,
        *,
        category: object | None = ...,
        is_injective: bool | str | None = ...,
        inverse: Callable[[object], object] | None = ...,
    ) -> None: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def _element_constructor_(self, x: object) -> Element: ...
    def ambient(self) -> Parent: ...
    def lift(self, x: Element) -> Element: ...
    def retract(self, x: Element) -> Element: ...
    def _repr_(self) -> str: ...
    def cardinality(self) -> int | PlusInfinity: ...
    def __iter__(self) -> Iterator[Element]: ...
    def _an_element_(self) -> Element: ...
    def _sympy_(self) -> _SympySetLike: ...

class ImageSet(
    ImageSubobject, Set_base, Set_add_sub_operators, Set_boolean_operators
):
    ...
