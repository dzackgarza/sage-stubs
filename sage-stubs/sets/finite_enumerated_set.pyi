from collections.abc import Iterable, Iterator
from sage.rings.integer import Integer
from sage.structure.element import Element
from sage.structure.parent import Parent
from sage.structure.unique_representation import UniqueRepresentation

class FiniteEnumeratedSet(UniqueRepresentation, Parent):
    def __classcall__(cls, *args: object, **options: object) -> FiniteEnumeratedSet: ...
    def __init__(self, elements: tuple[object, ...]) -> None: ...
    def __bool__(self) -> bool: ...
    def _repr_(self) -> str: ...
    def __contains__(self, x: object) -> bool: ...
    def __iter__(self) -> Iterator[object]: ...
    def list(self) -> list[object]: ...
    def an_element(self) -> Element: ...
    def first(self) -> Element: ...
    def last(self) -> Element: ...
    def random_element(self) -> Element: ...
    def cardinality(self) -> int: ...
    def rank(self, x: object) -> int: ...
    def unrank(self, r: int) -> Element: ...
    def __call__(self, *args: object, **kwargs: object) -> Element: ...
    def _element_constructor_(self, x: object) -> Element: ...
