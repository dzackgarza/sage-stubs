from collections.abc import Callable, Iterable, Iterator

from sage.categories.category import Category
from sage.structure.parent import Parent

class RecursivelyEnumeratedSet_forest(Parent):
    def __init__(
        self,
        roots: Iterable[object] | None = None,
        children: Callable[[object], Iterable[object]] | None = None,
        post_process: Callable[[object], object | None] | None = None,
        algorithm: str = 'depth',
        facade: Parent | None = None,
        category: Category | None = None,
    ) -> None: ...
    def _repr_(self) -> str: ...
    def roots(self) -> Iterable[object]: ...
    def children(self, x: object) -> Iterable[object]: ...
    def __iter__(self) -> Iterator[object]: ...
    def depth_first_search_iterator(self) -> Iterator[object]: ...
    def breadth_first_search_iterator(self) -> Iterator[object]: ...
    def _elements_of_depth_iterator_rec(self, depth: int = 0) -> Iterator[object]: ...
    def elements_of_depth_iterator(self, depth: int = 0) -> Iterator[object]: ...
    def __contains__(self, elt: object) -> bool: ...
