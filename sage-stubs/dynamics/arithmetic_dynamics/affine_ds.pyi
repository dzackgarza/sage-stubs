from sage.categories.category import Category
from sage.rings.ring import Ring
from sage.rings.integer import Integer
from sage.schemes.generic.morphism import SchemeMorphism
from sage.schemes.affine.affine_space import AffineSpace_generic
from sage.structure.element import Element
from sage.schemes.affine.affine_morphism import SchemeMorphism_polynomial_affine_space
from sage.dynamics.arithmetic_dynamics.generic_ds import DynamicalSystem

class DynamicalSystem_affine(SchemeMorphism_polynomial_affine_space, DynamicalSystem):
    def __init__(self, polys_or_rat_fncts: list[Element] | tuple[Element, ...], domain: AffineSpace_generic) -> None: ...
    def homogenize(self, n: tuple[int, int] | int) -> SchemeMorphism: ...
    def dynatomic_polynomial(self, period: list[int] | tuple[int, ...] | int) -> Element: ...
    def nth_iterate_map(self, n: int) -> SchemeMorphism: ...
    def nth_iterate(self, P: Element, n: int) -> Element: ...
    def orbit(self, P: Element, n: int | list[int] | tuple[int, int]) -> list[Element]: ...
    def multiplier(self, P: Element, n: int, check: bool = ...) -> Element: ...
    def conjugate(self, M: Element) -> SchemeMorphism: ...
    def degree(self) -> Integer | int | Element: ...

from sage.schemes.affine.affine_morphism import SchemeMorphism_polynomial_affine_space_field, SchemeMorphism_polynomial_affine_space_finite_field
from sage.graphs.digraph import DiGraph

class DynamicalSystem_affine_field(DynamicalSystem_affine, SchemeMorphism_polynomial_affine_space_field):
    def weil_restriction(self) -> SchemeMorphism: ...
    def reduce_base_field(self) -> SchemeMorphism: ...

class DynamicalSystem_affine_finite_field(DynamicalSystem_affine_field, SchemeMorphism_polynomial_affine_space_finite_field):
    def orbit_structure(self, P: Element) -> list[int] | tuple[int, int]: ...
    def cyclegraph(self) -> DiGraph: ...
